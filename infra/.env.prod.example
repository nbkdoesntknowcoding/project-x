# ── Infra passwords (generate with: openssl rand -hex 24) ─────────────────────
POSTGRES_PASSWORD=FILL_ME
REDIS_PASSWORD=FILL_ME

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=8080
COLLAB_PORT=1234
LOG_LEVEL=info

# ── Public URLs ───────────────────────────────────────────────────────────────
PUBLIC_MCP_URL=https://api.theboringpeople.in
MCP_BASE_URL=https://api.theboringpeople.in
MCP_AUTHORIZATION_SERVER=https://api.theboringpeople.in
OAUTH_ISSUER=https://api.theboringpeople.in
WEB_BASE_URL=https://mnema.theboringpeople.in
PUBLIC_COLLAB_URL=wss://api.theboringpeople.in/collab
COLLAB_INTERNAL_URL=http://collab:1234
PUBLIC_SITE_URL=https://mnema.theboringpeople.in
CORS_ORIGINS=https://mnema.theboringpeople.in

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=FILL_ME
JWT_ISSUER=https://api.theboringpeople.in
JWT_AUDIENCE=https://mnema.theboringpeople.in
JWT_AUDIENCE_MCP=https://api.theboringpeople.in/mcp

# ── WorkOS ────────────────────────────────────────────────────────────────────
WORKOS_CLIENT_ID=FILL_ME
WORKOS_CLIENT_SECRET=FILL_ME
WORKOS_REDIRECT_URI=https://api.theboringpeople.in/auth/callback
WORKOS_WEBHOOK_SECRET=FILL_ME
FRONTEND_URL=https://mnema.theboringpeople.in

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=FILL_ME
EMAIL_FROM=FILL_ME

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=FILL_ME
RAZORPAY_KEY_SECRET=FILL_ME
RAZORPAY_WEBHOOK_SECRET=FILL_ME

# ── AI / Embeddings ───────────────────────────────────────────────────────────
GEMINI_API_KEY=FILL_ME
VOYAGE_AI_API_KEY=FILL_ME
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=128
EMBEDDING_WORKER_CONCURRENCY=2

# ── Autocomplete ──────────────────────────────────────────────────────────────
AUTOCOMPLETE_MODEL=gemini-2.5-flash-lite
AUTOCOMPLETE_DEBOUNCE_MS=350
AUTOCOMPLETE_MAX_PREFIX_CHARS=2000
AUTOCOMPLETE_MAX_SUFFIX_CHARS=500
AUTOCOMPLETE_STOP_SEQUENCES=\n\n
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_USER_PER_DAY=1000
RATE_LIMIT_TENANT_DAILY_UNITS=50000

# ── MCP protocol ─────────────────────────────────────────────────────────────
MCP_PROTOCOL_VERSION=2025-11-25
MCP_ORIGIN_ALLOWLIST=https://mnema.theboringpeople.in

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
