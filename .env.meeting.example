# Meeting Bot env keys — ADD these to infra/.env on the VPS (the meeting compose
# reads --env-file/env_file infra/.env). The core Mnema keys (DATABASE_URL etc.)
# already live there; append the ones below.

# ── Recall.ai (joins the meeting + streams audio) ────────────────────────────
RECALL_API_KEY=                  # rotate the one pasted in chat
RECALL_REGION=ap-northeast-1
# Public wss URL Recall pushes mixed audio to (Caddy → pipecat-meeting). Include a
# random secret in the path so only Recall (which we told the URL) can connect.
RECALL_AUDIO_WSS=wss://meet-ws.theboringpeople.in/<MEETING_WS_SECRET>
MEETING_WS_SECRET=               # random string; must match the path in RECALL_AUDIO_WSS

# ── VAP pipeline (Pipecat) — same keys as the voice agent ────────────────────
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=             # cloned voice id
ELEVENLABS_MODEL=eleven_flash_v2_5   # optional; output is mp3 (Recall Output Audio)

# ── Mnema API (the bot calls back into Mnema to create tasks/docs) ───────────
MNEMA_API_URL=https://api.theboringpeople.in
MNEMA_API_KEY=
