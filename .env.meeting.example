# Meeting Bot env keys — ADD these to infra/.env on the VPS (the meeting compose
# reads --env-file infra/.env). The core Mnema keys (DATABASE_URL etc.) already
# live there; append the ones below.

# VAP pipeline (Pipecat) — reuse the same keys as the voice agent
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=             # cloned voice id
ELEVENLABS_OUTPUT_FORMAT=ulaw_8000
ACTIVE_PERSONA_ID=               # optional — meeting-observer persona row

# Meeting bot
BOT_GOOGLE_EMAIL=                # dedicated bot Google account
ENABLE_INJECTION=false           # Phase 2 gate — keep false until Phase 1 verified

# Mnema API (the bot calls back into Mnema to create tasks/docs)
MNEMA_API_URL=https://api.theboringpeople.in
MNEMA_API_KEY=                   # service account key (mnema_api_ prefix)
