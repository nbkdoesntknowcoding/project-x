---
/**
 * IsoFigures — a Mnema translation of Raycast's exploded isometric "blue box"
 * element diagrams (imgs 3–4): real Mnema UI surfaces blown apart into layered
 * plates on a dotted ground plane, with FIG_0x mono labels + annotations.
 * Pure CSS 3D transforms (no JS). Indigo technical-diagram accent + amber.
 */
---

<div class="iso-root">
  <!-- heading -->
  <div class="iso-head">
    <span class="iso-eyebrow">Composable down to the element</span>
    <h2 class="iso-title">Every surface is just<br />docs, wired together.</h2>
    <p class="iso-desc">
      The workspace, the editor, the MCP panel, the graph — each is the same
      content, addressed and composed. Pull any layer through MCP; edit one and
      the rest update live.
    </p>
    <a class="iso-link" href="/docs">Read the docs <span aria-hidden="true">→</span></a>
  </div>

  <!-- big figure: the workspace, exploded -->
  <div class="iso-wrap" aria-hidden="true">
    <span class="iso-fig-label">FIG_01 — workspace</span>

    <div class="iso-stage">
      <!-- dotted ground plane -->
      <div class="iso-ground"></div>

      <!-- plate 1: doc list -->
      <div class="iso-plate" style="transform: translate3d(-46px, 54px, 26px);">
        <div class="iso-plate-head">DOC LIST</div>
        <div class="iso-rows">
          <span class="iso-drow on"></span>
          <span class="iso-drow"></span>
          <span class="iso-drow"></span>
          <span class="iso-drow"></span>
        </div>
      </div>

      <!-- plate 2: editor -->
      <div class="iso-plate wide" style="transform: translate3d(2px, 4px, 96px);">
        <div class="iso-plate-head">EDITOR</div>
        <span class="iso-bar" style="width:70%"></span>
        <span class="iso-bar" style="width:52%"></span>
        <span class="iso-bar" style="width:62%"></span>
        <span class="iso-bar amber" style="width:38%"></span>
      </div>

      <!-- plate 3: mcp panel -->
      <div class="iso-plate" style="transform: translate3d(54px, -44px, 168px);">
        <div class="iso-plate-head"><span class="dot"></span>MCP PANEL</div>
        <span class="iso-bar" style="width:80%"></span>
        <span class="iso-bar" style="width:60%"></span>
        <div class="iso-chip">get_flow()</div>
      </div>
    </div>

    <!-- annotations (screen space) -->
    <span class="iso-anno a1">SEARCH · ADDRESSABLE</span>
    <span class="iso-anno a2">LIVE · 38ms</span>
    <span class="iso-anno a3">READ VIA MCP</span>
  </div>
</div>

<style>
  .iso-root {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 860px) {
    .iso-root { grid-template-columns: 1fr; gap: 24px; }
  }

  /* heading */
  .iso-eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 14px;
  }
  .iso-title {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 32px;
    line-height: 1.14;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 16px;
  }
  .iso-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 30rem;
    margin: 0 0 22px;
  }
  .iso-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--border-default);
    padding-bottom: 3px;
    transition: border-color 160ms;
  }
  .iso-link:hover { border-color: #7C9CFF; }

  /* figure stage */
  .iso-wrap {
    position: relative;
    height: 460px;
    perspective: 1300px;
    overflow: hidden;
  }
  .iso-fig-label {
    position: absolute;
    top: 6px;
    left: 8px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-quaternary);
    z-index: 4;
  }
  .iso-stage {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateX(56deg) rotateZ(-46deg) scale(0.94);
  }
  .iso-ground {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 460px;
    height: 380px;
    margin: -190px 0 0 -230px;
    background-image: radial-gradient(rgba(124, 156, 255, 0.22) 1.2px, transparent 1.2px);
    background-size: 26px 26px;
    border: 1px solid rgba(124, 156, 255, 0.12);
    border-radius: 6px;
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 40%, transparent 90%);
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 40%, transparent 90%);
  }
  .iso-plate {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 250px;
    height: 150px;
    margin: -75px 0 0 -125px;
    padding: 12px 14px;
    border-radius: 11px;
    border: 1px solid rgba(124, 156, 255, 0.5);
    background:
      linear-gradient(155deg, rgba(124, 156, 255, 0.13), rgba(8, 9, 12, 0.92));
    box-shadow:
      0 0 0 1px rgba(124, 156, 255, 0.08),
      0 40px 50px -24px rgba(0, 0, 0, 0.85),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .iso-plate.wide { width: 290px; margin-left: -145px; }
  .iso-plate-head {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9db0e8;
    margin-bottom: 12px;
  }
  .iso-plate-head .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--status-sync);
    box-shadow: 0 0 8px rgba(107, 227, 155, 0.7);
  }
  .iso-rows { display: flex; flex-direction: column; gap: 8px; }
  .iso-drow {
    height: 12px;
    border-radius: 4px;
    background: rgba(124, 156, 255, 0.12);
    border: 1px solid rgba(124, 156, 255, 0.2);
  }
  .iso-drow.on {
    background: rgba(124, 156, 255, 0.26);
    border-color: rgba(124, 156, 255, 0.5);
  }
  .iso-bar {
    display: block;
    height: 9px;
    border-radius: 4px;
    background: rgba(124, 156, 255, 0.22);
    margin-bottom: 9px;
  }
  .iso-bar.amber { background: rgba(255, 179, 112, 0.5); }
  .iso-chip {
    display: inline-block;
    margin-top: 4px;
    font-family: var(--mono);
    font-size: 9px;
    color: #FFB370;
    background: rgba(255, 179, 112, 0.12);
    border: 1px solid rgba(255, 179, 112, 0.32);
    border-radius: 5px;
    padding: 2px 6px;
  }

  /* annotations */
  .iso-anno {
    position: absolute;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    padding-left: 14px;
    z-index: 4;
  }
  .iso-anno::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 9px;
    height: 1px;
    background: rgba(124, 156, 255, 0.55);
  }
  .iso-anno.a1 { left: 6%; top: 66%; }
  .iso-anno.a2 { right: 8%; top: 50%; }
  .iso-anno.a3 { right: 10%; top: 24%; }

  @media (prefers-reduced-motion: reduce) {
    .iso-stage { transform: rotateX(56deg) rotateZ(-46deg) scale(0.94); }
  }

  /* secondary figure row */
  .iso-row {
    display: flex;
    gap: 20px;
    margin-top: 56px;
    padding-top: 48px;
    border-top: 1px solid var(--border-subtle);
  }
  .iso-row > .iso-mini { flex: 1 1 0; min-width: 0; }
  @media (max-width: 860px) {
    .iso-row { flex-direction: column; }
  }
  .iso-mini {
    position: relative;
    min-height: 296px;
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    background: var(--surface-overlay);
    padding: 0 20px 22px;
    overflow: hidden;
  }
  .iso-mini-fig {
    position: absolute;
    top: 12px;
    left: 16px;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    color: var(--text-quaternary);
    z-index: 3;
  }
  .iso-mini-stage {
    position: relative;
    height: 184px;
    perspective: 760px;
  }
  .iso-mini-3d {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateX(56deg) rotateZ(-46deg) scale(0.7);
  }
  .iso-mground {
    position: absolute;
    left: 50%; top: 50%;
    width: 230px; height: 190px;
    margin: -95px 0 0 -115px;
    border: 1px solid rgba(124, 156, 255, 0.12);
    border-radius: 6px;
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 35%, transparent 88%);
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 35%, transparent 88%);
  }
  .iso-mground.dots {
    background-image: radial-gradient(rgba(124, 156, 255, 0.26) 1.1px, transparent 1.1px);
    background-size: 22px 22px;
  }
  .iso-mplate {
    position: absolute;
    left: 50%; top: 50%;
    width: 120px; height: 80px;
    margin: -40px 0 0 -60px;
    border-radius: 10px;
    border: 1px solid rgba(124, 156, 255, 0.5);
    background: linear-gradient(155deg, rgba(124, 156, 255, 0.14), rgba(8, 9, 12, 0.92));
    box-shadow: 0 26px 32px -18px rgba(0, 0, 0, 0.85), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .iso-mplate.wide { width: 150px; margin-left: -75px; }
  .iso-mplate .n {
    font-family: var(--mono);
    font-size: 18px;
    color: #9db0e8;
  }
  .iso-mplate .code {
    font-family: var(--mono);
    font-size: 11px;
    color: #FFB370;
  }
  .iso-mplate .code.ok { color: var(--status-sync); }
  .iso-gnode {
    position: absolute;
    left: 50%; top: 50%;
    width: 16px; height: 16px;
    margin: -8px 0 0 -8px;
    border-radius: 5px;
    background: var(--c);
    box-shadow: 0 0 16px 2px color-mix(in oklab, var(--c) 60%, transparent), 0 18px 22px -10px rgba(0,0,0,0.8);
  }
  .iso-gnode.big { width: 24px; height: 24px; margin: -12px 0 0 -12px; border-radius: 7px; }

  .iso-mini-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 4px 0 6px;
    letter-spacing: -0.01em;
  }
  .iso-mini-desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-tertiary);
    margin: 0;
  }
</style>
