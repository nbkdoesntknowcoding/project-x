---
/**
 * IsoFigures — Mnema's exploded isometric element diagrams (Raycast-style).
 * SVG, with real 3D boxes (top + side faces = thickness) and UI content drawn on
 * the top faces, plus leader lines that connect labels to plate corners.
 */

// ── Isometric projection (2:1 dimetric) ─────────────────────────────────────
const C = 0.866;
const S = 0.5;
const iso = (x: number, y: number, z: number, ox: number, oy: number): [number, number] => [
  (x - y) * C + ox,
  (x + y) * S - z + oy,
];
const pt = (p: [number, number]) => `${p[0].toFixed(1)},${p[1].toFixed(1)}`;

function rect(cx: number, cy: number, z: number, w: number, d: number, ox: number, oy: number) {
  return {
    tl: iso(cx - w / 2, cy - d / 2, z, ox, oy),
    tr: iso(cx + w / 2, cy - d / 2, z, ox, oy),
    br: iso(cx + w / 2, cy + d / 2, z, ox, oy),
    bl: iso(cx - w / 2, cy + d / 2, z, ox, oy),
  };
}
const polyR = (c: ReturnType<typeof rect>) => `${pt(c.tl)} ${pt(c.tr)} ${pt(c.br)} ${pt(c.bl)}`;

// A solid iso box: top face + the two faces the viewer sees (right + left).
function box(cx: number, cy: number, z: number, w: number, d: number, t: number, ox: number, oy: number) {
  const top = rect(cx, cy, z, w, d, ox, oy);
  const bot = rect(cx, cy, z - t, w, d, ox, oy);
  return {
    top: polyR(top),
    right: `${pt(top.tr)} ${pt(top.br)} ${pt(bot.br)} ${pt(bot.tr)}`,
    left: `${pt(top.bl)} ${pt(top.br)} ${pt(bot.br)} ${pt(bot.bl)}`,
    corners: top,
  };
}
// A thin bar of UI content lying on a face at height z.
const bar = (cx: number, cy: number, z: number, w: number, d: number, ox: number, oy: number) =>
  polyR(rect(cx, cy, z, w, d, ox, oy));

const IND = 'rgba(124,156,255,'; // indigo with alpha suffix

// ── FIG_01 — the workspace, exploded into 4 boxes with content ──────────────
const OX = 280;
const OY = 188;
const W = 152;
const D = 92;
const T = 9;
type Bar = { poly: string; fill: string };
const f1defs = [
  {
    z: 156, label: 'COMMAND', side: 'r',
    bars: [
      { cx: 0, cy: -16, w: 124, d: 16, fill: 'rgba(255,179,112,0.55)' },
      { cx: -28, cy: 8, w: 60, d: 7, fill: IND + '0.32)' },
      { cx: -32, cy: 22, w: 50, d: 7, fill: IND + '0.22)' },
    ],
  },
  {
    z: 104, label: 'EDITOR', side: 'r',
    bars: [
      { cx: -6, cy: -22, w: 100, d: 6, fill: IND + '0.3)' },
      { cx: -16, cy: -8, w: 78, d: 6, fill: IND + '0.22)' },
      { cx: -2, cy: 6, w: 92, d: 6, fill: IND + '0.26)' },
      { cx: -24, cy: 20, w: 56, d: 6, fill: IND + '0.2)' },
    ],
  },
  {
    z: 52, label: 'DOC LIST', side: 'l',
    bars: [
      { cx: -52, cy: -20, w: 8, d: 8, fill: IND + '0.5)' },
      { cx: 4, cy: -20, w: 96, d: 7, fill: IND + '0.28)' },
      { cx: -52, cy: -2, w: 8, d: 8, fill: IND + '0.3)' },
      { cx: 4, cy: -2, w: 96, d: 7, fill: IND + '0.2)' },
      { cx: -52, cy: 16, w: 8, d: 8, fill: IND + '0.3)' },
      { cx: 4, cy: 16, w: 80, d: 7, fill: IND + '0.2)' },
    ],
  },
  { z: 0, label: 'GRAPH', side: 'l', graph: true, bars: [] as { cx: number; cy: number; w: number; d: number; fill: string }[] },
].map((l) => {
  const b = box(0, 0, l.z, W, D, T, OX, OY);
  const cy = OY - l.z;
  const anchor = l.side === 'r' ? b.corners.tr : b.corners.bl;
  const labelX = l.side === 'r' ? 512 : 70;
  const bars: Bar[] = (l.bars ?? []).map((bb) => ({ poly: bar(bb.cx, bb.cy, l.z, bb.w, bb.d, OX, OY), fill: bb.fill }));
  // graph nodes for the base plate
  const gnodes = l.graph
    ? [
        { x: -34, y: -14, c: '#a78bfa', r: 4 },
        { x: 10, y: -22, c: '#60a5fa', r: 3.4 },
        { x: 40, y: 6, c: '#FFB370', r: 3.4 },
        { x: -6, y: 22, c: '#6BE39B', r: 3 },
        { x: 16, y: 4, c: '#e879f9', r: 4.6 },
      ].map((n) => ({ ...n, p: iso(n.x, n.y, l.z + 2, OX, OY) }))
    : [];
  const gedges = l.graph ? ([[0, 4], [1, 4], [2, 4], [3, 0]] as [number, number][]) : [];
  return { ...l, ...b, cy, anchor, labelX, bars, gnodes, gedges };
});

// ── FIG_02 — sequenced flow: 3 doc-boxes with content, connected ────────────
const F2 = [0, 34, 68].map((z, i) => {
  const b = box(0, 0, z, 76, 52, 8, 100, 104);
  return {
    i,
    box: b,
    lines: [bar(-6, -10, z, 46, 5, 100, 104), bar(-12, 4, z, 34, 5, 100, 104)],
    dot: bar(-26, -10, z, 7, 7, 100, 104),
    center: iso(0, 0, z, 100, 104),
    next: iso(0, 0, z + 34, 100, 104),
  };
});

// ── FIG_03 — knowledge graph: a base plane + a real little network ──────────
const F3plane = box(0, 0, 0, 120, 88, 5, 100, 92);
const F3nodes = [
  { x: -38, y: -16, z: 20, c: '#a78bfa', r: 5 },
  { x: 8, y: -28, z: 40, c: '#60a5fa', r: 4 },
  { x: 38, y: -8, z: 30, c: '#FFB370', r: 4 },
  { x: 30, y: 22, z: 16, c: '#6BE39B', r: 3.5 },
  { x: -18, y: 26, z: 24, c: '#7C9CFF', r: 3.5 },
  { x: -2, y: 2, z: 56, c: '#e879f9', r: 6.5 },
].map((n) => ({ ...n, p: iso(n.x, n.y, n.z, 100, 92), base: iso(n.x, n.y, 2, 100, 92) }));
const F3edges: [number, number][] = [[0, 5], [1, 5], [2, 5], [3, 5], [4, 0], [1, 2], [3, 2]];

// ── FIG_04 — MCP terminal box with code content ─────────────────────────────
const F4 = box(0, 0, 0, 116, 70, 10, 100, 78);
const F4lines = [
  { poly: bar(-18, -22, 0, 66, 5, 100, 78), fill: 'rgba(255,179,112,0.5)' },
  { poly: bar(-30, -8, 0, 42, 5, 100, 78), fill: IND + '0.28)' },
  { poly: bar(-26, 6, 0, 50, 5, 100, 78), fill: IND + '0.28)' },
  { poly: bar(-34, 20, 0, 34, 5, 100, 78), fill: 'rgba(107,227,155,0.55)' },
];
---

<div class="iso-root">
  <div class="iso-head">
    <span class="iso-eyebrow">Composable down to the element</span>
    <h2 class="iso-title">Every surface is just<br />docs, wired together.</h2>
    <p class="iso-desc">
      The command bar, the editor, the doc list, the graph — each is a view onto
      the same content. Pull any layer through MCP; edit one and the rest update live.
    </p>
    <a class="iso-link" href="/docs">Read the docs <span aria-hidden="true">→</span></a>
  </div>

  <div class="iso-fig-wrap" aria-hidden="true">
    <svg viewBox="0 0 560 440" width="100%" role="img" aria-label="Exploded workspace diagram">
      <defs>
        <pattern id="isoDots" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1.1" cy="1.1" r="1.1" fill="rgba(124,156,255,0.14)" />
        </pattern>
        <linearGradient id="isoTop" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="rgba(124,156,255,0.18)" />
          <stop offset="1" stop-color="rgba(124,156,255,0.06)" />
        </linearGradient>
      </defs>

      <rect x="46" y="24" width="410" height="392" fill="url(#isoDots)"
        style="mask: radial-gradient(ellipse 58% 58% at 46% 46%, #000 35%, transparent 85%); -webkit-mask: radial-gradient(ellipse 58% 58% at 46% 46%, #000 35%, transparent 85%);" />
      <text x="20" y="26" class="iso-tag">FIG_01 — WORKSPACE</text>

      {f1defs.map((l) => (
        <g>
          {/* solid box: sides first (depth), then top */}
          <polygon points={l.left} fill="rgba(10,12,20,0.85)" stroke={IND + '0.4)'} stroke-width="1" stroke-linejoin="round" />
          <polygon points={l.right} fill="rgba(40,52,92,0.5)" stroke={IND + '0.45)'} stroke-width="1" stroke-linejoin="round" />
          <polygon points={l.top} fill="url(#isoTop)" stroke={IND + '0.65)'} stroke-width="1.2" stroke-linejoin="round" />
          {/* UI content on the top face */}
          {l.bars.map((b) => <polygon points={b.poly} fill={b.fill} />)}
          {l.gedges.map(([a, b]) => <line x1={l.gnodes[a]!.p[0]} y1={l.gnodes[a]!.p[1]} x2={l.gnodes[b]!.p[0]} y2={l.gnodes[b]!.p[1]} stroke={IND + '0.45)'} stroke-width="0.9" />)}
          {l.gnodes.map((n) => <g><circle cx={n.p[0]} cy={n.p[1]} r={n.r * 2.1} fill={n.c} opacity="0.18" /><circle cx={n.p[0]} cy={n.p[1]} r={n.r} fill={n.c} /></g>)}
          {/* leader line → label */}
          <polyline
            points={`${l.labelX + (l.side === 'r' ? -6 : 6)},${l.cy} ${l.side === 'r' ? l.anchor[0] + 8 : l.anchor[0] - 8},${l.cy} ${pt(l.anchor)}`}
            fill="none" stroke={IND + '0.5)'} stroke-width="1" />
          <circle cx={l.anchor[0]} cy={l.anchor[1]} r="2" fill="#7C9CFF" />
          <text x={l.labelX} y={l.cy + 3.5} class="iso-anno" text-anchor={l.side === 'r' ? 'start' : 'end'}>{l.label}</text>
        </g>
      ))}
    </svg>
  </div>
</div>

<div class="iso-strip" aria-hidden="true">
  <!-- FIG_02 — flow of doc boxes -->
  <div class="iso-cell">
    <svg viewBox="0 0 200 165" width="100%" role="img">
      <text x="6" y="14" class="iso-tag">FIG_02</text>
      {F2.map((p) => (
        <g>
          {p.i < 2 && <line x1={p.center[0]} y1={p.center[1]} x2={p.next[0]} y2={p.next[1]} stroke="rgba(255,179,112,0.55)" stroke-width="1.2" />}
          <polygon points={p.box.left} fill="rgba(10,12,20,0.85)" stroke="rgba(124,156,255,0.4)" stroke-width="1" stroke-linejoin="round" />
          <polygon points={p.box.right} fill="rgba(40,52,92,0.5)" stroke="rgba(124,156,255,0.45)" stroke-width="1" stroke-linejoin="round" />
          <polygon points={p.box.top} fill="url(#isoTop)" stroke="rgba(124,156,255,0.65)" stroke-width="1.1" stroke-linejoin="round" />
          <polygon points={p.dot} fill="rgba(255,179,112,0.7)" />
          {p.lines.map((ln) => <polygon points={ln} fill="rgba(124,156,255,0.3)" />)}
        </g>
      ))}
    </svg>
    <h3 class="iso-cell-title">Sequenced into flows.</h3>
    <p class="iso-cell-desc">Each step is a doc plus your instruction — read in order, not dumped.</p>
  </div>

  <!-- FIG_03 — graph network -->
  <div class="iso-cell">
    <svg viewBox="0 0 200 165" width="100%" role="img">
      <text x="6" y="14" class="iso-tag">FIG_03</text>
      <polygon points={F3plane.left} fill="rgba(10,12,20,0.7)" stroke="rgba(124,156,255,0.2)" stroke-width="0.8" />
      <polygon points={F3plane.right} fill="rgba(40,52,92,0.35)" stroke="rgba(124,156,255,0.22)" stroke-width="0.8" />
      <polygon points={F3plane.top} fill="rgba(124,156,255,0.05)" stroke="rgba(124,156,255,0.28)" stroke-width="0.9" />
      {F3nodes.map((n) => <line x1={n.base[0]} y1={n.base[1]} x2={n.p[0]} y2={n.p[1]} stroke="rgba(124,156,255,0.22)" stroke-width="0.8" />)}
      {F3edges.map(([a, b]) => <line x1={F3nodes[a]!.p[0]} y1={F3nodes[a]!.p[1]} x2={F3nodes[b]!.p[0]} y2={F3nodes[b]!.p[1]} stroke="rgba(124,156,255,0.4)" stroke-width="0.9" />)}
      {F3nodes.map((n) => <g><circle cx={n.p[0]} cy={n.p[1]} r={n.r * 2.1} fill={n.c} opacity="0.18" /><circle cx={n.p[0]} cy={n.p[1]} r={n.r} fill={n.c} /></g>)}
    </svg>
    <h3 class="iso-cell-title">A graph above the docs.</h3>
    <p class="iso-cell-desc">Connections lift off the page — links agents can traverse.</p>
  </div>

  <!-- FIG_04 — MCP terminal -->
  <div class="iso-cell">
    <svg viewBox="0 0 200 165" width="100%" role="img">
      <text x="6" y="14" class="iso-tag">FIG_04</text>
      <polygon points={F4.left} fill="rgba(10,12,20,0.85)" stroke="rgba(124,156,255,0.4)" stroke-width="1" stroke-linejoin="round" />
      <polygon points={F4.right} fill="rgba(40,52,92,0.5)" stroke="rgba(124,156,255,0.45)" stroke-width="1" stroke-linejoin="round" />
      <polygon points={F4.top} fill="url(#isoTop)" stroke="rgba(124,156,255,0.65)" stroke-width="1.1" stroke-linejoin="round" />
      {F4lines.map((ln) => <polygon points={ln.poly} fill={ln.fill} />)}
    </svg>
    <h3 class="iso-cell-title">Read live via MCP.</h3>
    <p class="iso-cell-desc">An agent calls a tool; Mnema returns the exact context, fast.</p>
  </div>
</div>

<style>
  .iso-root { display: grid; grid-template-columns: 0.82fr 1.18fr; gap: 40px; align-items: center; }
  @media (max-width: 860px) { .iso-root { grid-template-columns: 1fr; gap: 16px; } }
  .iso-eyebrow { display: block; font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 14px; }
  .iso-title { font-family: var(--sans); font-weight: 500; font-size: 32px; line-height: 1.14; letter-spacing: -0.02em; color: var(--text-primary); margin: 0 0 16px; }
  .iso-desc { font-size: 15px; line-height: 1.6; color: var(--text-secondary); max-width: 30rem; margin: 0 0 22px; }
  .iso-link { display: inline-flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-primary); text-decoration: none; border-bottom: 1px solid var(--border-default); padding-bottom: 3px; transition: border-color 160ms; }
  .iso-link:hover { border-color: #7C9CFF; }
  .iso-fig-wrap { position: relative; }
  :global(.iso-tag) { font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.12em; fill: var(--text-quaternary); }
  :global(.iso-anno) { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.08em; fill: var(--text-secondary); }

  .iso-strip { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 48px; padding-top: 40px; border-top: 1px solid var(--border-subtle); }
  @media (max-width: 860px) { .iso-strip { grid-template-columns: 1fr; gap: 32px; } }
  .iso-cell { padding: 0 26px; position: relative; }
  .iso-cell + .iso-cell { border-left: 1px solid var(--border-subtle); }
  @media (max-width: 860px) { .iso-cell + .iso-cell { border-left: none; } }
  .iso-cell svg { display: block; height: 165px; margin-bottom: 14px; }
  .iso-cell-title { font-size: 16px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px; letter-spacing: -0.01em; }
  .iso-cell-desc { font-size: 13px; line-height: 1.5; color: var(--text-tertiary); margin: 0; }
</style>
