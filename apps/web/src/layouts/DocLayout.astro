---
import BaseLayout from './BaseLayout.astro';
import { Sidebar } from '../components/app/Sidebar';
import { WorkspaceSwitcher } from '../components/nav/WorkspaceSwitcher';

interface Props {
  title: string;
  docType?: string;
  workspaceName?: string;
  email?: string;
  backUrl?: string;
}

const { title, docType = 'doc', workspaceName: wsProp, email, backUrl = '/app/content' } = Astro.props;

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const domainPart = auth.email.split('@')[1]?.split('.')[0] ?? '';
const workspaceName = wsProp ?? (domainPart
  ? domainPart.charAt(0).toUpperCase() + domainPart.slice(1)
  : 'Workspace');
const userInitial = (email?.[0] ?? auth.email[0] ?? 'U').toUpperCase();

const pathname = Astro.url.pathname;

const apiUrl =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
let typeCounts: Record<string, number> = {};
try {
  const res = await fetch(`${apiUrl}/api/content/type-counts`, {
    headers: { Cookie: `boppl_jwt=${auth.jwt}` },
  });
  if (res.ok) {
    const body = (await res.json()) as { counts: Record<string, number> };
    typeCounts = body.counts ?? {};
  }
} catch { /* offline */ }
---

<BaseLayout title={`${title} — Mnema`}>
  <style is:global>
    :root {
      --topbar-h: 40px;
      --editbar-h: 38px;
      --status-h: 24px;
      --sidebar-w: 220px;
    }

    .dl-shell {
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      grid-template-rows: var(--topbar-h) var(--editbar-h) 1fr var(--status-h);
      grid-template-areas:
        "dl-topbar  dl-topbar"
        "dl-sidebar dl-editbar"
        "dl-sidebar dl-main"
        "dl-status  dl-status";
      height: 100vh;
      overflow: hidden;
    }

    /* TOPBAR */
    .dl-topbar {
      grid-area: dl-topbar;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 12px;
      background: var(--surface);
      border-bottom: 1px solid var(--line);
    }
    .dl-tb-left { display: flex; align-items: center; gap: 8px; }
    .dl-brand {
      display: inline-flex; align-items: center; gap: 7px;
      font: 600 12.5px/1 var(--sans); color: var(--ink); text-decoration: none;
    }
    .dl-glyph {
      width: 20px; height: 20px; border-radius: 5px;
      overflow: hidden; display: inline-flex; flex-shrink: 0;
    }
    .dl-tb-div { width: 1px; height: 14px; background: var(--line-strong); flex-shrink: 0; }
    .dl-ws-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 3px 6px 3px 4px; border-radius: 5px;
      background: transparent; border: 1px solid transparent;
      cursor: pointer; color: var(--ink); font: 500 12px/1 var(--sans);
    }
    .dl-ws-btn:hover { background: var(--surface-2); border-color: var(--line); }
    .dl-ws-av {
      width: 14px; height: 14px; border-radius: 4px;
      background: linear-gradient(135deg, #7C9CFF, #C8A2FF);
      color: white; font: 700 8.5px/1 var(--sans);
      display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .dl-crumbs {
      flex: 1; display: flex; align-items: center; justify-content: center;
      gap: 6px; font: 500 12px/1 var(--sans); color: var(--ink-muted);
    }
    .dl-crumbs .here { color: var(--ink); font-weight: 600; }
    .dl-crumbs .sep { color: var(--ink-faint); font-size: 9px; }
    .dl-tb-right { display: flex; align-items: center; gap: 2px; }
    .dl-icon-btn {
      width: 24px; height: 24px; border-radius: 4px;
      background: transparent; border: 0; color: var(--ink-muted); cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center; text-decoration: none;
    }
    .dl-icon-btn:hover { background: var(--surface-2); color: var(--ink); }
    .dl-share-btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 8px; border-radius: 5px;
      background: var(--surface-2); border: 1px solid var(--line);
      color: var(--ink); cursor: pointer; font: 500 11.5px/1 var(--sans);
      margin-left: 3px;
    }
    .dl-share-btn:hover { background: var(--surface-3); }
    .dl-user-chip {
      width: 22px; height: 22px; border-radius: 50%;
      background: linear-gradient(135deg, rgba(var(--accent-rgb),0.95), rgba(255,122,138,0.95));
      color: var(--on-ink); font: 700 9.5px/1 var(--sans);
      display: inline-flex; align-items: center; justify-content: center;
      cursor: pointer; margin-left: 4px; text-decoration: none;
    }

    /* SIDEBAR */
    .dl-sidebar {
      grid-area: dl-sidebar;
      background: var(--surface);
      border-right: 1px solid var(--line);
      overflow-y: auto;
      display: flex; flex-direction: column;
    }
    .dl-sidebar > aside { width: 100% !important; height: 100% !important; }

    /* EDIT BAR */
    .dl-editbar {
      grid-area: dl-editbar;
      display: flex; align-items: center; gap: 2px;
      padding: 0 16px;
      background: var(--canvas);
      border-bottom: 1px solid var(--line);
      overflow: hidden;
    }
    .dl-eb-group { display: flex; align-items: center; gap: 1px; }
    .dl-eb-sep { width: 1px; height: 16px; background: var(--line); margin: 0 6px; flex-shrink: 0; }
    .dl-eb-btn {
      height: 26px; min-width: 26px; padding: 0 6px;
      border: 0; background: transparent; border-radius: 4px;
      color: var(--ink-muted); cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center; gap: 4px;
      font: 500 12px/1 var(--sans); flex-shrink: 0;
    }
    .dl-eb-btn:hover { background: var(--surface-2); color: var(--ink); }
    .dl-eb-heading {
      height: 26px; padding: 0 8px;
      border: 0; background: transparent; border-radius: 4px;
      color: var(--ink); cursor: pointer; flex-shrink: 0;
      display: inline-flex; align-items: center; gap: 6px;
      font: 500 12px/1 var(--sans);
    }
    .dl-eb-heading:hover { background: var(--surface-2); }
    .dl-eb-heading svg { color: var(--ink-muted); }
    .dl-eb-spacer { flex: 1; }
    .dl-eb-status {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 3px 8px 3px 7px; border-radius: 999px;
      background: rgba(107,227,155,0.08); border: 1px solid rgba(107,227,155,0.22);
      color: var(--status-sync); font: 500 11px/1 var(--sans); flex-shrink: 0;
    }
    .dl-eb-status .sig { width: 5px; height: 5px; border-radius: 50%; background: currentColor; box-shadow: 0 0 4px currentColor; opacity: 0.85; }
    .dl-ai-btn {
      height: 26px; padding: 0 10px; flex-shrink: 0;
      border: 1px solid var(--line-strong); background: var(--surface-2);
      border-radius: 5px; cursor: pointer; color: var(--ink);
      display: inline-flex; align-items: center; gap: 6px;
      font: 500 11.5px/1 var(--sans);
    }
    .dl-ai-btn:hover { background: var(--surface-3); border-color: var(--line-bright); }
    .dl-ai-btn .acc { color: var(--accent); }
    .dl-ai-btn .shortcut {
      font: 500 10px/1 var(--mono); padding: 2px 4px; border-radius: 3px;
      background: var(--canvas); border: 1px solid var(--line); color: var(--ink-muted);
    }

    /* MAIN */
    .dl-main {
      grid-area: dl-main;
      overflow-y: auto;
      background: var(--canvas);
      position: relative;
    }

    /* STATUS BAR */
    .dl-statusbar {
      grid-area: dl-status;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 14px;
      background: var(--surface);
      border-top: 1px solid var(--line);
      font: 500 11px/1 var(--mono); letter-spacing: 0.02em; color: var(--ink-muted);
    }
    .dl-sb-left, .dl-sb-right { display: flex; align-items: center; gap: 14px; }
    .dl-sb-sig {
      width: 6px; height: 6px; border-radius: 50%; background: #6BE39B;
      box-shadow: 0 0 5px rgba(107,227,155,0.5);
      animation: dl-pulse 2s ease-in-out infinite;
    }
    @keyframes dl-pulse {
      0%,100% { box-shadow: 0 0 0 0 rgba(107,227,155,0.55); }
      50% { box-shadow: 0 0 0 4px rgba(107,227,155,0); }
    }
    .dl-sb-sep { width: 1px; height: 12px; background: var(--line); }
    .dl-type-badge {
      font: 500 9.5px/1 var(--mono); letter-spacing: 0.06em; text-transform: uppercase;
      padding: 2px 6px; border-radius: 3px;
      background: var(--surface-2); color: var(--ink-muted);
    }
  </style>

  <div class="dl-shell">

    <!-- TOPBAR -->
    <header class="dl-topbar">
      <div class="dl-tb-left">
        <a href="/app/content" class="dl-brand">
          <span class="dl-glyph"><img src="/logo.svg" width="20" height="20" alt="Mnema" draggable="false"></span>
          <span>Mnema</span>
        </a>
        <span class="dl-tb-div"></span>
        <WorkspaceSwitcher
          currentWorkspaceId={auth.tenant_id}
          client:load
        />
      </div>
      <div class="dl-crumbs">
        <a href={backUrl} style="color:var(--ink-muted);text-decoration:none;">
          {backUrl.includes('?folder=') ? 'Folder' : 'Content'}
        </a>
        <svg class="sep" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--ink-faint)"><path d="m9 6 6 6-6 6"/></svg>
        <span class="here">{title || 'Untitled'}</span>
      </div>
      <div class="dl-tb-right">
        <a href="/app/settings" class="dl-icon-btn" title="Settings">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </a>
        <button class="dl-share-btn" type="button">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><path d="M12 2v13"/></svg>
          Share
        </button>
        <a href="/auth/logout" class="dl-user-chip" title="Account">{userInitial}</a>
      </div>
    </header>

    <!-- SIDEBAR (workspace nav) -->
    <aside class="dl-sidebar">
      <Sidebar
        workspaceName={workspaceName}
        currentPath={pathname}
        typeCounts={typeCounts}
        client:load
      />
    </aside>

    <!-- EDIT BAR -->
    <div class="dl-editbar">
      <div class="dl-eb-group">
        <button class="dl-eb-heading" title="Block type">
          <span>Paragraph</span>
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </button>
      </div>
      <span class="dl-eb-sep"></span>
      <div class="dl-eb-group">
        <button class="dl-eb-btn" title="Bold (⌘B)"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M7 4h7a4 4 0 0 1 3 6.7A4 4 0 0 1 14 18H7zm2 2v4h5a2 2 0 1 0 0-4zm0 6v4h5a2 2 0 1 0 0-4z"/></svg></button>
        <button class="dl-eb-btn" title="Italic (⌘I)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
        <button class="dl-eb-btn" title="Underline"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 4v7a6 6 0 0 0 12 0V4"/><line x1="5" y1="21" x2="19" y2="21"/></svg></button>
        <button class="dl-eb-btn" title="Strikethrough"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M16 4H9a3 3 0 0 0-2.8 4M14 12a4 4 0 0 1 0 8H6"/><line x1="4" y1="12" x2="20" y2="12"/></svg></button>
        <button class="dl-eb-btn" title="Inline code"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></button>
      </div>
      <span class="dl-eb-sep"></span>
      <div class="dl-eb-group">
        <button class="dl-eb-btn" title="Link"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-2 2"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l2-2"/></svg></button>
        <button class="dl-eb-btn" title="Bullet list"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1" fill="currentColor" stroke="none"/></svg></button>
        <button class="dl-eb-btn" title="Numbered list"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="10" y1="6" x2="20" y2="6"/><line x1="10" y1="12" x2="20" y2="12"/><line x1="10" y1="18" x2="20" y2="18"/><path d="M4 6h1v4M4 10h2M5 14H3.5a1.5 1.5 0 1 1 1.5 2.5L3 19h3"/></svg></button>
        <button class="dl-eb-btn" title="Blockquote"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg></button>
        <button class="dl-eb-btn" title="Code block"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="m10 9-3 3 3 3M14 9l3 3-3 3"/></svg></button>
      </div>
      <span class="dl-eb-sep"></span>
      <button class="dl-eb-btn" title="Comment (⌘⇧M)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></button>

      <div class="dl-eb-spacer"></div>

      <button class="dl-ai-btn" type="button">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="acc"><path d="M12 2 9.4 8.6 2 9.5l6 4.6L6 22l6-3.6L18 22l-2-7.9 6-4.6L14.6 8.6z"/></svg>
        Ask μ
        <span class="shortcut">⌘ K</span>
      </button>
    </div>

    <!-- MAIN CONTENT -->
    <main class="dl-main">
      <slot />
    </main>

    <!-- STATUS BAR -->
    <footer class="dl-statusbar">
      <div class="dl-sb-left">
        <span style="display:flex;align-items:center;gap:6px;">
          <span class="dl-sb-sig"></span>
          MCP live
        </span>
        <span class="dl-sb-sep"></span>
        <span class="dl-type-badge">{docType}</span>
      </div>
      <div class="dl-sb-right">
        {email && <span style="color:var(--ink-soft);">{email}</span>}
      </div>
    </footer>

  </div>
</BaseLayout>
