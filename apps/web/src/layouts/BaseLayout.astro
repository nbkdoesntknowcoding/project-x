---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'BOPPL Context Engine' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1440" />
    <title>{title}</title>

    <link rel="preload" href="/fonts/geist/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist/Geist-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist/GeistMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-serif/InstrumentSerif-Regular.woff2" as="font" type="font/woff2" crossorigin />

    {/*
      Phase 4.3 — no-FOUC theme script.

      Runs synchronously before any stylesheet evaluates, so the page's
      first paint already has the right data-theme. is:inline keeps Astro
      from hoisting/deferring it.

      Resolution order:
        1. localStorage['mnema:theme']  → 'light' | 'dark' | (absent = system)
        2. prefers-color-scheme media query
        3. fallback to 'dark' (the dark surface tokens are the design's
           dark-first default)

      Wrapped in try/catch because some private-mode browsers throw on
      localStorage access; the fallback keeps the site visible.
    */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('mnema-theme');
          var resolved;
          if (stored === 'light') {
            resolved = 'light';
          } else if (stored === 'dark') {
            resolved = 'dark';
          } else if (stored === 'system') {
            resolved = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          } else {
            resolved = 'dark';
          }
          document.documentElement.setAttribute('data-theme', resolved);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body class="font-sans">
    <slot />
  </body>
</html>
