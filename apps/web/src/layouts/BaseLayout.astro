---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'BOPPL Context Engine' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="font-sans">
    <slot />
  </body>
</html>
