---
import BaseLayout from './BaseLayout.astro';
import { SettingsNav } from '../components/settings/SettingsNav';

interface Props {
  title: string;
}

const { title } = Astro.props;

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}
---

<BaseLayout title={`${title} · Settings · Mnema`}>
  <div class="flex min-h-screen" style="background: var(--surface-base);">
    <aside
      class="w-52 py-6 px-3 flex flex-col flex-shrink-0"
      style="border-right: 1px solid var(--border-subtle); background: var(--surface-base);"
    >
      <a
        href="/app"
        class="block px-2 py-1.5 mb-4 transition-colors"
        style="font-size: 12px; color: var(--text-tertiary);"
        onmouseover="this.style.color='var(--text-primary)'"
        onmouseout="this.style.color='var(--text-tertiary)'"
      >
        ← Back to docs
      </a>
      <SettingsNav client:load currentPath={Astro.url.pathname} />
      <div
        class="mt-auto px-2 pt-4"
        style="font-size: 11px; color: var(--text-quaternary); border-top: 1px solid var(--border-subtle);"
      >
        Signed in as<br />
        <span style="color: var(--text-tertiary);">{auth.email}</span>
      </div>
    </aside>

    <main class="flex-1 py-8 px-12">
      <div style="max-width: 640px;">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>
