---
// Public page — no auth required
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Integrations — Mnema</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    (function(){var t=localStorage.getItem('mnema-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();
  </script>
  <style is:global>
    :root { --sans: 'Geist', system-ui, sans-serif; --mono: 'Geist Mono', monospace; }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: var(--sans); background: var(--canvas, #0a0b0d); color: var(--ink, #e8e9eb); line-height: 1.6; }
    .ig-wrap { max-width: 860px; margin: 0 auto; padding: 60px 28px 80px; }
    .ig-brand { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: inherit; font: 600 14px/1 var(--sans); margin-bottom: 48px; }
    .ig-glyph { width: 26px; height: 26px; border-radius: 7px; overflow: hidden; display: inline-flex; }
    h1 { margin: 0 0 10px; font: 600 30px/1.2 var(--sans); letter-spacing: -0.02em; }
    .ig-sub { margin: 0 0 48px; font-size: 15px; color: var(--ink-muted, #888); max-width: 40rem; }
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    thead th {
      text-align: left; padding: 8px 14px;
      font: 500 10.5px/1 var(--mono); letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--ink-muted, #888); border-bottom: 1px solid var(--line, #2a2b2d);
    }
    tbody tr { border-bottom: 1px solid var(--line, #1e1f22); }
    tbody tr:hover { background: var(--surface, #111); }
    tbody td { padding: 11px 14px; vertical-align: middle; }
    .ig-app { font: 500 13.5px/1 var(--sans); color: var(--ink, #e8e9eb); }
    .ig-app a { color: inherit; text-decoration: none; }
    .ig-app a:hover { color: #60a5fa; }
    .ig-ok   { color: #6be39b; font-size: 15px; }
    .ig-warn { color: #fbbf24; font-size: 15px; }
    .ig-no   { color: var(--ink-muted, #555); font-size: 15px; }
    .ig-method { font: 400 12px/1 var(--mono); color: var(--ink-muted, #888); }
    .ig-section-label {
      font: 500 10.5px/1 var(--mono); letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--ink-muted, #888); margin: 40px 0 14px;
    }
  </style>
</head>
<body>
<div class="ig-wrap">
  <a href="/" class="ig-brand">
    <span class="ig-glyph"><img src="/logo.svg" width="26" height="26" alt="Mnema" /></span>
    Mnema
  </a>

  <h1>Integrations</h1>
  <p class="ig-sub">
    Mnema works with every major AI coding tool through the Model Context Protocol (MCP).
    Connect once — Claude, Cursor, ChatGPT, Codex, and more can all search and write to your workspace.
  </p>

  <div class="ig-section-label">Compatibility matrix</div>
  <table>
    <thead>
      <tr>
        <th>App</th>
        <th>MCP</th>
        <th>Hook tracking</th>
        <th>Install method</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="ig-app"><a href="/app/connections/claude">Claude Desktop</a></td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-ok">✅</span></td>
        <td class="ig-method">Shell script / manual config</td>
      </tr>
      <tr>
        <td class="ig-app">Cursor</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-ok">✅</span></td>
        <td class="ig-method"><a href="/install/cursor" style="color:#60a5fa;">Deep link</a></td>
      </tr>
      <tr>
        <td class="ig-app">Windsurf</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-ok">✅</span></td>
        <td class="ig-method"><a href="/install/windsurf" style="color:#60a5fa;">Deep link</a></td>
      </tr>
      <tr>
        <td class="ig-app">Cline</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-warn">⚠ Manual</span></td>
        <td class="ig-method">Config JSON</td>
      </tr>
      <tr>
        <td class="ig-app">Continue.dev</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Config JSON</td>
      </tr>
      <tr>
        <td class="ig-app"><a href="/connect/chatgpt">ChatGPT Business</a></td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Admin panel URL (<code style="font:400 11.5px/1 var(--mono);padding:1px 4px;background:#1a1b1d;border-radius:3px;">/mcp/http</code>)</td>
      </tr>
      <tr>
        <td class="ig-app"><a href="/connect/chatgpt">ChatGPT Pro / Plus</a></td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Developer Mode</td>
      </tr>
      <tr>
        <td class="ig-app">OpenAI Codex</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Plugin registry (<a href="/.well-known/ai-plugin.json" style="color:#60a5fa;" target="_blank">manifest</a>)</td>
      </tr>
      <tr>
        <td class="ig-app"><a href="/connect/chatgpt">OpenAI API</a></td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Code snippet (<code style="font:400 11.5px/1 var(--mono);padding:1px 4px;background:#1a1b1d;border-radius:3px;">type:"mcp"</code>)</td>
      </tr>
      <tr>
        <td class="ig-app">Gemini</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Function JSON</td>
      </tr>
      <tr>
        <td class="ig-app">Replit</td>
        <td><span class="ig-warn">⚠ REST fallback</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">REST API (<a href="/api/public/v1/openapi.json" style="color:#60a5fa;" target="_blank">OpenAPI</a>)</td>
      </tr>
      <tr>
        <td class="ig-app">Zed</td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">mcp-remote package</td>
      </tr>
      <tr>
        <td class="ig-app"><a href="/app/connections/antigravity">Antigravity</a></td>
        <td><span class="ig-ok">✅</span></td>
        <td><span class="ig-no">❌</span></td>
        <td class="ig-method">Config JSON</td>
      </tr>
    </tbody>
  </table>

  <p style="margin-top:28px;font-size:13px;color:var(--ink-muted,#888);">
    ✅ Full support &nbsp;·&nbsp; ⚠ Partial / manual &nbsp;·&nbsp; ❌ Not available<br/>
    Hook tracking requires the <a href="/app/connections/claude" style="color:#60a5fa;">Mnema Claude hooks shell script</a> installed on your machine.
  </p>
</div>
</body>
</html>
