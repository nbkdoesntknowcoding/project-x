---
import PublicLayout from '../../layouts/PublicLayout.astro';
---

<PublicLayout
  title="Docs — Mnema"
  description="Documentation for Mnema, the live context engine for Claude."
  pathname="/docs"
>
  <section class="max-w-[680px] mx-auto px-6 pt-[80px] pb-[96px]">
    <span
      class="block mb-3 font-mono uppercase"
      style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
    >
      Docs
    </span>
    <h1
      style="font-size: 28px; line-height: 1.3; letter-spacing: -0.01em; font-weight: 500; color: var(--text-primary); margin-bottom: 48px;"
    >
      Documentation
    </h1>

    <nav class="space-y-3">
      <a
        href="/docs/getting-started"
        class="group flex items-start justify-between p-6 rounded-lg transition-[background] block"
        style="background: var(--surface-overlay); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg);"
        onmouseover="this.style.background='var(--surface-elevated)'"
        onmouseout="this.style.background='var(--surface-overlay)'"
      >
        <div>
          <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">
            Getting started
          </h3>
          <p style="font-size: 14px; color: var(--text-secondary);">
            A 5-minute tour: invite a teammate, create a doc, try search.
          </p>
        </div>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--text-tertiary)"
          stroke-width="1.5"
          style="flex-shrink: 0; margin-top: 4px; margin-left: 16px;"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <a
        href="/docs/connect"
        class="group flex items-start justify-between p-6 rounded-lg transition-[background] block"
        style="background: var(--surface-overlay); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg);"
        onmouseover="this.style.background='var(--surface-elevated)'"
        onmouseout="this.style.background='var(--surface-overlay)'"
      >
        <div>
          <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">
            Connect to Claude
          </h3>
          <p style="font-size: 14px; color: var(--text-secondary);">
            Step-by-step setup for the MCP connector.
          </p>
        </div>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--text-tertiary)"
          stroke-width="1.5"
          style="flex-shrink: 0; margin-top: 4px; margin-left: 16px;"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <a
        href="/docs/flows"
        class="group flex items-start justify-between p-6 rounded-lg transition-[background] block"
        style="background: var(--surface-overlay); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg);"
        onmouseover="this.style.background='var(--surface-elevated)'"
        onmouseout="this.style.background='var(--surface-overlay)'"
      >
        <div>
          <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">
            Flows
          </h3>
          <p style="font-size: 14px; color: var(--text-secondary);">
            What a flow is, how Claude calls one, when to use one. (Editor ships next release.)
          </p>
        </div>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--text-tertiary)"
          stroke-width="1.5"
          style="flex-shrink: 0; margin-top: 4px; margin-left: 16px;"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </nav>
  </section>
</PublicLayout>
