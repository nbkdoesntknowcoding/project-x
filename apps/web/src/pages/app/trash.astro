---
import AppLayout from '../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const domainPart = auth.email?.split('@')[1]?.split('.')[0] ?? '';
const workspaceName = domainPart
  ? domainPart.charAt(0).toUpperCase() + domainPart.slice(1)
  : 'Workspace';
---

<style>
  .tr-main { max-width: 880px; margin: 0 auto; padding: 40px 32px 100px; }

  .tr-pre {
    font: 500 11px/1 var(--mono); letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-muted); margin-bottom: 12px;
  }
  .tr-page-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 16px; margin-bottom: 22px;
  }
  .tr-page-head h1 {
    margin: 0; font: 500 28px/1.15 var(--sans); letter-spacing: -0.02em;
  }
  .tr-page-head .tr-sub {
    margin: 6px 0 0; font-size: 14px; color: var(--ink-soft); max-width: 36rem;
  }

  .tr-btn {
    font: 500 12.5px/1 var(--sans); padding: 8px 12px; border-radius: 6px;
    cursor: pointer; border: 1px solid transparent;
    display: inline-flex; align-items: center; gap: 6px; white-space: nowrap;
  }
  .tr-btn-secondary {
    background: var(--surface); color: var(--ink); border-color: var(--line-strong);
  }
  .tr-btn-secondary:hover { background: var(--surface-2); border-color: var(--line-bright); }
  .tr-btn-danger {
    background: rgba(255,122,138,0.10); color: var(--status-error);
    border-color: rgba(255,122,138,0.30);
  }
  .tr-btn-danger:hover { background: rgba(255,122,138,0.18); border-color: var(--status-error); }
  .tr-btn-ghost { background: transparent; color: var(--ink-soft); }
  .tr-btn-ghost:hover { background: var(--surface-2); color: var(--ink); }

  /* FILTER CHIPS */
  .tr-chips { display: flex; gap: 6px; margin-bottom: 14px; }
  .tr-chip {
    font: 500 12px/1 var(--sans); padding: 6px 11px; border-radius: 999px;
    background: transparent; border: 1px solid transparent;
    color: var(--ink-muted); cursor: pointer;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .tr-chip:hover { color: var(--ink); background: var(--surface-2); }
  .tr-chip.active {
    background: var(--surface-2); color: var(--ink); border-color: var(--line);
  }
  .tr-chip .ct {
    font: 500 10.5px/1 var(--mono); color: var(--ink-faint); letter-spacing: 0.02em;
  }
  .tr-chip.active .ct { color: var(--ink-muted); }

  .tr-meta-line {
    font: 500 11px/1 var(--mono); letter-spacing: 0.04em;
    color: var(--ink-muted); margin: 0 0 8px;
    display: flex; align-items: center; gap: 14px;
  }
  .tr-meta-line .v { color: var(--ink-soft); font-weight: 600; }
  .tr-meta-line .sep { color: var(--ink-faint); }

  /* LIST */
  .tr-list { display: flex; flex-direction: column; border-top: 1px solid var(--line); }
  .tr-row {
    display: grid;
    grid-template-columns: 24px 24px minmax(0,1fr) 200px 130px 180px;
    align-items: center; gap: 12px; padding: 0 12px; height: 62px;
    border-bottom: 1px solid var(--line); cursor: default; position: relative;
  }
  .tr-row:hover { background: var(--surface); }
  .tr-row:hover .tr-actions { opacity: 1; }
  .tr-row.selected { background: var(--accent-soft); }
  .tr-row.selected::before {
    content: ""; position: absolute; left: 0; top: 10px; bottom: 10px;
    width: 2px; background: var(--accent); border-radius: 2px;
  }

  .tr-check {
    width: 16px; height: 16px; border-radius: 4px;
    background: transparent; border: 1.5px solid var(--line-strong);
    cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
    color: var(--on-ink);
  }
  .tr-check:hover { border-color: var(--line-bright); }
  .tr-check.on { background: var(--accent); border-color: var(--accent); }
  .tr-check.on svg { display: block; }
  .tr-check svg { display: none; }

  .tr-ico {
    width: 24px; height: 24px; border-radius: 6px;
    background: var(--surface-2); border: 1px solid var(--line);
    color: var(--ink-soft);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .tr-ico.flow { color: var(--status-edit); }

  .tr-title {
    font: 500 14px/1.3 var(--sans); color: var(--ink-soft);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  .tr-deleted-by {
    display: flex; align-items: center; gap: 8px;
    font: 400 12.5px/1.3 var(--sans); color: var(--ink-muted); min-width: 0;
  }
  .tr-deleted-by .av {
    width: 18px; height: 18px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font: 700 9.5px var(--sans); color: white; flex-shrink: 0;
  }
  .tr-deleted-by .av.a { background: linear-gradient(135deg,#FFB370,#FF7A8A); }
  .tr-deleted-by .av.b { background: linear-gradient(135deg,#7C9CFF,#C8A2FF); }
  .tr-deleted-by .av.c { background: linear-gradient(135deg,#6BE39B,#2B9B9B); }
  .tr-deleted-by .name {
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--ink-soft);
  }
  .tr-deleted-by .when {
    margin-left: auto; font: 500 11px var(--mono); color: var(--ink-muted); flex-shrink: 0;
  }

  .tr-expires {
    font: 500 11px/1 var(--mono); color: var(--ink-muted);
    letter-spacing: 0.02em; text-align: right;
  }
  .tr-expires.warn { color: var(--status-error); }
  .tr-expires.warn::before {
    content: "●"; color: var(--status-error); font-size: 8px;
    margin-right: 5px; vertical-align: middle;
  }

  .tr-actions {
    display: flex; gap: 4px; justify-content: flex-end; opacity: 0;
    transition: opacity 140ms ease;
  }
  .tr-row.selected .tr-actions { opacity: 1; }
  .tr-act-btn {
    font: 500 11.5px/1 var(--sans); padding: 5px 10px; border-radius: 5px;
    background: transparent; border: 1px solid var(--line);
    color: var(--ink-soft); cursor: pointer;
  }
  .tr-act-btn:hover { color: var(--ink); border-color: var(--line-strong); background: var(--surface-2); }
  .tr-act-btn.danger:hover { color: var(--status-error); border-color: var(--status-error); background: transparent; }

  /* EMPTY STATE */
  .tr-empty {
    display: none; flex-direction: column; align-items: center;
    text-align: center; padding: 80px 24px;
  }
  .tr-empty.active { display: flex; }
  .tr-empty .ic {
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--surface); border: 1px solid var(--line);
    color: var(--ink-soft);
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .tr-empty h3 { margin: 0 0 8px; font: 500 16px/1.3 var(--sans); letter-spacing: -0.005em; }
  .tr-empty p { margin: 0; font-size: 13px; color: var(--ink-muted); line-height: 1.55; max-width: 24rem; }

  .tr-list.hidden { display: none; }
  .tr-meta-line.hidden { display: none; }

  /* BULK BAR */
  .tr-bulkbar {
    position: fixed; left: 50%; bottom: 48px;
    transform: translateX(-50%) translateY(110%);
    background: var(--surface); border: 1px solid var(--line-strong);
    border-radius: 12px; padding: 8px 12px;
    display: flex; align-items: center; gap: 12px;
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.6);
    z-index: 30; transition: transform 240ms cubic-bezier(0.16,1,0.3,1);
  }
  .tr-bulkbar.active { transform: translateX(-50%) translateY(0); }
  .tr-bulkbar .count {
    display: inline-flex; align-items: center; gap: 8px;
    font: 500 12px/1 var(--sans); color: var(--ink-soft);
    padding-right: 10px; border-right: 1px solid var(--line);
  }
  .tr-bulkbar .count .n {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--accent); color: var(--on-ink);
    font: 700 11px/1 var(--mono);
  }
  .tr-bulkbar .bb-actions { display: flex; gap: 6px; }
  .tr-bulkbar .clear {
    font: 500 11.5px var(--sans); background: transparent; border: 0;
    color: var(--ink-muted); cursor: pointer; padding: 6px 4px;
  }
  .tr-bulkbar .clear:hover { color: var(--ink); }

  /* CONFIRM MODAL */
  .tr-overlay {
    position: fixed; inset: 0; background: rgba(10,11,13,0.80);
    backdrop-filter: blur(8px); display: none;
    align-items: center; justify-content: center; z-index: 60;
  }
  .tr-overlay.active { display: flex; }
  .tr-confirm {
    width: 100%; max-width: 460px; background: var(--surface);
    border: 1px solid rgba(255,122,138,0.32); border-radius: 12px;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.7); overflow: hidden;
  }
  .tr-confirm-head {
    padding: 16px 20px 12px; display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid var(--line);
  }
  .tr-confirm-head .ic {
    width: 28px; height: 28px; border-radius: 7px;
    background: rgba(255,122,138,0.14); border: 1px solid rgba(255,122,138,0.32);
    color: var(--status-error);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .tr-confirm-head h3 { margin: 0; font: 500 14.5px/1 var(--sans); color: var(--ink); }
  .tr-confirm-body { padding: 16px 20px 18px; }
  .tr-confirm-body p { margin: 0 0 10px; font: 400 13px/1.55 var(--sans); color: var(--ink-soft); }
  .tr-confirm-body p strong { color: var(--ink); font-weight: 600; }
  .tr-confirm-foot {
    padding: 12px 20px; display: flex; justify-content: flex-end; gap: 8px;
    background: var(--surface-2); border-top: 1px solid var(--line);
  }
</style>

