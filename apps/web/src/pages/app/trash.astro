<script>
// Filter chips
document.getElementById('tr-chips')?.addEventListener('click', (e) => {
  const b = (e.target as Element).closest('.tr-chip') as HTMLElement | null;
  if (!b) return;
  document.querySelectorAll('.tr-chip').forEach((c) => c.classList.toggle('active', c === b));
  const type = b.dataset.type;
  let visible = 0;
  document.querySelectorAll('.tr-row').forEach((r: Element) => {
    const row = r as HTMLElement;
    const show = type === 'all' || row.dataset.type === type;
    row.style.display = show ? 'grid' : 'none';
    if (show) visible++;
  });
  const el = document.querySelector('#tr-visible-count');
  if (el) el.textContent = String(visible);
});

// Row selection
const bulk = document.getElementById('tr-bulkbar');
const bulkN = document.getElementById('tr-bulk-n');
const bulkLabel = document.getElementById('tr-bulk-label');
function updateBulk() {
  const sel = document.querySelectorAll('.tr-row.selected').length;
  if (bulkN) bulkN.textContent = String(sel);
  if (bulkLabel) bulkLabel.textContent = sel === 1 ? 'item selected' : 'items selected';
  bulk?.classList.toggle('active', sel > 0);
}
document.querySelectorAll('.tr-check').forEach((c) => {
  c.addEventListener('click', (e) => {
    e.stopPropagation();
    const row = (c as Element).closest('.tr-row');
    if (!row) return;
    row.classList.toggle('selected');
    c.classList.toggle('on', row.classList.contains('selected'));
    updateBulk();
  });
});
document.getElementById('tr-bulk-clear')?.addEventListener('click', () => {
  document.querySelectorAll('.tr-row.selected').forEach((r) => {
    r.classList.remove('selected');
    r.querySelector('.tr-check')?.classList.remove('on');
  });
  updateBulk();
});

// Per-row restore/delete
document.querySelectorAll('.tr-act-btn').forEach((b) => {
  b.addEventListener('click', (e) => {
    e.stopPropagation();
    const row = (b as Element).closest('.tr-row') as HTMLElement | null;
    if (!row) return;
    row.style.opacity = '0';
    setTimeout(() => row.remove(), 200);
  });
});

// Empty trash modal
const overlay = document.getElementById('tr-overlay');
document.getElementById('tr-empty-btn')?.addEventListener('click', () => overlay?.classList.add('active'));
document.getElementById('tr-cancel')?.addEventListener('click', () => overlay?.classList.remove('active'));
overlay?.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('active'); });
document.getElementById('tr-confirm-empty')?.addEventListener('click', () => {
  document.querySelectorAll('.tr-row').forEach((r) => r.remove());
  document.getElementById('tr-list')?.classList.add('hidden');
  document.getElementById('tr-meta-line')?.classList.add('hidden');
  const chips = document.getElementById('tr-chips') as HTMLElement | null;
  if (chips) chips.style.display = 'none';
  document.getElementById('tr-empty')?.classList.add('active');
  overlay?.classList.remove('active');
});
window.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && overlay?.classList.contains('active')) overlay.classList.remove('active');
});
</script>
