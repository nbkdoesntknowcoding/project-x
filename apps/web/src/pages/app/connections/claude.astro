---
import AppLayout from '../../../layouts/AppLayout.astro';
import { MonoLabel } from '../../../components/ui/typography';
import { Plug } from 'lucide-react';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

// The MCP endpoint URL points at the production API host so users can
// paste it directly into Claude. In dev this is overridable via env.
const mcpHost =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ??
  'https://context.theboringpeople.in';
const mcpEndpoint = `${mcpHost}/mcp`;
---

<AppLayout title="Claude connection — Mnema" workspaceName="Workspace" email={auth.email}>
  <div class="max-w-3xl mx-auto px-8 py-12">
    <div class="mb-12">
      <div class="mb-3">
        <MonoLabel>Connections</MonoLabel>
      </div>
      <h1
        class="font-sans font-medium"
        style="font-size: 28px; line-height: 1.2; letter-spacing: -0.01em; color: var(--text-primary); margin-bottom: 12px;"
      >
        Claude
      </h1>
      <p
        class="max-w-xl"
        style="font-size: 15px; line-height: 1.65; color: var(--text-secondary);"
      >
        Claude reads your workspace through the Model Context Protocol. One endpoint, one
        connector, live access to every doc and (next release) every flow.
      </p>
    </div>

    <!-- Endpoint card -->
    <section
      class="relative overflow-hidden mb-8"
      style="background: var(--surface-overlay); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: 24px;"
    >
      <div class="flex items-center gap-2 mb-4">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--status-success); display: inline-block;"></span>
        <MonoLabel>Workspace endpoint</MonoLabel>
      </div>
      <div class="flex items-center gap-2">
        <code
          class="flex-1 font-mono truncate"
          style="font-size: 13px; padding: 8px 12px; background: var(--surface-sunken); color: var(--text-primary); border-radius: var(--radius-sm);"
          id="mcp-endpoint"
        >
          {mcpEndpoint}
        </code>
        <button
          type="button"
          id="copy-endpoint"
          class="inline-flex items-center justify-center h-9 px-3 font-medium select-none"
          style="font-size: 13px; background: var(--interactive-secondary); color: var(--text-primary); border: 1px solid var(--border-default); border-radius: var(--radius-md);"
          onmouseover="this.style.background='var(--interactive-secondary-hover)'"
          onmouseout="this.style.background='var(--interactive-secondary)'"
        >
          Copy
        </button>
      </div>
      <p style="font-size: 12px; color: var(--text-tertiary); margin-top: 12px;">
        Paste this URL into Claude's connector settings to authorize live read access to this
        workspace.
      </p>
    </section>

    <!-- How to connect -->
    <section class="mb-12">
      <div class="mb-4">
        <MonoLabel>How to connect</MonoLabel>
      </div>
      <ol class="space-y-6 list-none">
        {[
          {
            heading: 'Open Claude’s connector settings',
            body: 'In Claude Desktop or Claude.ai, open Settings → Connectors. You need Claude Pro or higher for MCP connectors.',
          },
          {
            heading: 'Add a new connector',
            body: 'Click “Add connector” and paste the endpoint above. Give it a name like “Mnema”.',
          },
          {
            heading: 'Authorize the connection',
            body: 'Claude opens a browser tab to confirm. You’ll see your Mnema workspace name and the requested scope (docs:read). Approve to finish.',
          },
          {
            heading: 'Ask Claude to read a doc',
            body: 'Once connected, try “What docs are in my Mnema workspace?” or reference any doc by title.',
          },
        ].map((step, i) => (
          <li class="flex gap-4">
            <div
              class="flex-shrink-0 flex items-center justify-center font-mono font-medium"
              style="width: 28px; height: 28px; border-radius: 50%; background: var(--surface-elevated); border: 1px solid var(--border-default); font-size: 13px; color: var(--text-primary);"
            >
              {i + 1}
            </div>
            <div class="pt-0.5">
              <h3 style="font-size: 15px; font-weight: 500; color: var(--text-primary); line-height: 1.5; margin-bottom: 4px;">
                {step.heading}
              </h3>
              <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.65;">
                {step.body}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- What Claude can access -->
    <section
      style="background: var(--surface-overlay); border: 1px solid var(--border-default); border-radius: var(--radius-lg); padding: 24px;"
    >
      <h3 style="font-size: 14px; font-weight: 500; color: var(--text-primary); margin-bottom: 8px;">
        What Claude can access
      </h3>
      <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.65;">
        Authorizing grants <code class="font-mono" style="font-size: 12px; padding: 2px 6px; background: var(--surface-sunken); color: var(--text-primary); border-radius: var(--radius-sm);">docs:read</code> — search and read access to every doc in this workspace. It also lets Claude discover and walk your flows (sequenced content for structured context delivery). Write access (<code class="font-mono" style="font-size: 12px; padding: 2px 6px; background: var(--surface-sunken); color: var(--text-primary); border-radius: var(--radius-sm);">docs:write</code>) is a separate scope for letting Claude draft and update docs directly.
      </p>
    </section>
  </div>

  <script>
    document.getElementById('copy-endpoint')?.addEventListener('click', () => {
      const el = document.getElementById('mcp-endpoint');
      if (!el) return;
      navigator.clipboard.writeText(el.textContent?.trim() ?? '').then(() => {
        const btn = document.getElementById('copy-endpoint') as HTMLButtonElement | null;
        if (!btn) return;
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      });
    });
  </script>
</AppLayout>
