---
import AppLayout from '../../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) return Astro.redirect('/auth/login');

const apiUrl    = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
const publicUrl = (import.meta.env.PUBLIC_MCP_URL as string | undefined) ?? apiUrl;
const mcpUrl    = `${publicUrl}/mcp`;

type TokenRow = { id: string; name: string };
let tokens: TokenRow[] = [];
try {
  const res = await fetch(`${apiUrl}/api/mcp-tokens`, { headers: { Cookie: `boppl_jwt=${auth.jwt}` } });
  if (res.ok) tokens = ((await res.json()) as { tokens: TokenRow[] }).tokens ?? [];
} catch { /* offline */ }

const firstTokenId = tokens[0]?.id ?? '';
const deepLinkUrl  = firstTokenId
  ? `/install/windsurf?workspaceToken=${firstTokenId}`
  : '/install/windsurf';
---

<AppLayout title="Windsurf Connection">
  <style is:global>
    .conn-wrap { max-width: 640px; margin: 0 auto; padding: 40px 32px 80px; font-family: var(--sans); }
    .conn-pre  { font: 500 11px/1 var(--mono); letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); margin: 0 0 12px; }
    .conn-h1   { margin: 0 0 6px; font: 500 28px/1.15 var(--sans); letter-spacing: -0.02em; color: var(--ink); }
    .conn-sub  { margin: 0 0 36px; font-size: 14px; color: var(--ink-soft); }
    .conn-card { background: var(--surface); border: 1px solid var(--line-strong); border-radius: 12px; padding: 20px 22px; margin-bottom: 16px; }
    .conn-card h3 { margin: 0 0 8px; font: 600 14px/1 var(--sans); color: var(--ink); }
    .conn-card p  { margin: 0 0 14px; font-size: 13px; color: var(--ink-soft); line-height: 1.5; }
    .conn-url  { display: flex; align-items: center; gap: 8px; background: var(--surface-2); border: 1px solid var(--line); border-radius: 8px; padding: 9px 12px; }
    .conn-url code { flex: 1; font: 500 12.5px/1 var(--mono); color: var(--ink); word-break: break-all; }
    .conn-copy { flex-shrink: 0; padding: 5px 12px; border-radius: 6px; border: 1px solid var(--line-strong); background: transparent; color: var(--ink-soft); font: 500 12px var(--sans); cursor: pointer; }
    .conn-copy:hover { background: var(--surface-3); color: var(--ink); }
    .conn-btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 9px 18px; border-radius: 8px; border: none; background: var(--accent); color: #0A0B0D; font: 600 13px var(--sans); cursor: pointer; text-decoration: none; }
  </style>

  <div class="conn-wrap">
    <p class="conn-pre">Connections</p>
    <h1 class="conn-h1">Windsurf</h1>
    <p class="conn-sub">Connect Mnema to Windsurf (Codeium) so Cascade can read your workspace docs and context.</p>

    <div class="conn-card">
      <h3>One-click install</h3>
      <p>Opens Windsurf and adds Mnema automatically.</p>
      <a href={deepLinkUrl} class="conn-btn-primary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
        Connect Windsurf
      </a>
    </div>

    <div class="conn-card">
      <h3>Manual setup</h3>
      <p>Add to Windsurf → Settings → MCP, or paste in <code style="font:500 12px var(--mono);background:var(--surface-2);padding:1px 5px;border-radius:4px;">~/.codeium/windsurf/mcp_config.json</code>:</p>
      <div class="conn-url" style="flex-direction:column;align-items:flex-start;">
        <code style="white-space:pre;font-size:12px;line-height:1.6;">{`{
  "mcpServers": {
    "mnema": {
      "type": "sse",
      "url": "${mcpUrl}"
    }
  }
}`}</code>
        <button class="conn-copy" style="margin-top:8px;"
          onclick={`navigator.clipboard.writeText(JSON.stringify({"mcpServers":{"mnema":{"type":"sse","url":"${mcpUrl}"}}},null,2)).then(()=>{this.textContent='Copied!';setTimeout(()=>this.textContent='Copy config',1500)})`}>
          Copy config
        </button>
      </div>
    </div>
  </div>
</AppLayout>
