                </div>
                <div class="t-name">New folder</div>
              </button>
            </div>
          </>
        )}

        {/* ── DOCS SECTION ── */}
        {(unfiledDocs.length > 0 || (isInsideFolder && docs.length > 0)) && (
          <>
            <div class="co-section-title">
              <h3>{isInsideFolder ? heading : 'Docs'}</h3>
              <span class="co-count">
                {isInsideFolder ? docs.length : unfiledDocs.length}
                {' '}
                {(isInsideFolder ? docs.length : unfiledDocs.length) === 1 ? 'item' : 'items'}
              </span>
            </div>

            {/* UNFILE DROP ZONE — shown only when dragging inside a folder */}
            {isInsideFolder && (
              <div id="co-unfile-zone" class="co-unfile-zone">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                Drop here to move out of folder
              </div>
            )}

            {/* ICON GRID */}
            <div class="co-icon-grid">
              {(isInsideFolder ? docs : unfiledDocs).map((d) => {
                const ext = extClass(d);
                const label = extLabel(d);
                return (
                  <a href={`/app/content/${d.id}?back=${backParam}`} class="co-tile" draggable="true" data-doc-id={d.id}>
                    <div class="ico-wrap">
                      <div class={`co-fi ${ext}`}>
                        <div class="sheet">
                          <div class="lines">
                            <i></i><i></i><i></i><i></i><i></i>
                          </div>
                        </div>
                        <div class="ext-tag">{label}</div>
                      </div>
                    </div>
                    <div class="t-name" data-tooltip={d.title || 'Untitled'}>{d.title || 'Untitled'}</div>
                    <div class="t-meta">{relativeTime(d.updated_at)}</div>
                  </a>
                );
              })}
            </div>

            {/* LIST VIEW */}
            <div class="co-list">
              <div class="co-lr head">
                <span></span>
                <span>NAME</span>
                <span>TYPE</span>
                <span>UPDATED</span>
                <span>FOLDER</span>
              </div>
              {(isInsideFolder ? docs : unfiledDocs).map((d) => {
                const unread = unreadByDoc.get(d.id) ?? 0;
                const ext = extClass(d);
                const label = extLabel(d);
                return (
                  <a href={`/app/content/${d.id}?back=${backParam}`} class="co-lr" draggable="true" data-doc-id={d.id}>
                    <div class="co-ic">
                      <div class={`co-file-ico ${ext}`}>
                        <div class="sheet"></div>
                        <div class="ext">{label}</div>
                      </div>
                    </div>
                    <span class="co-nm">
                      {unread > 0 && <span class="co-unread" title={`${unread} unread`}></span>}
                      <span class="co-name" data-tooltip={d.title || 'Untitled'}>{d.title || 'Untitled'}</span>
                    </span>
                    <span class="co-type">{d.type ?? 'doc'}</span>
                    <span class="co-dt">{relativeTime(d.updated_at)}</span>
                    <span onclick="event.preventDefault();event.stopPropagation();">
                      <select
                        class="co-move-sel"
                        data-doc-id={d.id}
                        data-current-folder={d.folder_id ?? ''}
                        title="Move to folder"
                      >
                        <option value="">— unfiled —</option>
                        {folders.map((f) => (
                          <option value={f.id} selected={f.id === d.folder_id}>{f.name}</option>
                        ))}
                      </select>
                    </span>
                  </a>
                );
              })}
            </div>
          </>
        )}

      </div>
      </>
    )}
  </div>

  <script define:vars={{ folderParam, isInsideFolder, backParam }}>
    const DOC_DRAG_TYPE = 'application/x-mnema-doc-id';

    // --- Create doc (blank) ---
    async function createDoc(title = 'Untitled', markdown = '') {
      const typeEl = document.getElementById('new-doc-type');
      const type = typeEl?.value ?? 'doc';
      const body = folderParam
        ? { title, type, markdown, folder_id: folderParam }
        : { title, type, markdown };
      const res = await fetch(`/api/docs`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        alert(err.message ?? 'Failed to create doc');
        return null;
      }
      const { doc } = await res.json();
      return doc;
    }

    document.getElementById('new-doc-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const doc = await createDoc();
      if (doc) window.location.href = `/app/content/${doc.id}?back=${backParam}`;
    });
    document.getElementById('new-doc-form-empty')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const doc = await createDoc();
      if (doc) window.location.href = `/app/content/${doc.id}?back=${backParam}`;
    });

    // --- Upload files (.md / .txt → new docs) ---
    async function importFile(file) {
      const text = await file.text();
      const title = file.name.replace(/\.(md|txt|markdown)$/i, '').trim() || 'Untitled';
      const body = folderParam
        ? { title, type: 'doc', markdown: text, folder_id: folderParam }
        : { title, type: 'doc', markdown: text };
      const res = await fetch(`/api/docs`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      return res.ok ? (await res.json()).doc : null;
    }

    async function importFiles(files) {
      const valid = Array.from(files).filter(f => /\.(md|txt|markdown)$/i.test(f.name));
      if (!valid.length) { alert('Only .md and .txt files are supported'); return; }
      // Import all, then navigate to the first one
      const results = await Promise.all(valid.map(importFile));
      const first = results.find(Boolean);
      if (first) window.location.href = `/app/content/${first.id}?back=${backParam}`;
      else window.location.reload();
    }

    document.getElementById('co-upload-inp')?.addEventListener('change', (e) => {
      if (e.target.files?.length) void importFiles(e.target.files);
      e.target.value = ''; // reset so same file can be re-uploaded
    });

    // ── Import DOCX / PDF ─────────────────────────────────────────────────
    const docxLabel = document.getElementById('co-docx-label');
    async function importDocxPdf(file) {
      const originalText = docxLabel?.querySelector('svg')?.nextSibling;
      if (docxLabel) docxLabel.setAttribute('data-loading', 'true');
      const labelSpan = docxLabel?.childNodes[2]; // text node after svg
      const prevText = docxLabel ? docxLabel.innerHTML : '';
      if (docxLabel) docxLabel.title = `Processing ${file.name}...`;

      const form = new FormData();
      // folderId must come BEFORE the file — multipart only captures fields
      // that appear before the file part in the stream.
      if (folderParam) form.append('folderId', folderParam);
      form.append('file', file, file.name);

      try {
        const res = await fetch('/api/document-files/upload', {
          method: 'POST',
          credentials: 'include',
          body: form,
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          alert(`Import failed: ${err.message ?? res.statusText}`);
          return;
        }
        const { docId } = await res.json();
        window.location.href = `/app/content/${docId}?back=${backParam}`;
      } catch (err) {
        alert(`Import failed: ${String(err)}`);
      } finally {
        if (docxLabel) docxLabel.title = 'Import DOCX or PDF';
      }
    }

    document.getElementById('co-docx-inp')?.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (file) void importDocxPdf(file);
      e.target.value = '';
    });

    // --- Create folder (supports nested via parent_id) ---
    const addBtn = document.getElementById('co-add-folder-btn');
    const inputWrap = document.getElementById('co-folder-input-wrap');
    const nameInp = document.getElementById('co-folder-name-inp');

    addBtn?.addEventListener('click', () => {
      addBtn.style.display = 'none';
      inputWrap?.classList.add('visible');
      nameInp?.focus();
    });

    async function submitFolder() {
      const name = nameInp?.value?.trim();
      if (!name) { cancelFolder(); return; }
      const body = folderParam ? { name, parent_id: folderParam } : { name };
      const res = await fetch(`/api/folders`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) { alert('Failed to create folder'); return; }
      window.location.reload();
    }

    function cancelFolder() {
      if (inputWrap) inputWrap.classList.remove('visible');
      if (addBtn) addBtn.style.display = '';
      if (nameInp) nameInp.value = '';
    }

    nameInp?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); void submitFolder(); }
      if (e.key === 'Escape') cancelFolder();
    });
    nameInp?.addEventListener('blur', () => {
      setTimeout(() => {
        if (document.activeElement !== nameInp) {
          if (nameInp?.value?.trim()) { void submitFolder(); } else { cancelFolder(); }
        }
      }, 150);
    });

    // ── RIGHT-CLICK CONTEXT MENU ─────────────────────────────────────────
    const ctxMenu = document.getElementById('co-ctx-menu');
    let ctxTarget = null; // { type: 'doc'|'folder', id, name, el }

    function hideCtx() {
      if (ctxMenu) ctxMenu.classList.remove('visible');
      ctxTarget = null;
    }

    function showCtx(x, y, items) {
      if (!ctxMenu) return;
      // Build menu items
      ctxMenu.innerHTML = items.map(item => {
        if (item === '---') return '<div class="co-ctx-sep"></div>';
        const dangerClass = item.danger ? ' danger' : '';
        return `<div class="co-ctx-item${dangerClass}" data-action="${item.action}">${item.icon ?? ''}${item.label}</div>`;
      }).join('');
      // Position near cursor, flip if off-screen
      ctxMenu.style.left = '0px';
      ctxMenu.style.top = '0px';
      ctxMenu.classList.add('visible');
      const mw = ctxMenu.offsetWidth;
      const mh = ctxMenu.offsetHeight;
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      ctxMenu.style.left = (x + mw > vw ? x - mw : x) + 'px';
      ctxMenu.style.top  = (y + mh > vh ? y - mh : y) + 'px';
    }

    function iconSvg(path, size = 14) {
      return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
    }

    // Build menu for a doc tile
    function docCtxItems() {
      return [
        { action: 'preview', label: 'Preview',      icon: iconSvg('<path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/>') },
        { action: 'open',   label: 'Open',         icon: iconSvg('<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>') },
        { action: 'rename', label: 'Rename',        icon: iconSvg('<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>') },
        '---',
        { action: 'delete', label: 'Delete',        icon: iconSvg('<polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>'), danger: true },
      ];
    }

    // Build menu for a folder tile
    function folderCtxItems() {
      return [
        { action: 'open',    label: 'Open',          icon: iconSvg('<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>') },
        { action: 'rename',  label: 'Rename',        icon: iconSvg('<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>') },
        { action: 'new-sub', label: 'New folder inside', icon: iconSvg('<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>') },
        '---',
        { action: 'delete',  label: 'Delete',        icon: iconSvg('<polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/>'), danger: true },
      ];
    }

    // Attach contextmenu to doc tiles
    document.querySelectorAll('.co-tile[data-doc-id], .co-lr[data-doc-id]').forEach(el => {
      el.addEventListener('contextmenu', e => {
        e.preventDefault();
        ctxTarget = { type: 'doc', id: el.dataset.docId, name: el.querySelector('.t-name,.co-name')?.textContent?.trim() ?? '', el, href: el.href };
        showCtx(e.clientX + 2, e.clientY + 2, docCtxItems());
      });
    });

    // Attach contextmenu to folder tiles
    document.querySelectorAll('.co-tile[data-folder-id]').forEach(el => {
      el.addEventListener('contextmenu', e => {
        e.preventDefault();
        ctxTarget = { type: 'folder', id: el.dataset.folderId, name: el.dataset.folderName ?? '', el };
        showCtx(e.clientX + 2, e.clientY + 2, folderCtxItems());
      });
    });

    // Handle menu item clicks
    ctxMenu?.addEventListener('click', async e => {
      const item = e.target.closest('[data-action]');
      if (!item || !ctxTarget) return;
      const action = item.dataset.action;
      const t = ctxTarget;
      hideCtx();

      if (action === 'preview' && t.type === 'doc') {
        window.dispatchEvent(new CustomEvent('mnema:preview-doc', { detail: { docId: t.id } }));
        return;
      }

      if (action === 'open') {
        if (t.type === 'doc') window.location.href = t.href ?? `/app/content/${t.id}?back=${backParam}`;
        else window.location.href = `/app/content?folder=${t.id}`;
        return;
      }

      if (action === 'rename' && t.type === 'doc') {
        const newName = window.prompt('Rename doc:', t.name);
        if (!newName?.trim() || newName.trim() === t.name) return;
        const res = await fetch(`/api/docs/${t.id}`, {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title: newName.trim() }),
        });
        if (res.ok) {
          // Update the title in place on all matching elements (icon + list view).
          document.querySelectorAll(`[data-doc-id="${t.id}"] .t-name, [data-doc-id="${t.id}"] .co-name`).forEach(el => {
            el.textContent = newName.trim();
          });
        } else {
          alert('Failed to rename doc');
        }
        return;
      }

      if (action === 'rename' && t.type === 'folder') {
        const newName = window.prompt('Rename folder:', t.name);
        if (!newName?.trim() || newName.trim() === t.name) return;
        const res = await fetch(`/api/folders/${t.id}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: newName.trim() }),
        });
        if (res.ok) window.location.reload();
        else alert('Failed to rename folder');
        return;
      }

      if (action === 'new-sub' && t.type === 'folder') {
        const name = window.prompt('New folder name:');
        if (!name?.trim()) return;
        const res = await fetch(`/api/folders`, {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name.trim(), parent_id: t.id }),
        });
        if (res.ok) window.location.href = `/app/content?folder=${t.id}`;
        else alert('Failed to create folder');
        return;
      }

      if (action === 'delete') {
        if (t.type === 'doc') {
          if (!confirm(`Delete "${t.name}"? This cannot be undone.`)) return;
          const res = await fetch(`/api/docs/${t.id}`, {
            method: 'DELETE', credentials: 'include', headers: {},
          });
          if (res.ok || res.status === 204) window.location.reload();
          else alert('Failed to delete doc');
        } else {
          if (!confirm(`Delete folder "${t.name}"? Docs inside will become unfiled.`)) return;
          const res = await fetch(`/api/folders/${t.id}`, {
            method: 'DELETE', credentials: 'include', headers: {},
          });
          if (res.ok || res.status === 204) window.location.reload();
          else alert('Failed to delete folder');
        }
        return;
      }
    });

    // Dismiss on outside click / Escape
    document.addEventListener('click', e => {
      if (ctxMenu && !ctxMenu.contains(e.target)) hideCtx();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') hideCtx();
    });

    // --- Move doc to folder (list view select) ---
    document.querySelectorAll('.co-move-sel').forEach((sel) => {
      sel.addEventListener('change', async (e) => {
        const docId = e.target.dataset.docId;
        const folderId = e.target.value || null;
        if (!docId) return;
        await fetch(`/api/docs/${docId}/folder`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ folder_id: folderId }),
        });
        window.location.reload();
      });
    });

    // --- View toggle ---
    const coViewSeg = document.getElementById('co-view-seg');
    const coWrap = document.getElementById('co-wrap');
    coViewSeg?.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-view]');
      if (!btn || !coWrap) return;
      const v = btn.dataset.view;
      coWrap.classList.remove('view-icons', 'view-list');
      coWrap.classList.add('view-' + v);
      coViewSeg.querySelectorAll('button').forEach((b) => {
        const isActive = b.dataset.view === v;
        b.style.background = isActive ? 'var(--canvas)' : 'transparent';
        b.style.color = isActive ? 'var(--ink)' : 'var(--ink-muted)';
      });
    });

    // ── WITHIN-APP DRAG (move docs between folders) ──────────────────────
    // Uses a custom MIME type so it never conflicts with OS file drops or
    // the browser's default link-drag behaviour on <a> elements.
    let draggingDocId = null;
    const unfileZone = document.getElementById('co-unfile-zone');

    async function moveDocToFolder(docId, folderId) {
      const res = await fetch(`/api/docs/${docId}/folder`, {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ folder_id: folderId }),
      });
      if (res.ok) window.location.reload();
    }

    document.querySelectorAll('.co-tile[data-doc-id], .co-lr[data-doc-id]').forEach((el) => {
      el.addEventListener('dragstart', (e) => {
        draggingDocId = el.dataset.docId;
        // Custom type prevents conflict with link/URL drag and OS file drops
        e.dataTransfer.setData(DOC_DRAG_TYPE, draggingDocId);
        e.dataTransfer.setData('text/plain', draggingDocId); // fallback
        e.dataTransfer.effectAllowed = 'move';
        setTimeout(() => el.classList.add('co-dragging'), 0);
        if (unfileZone) unfileZone.classList.add('co-drag-active');
      });
      el.addEventListener('dragend', () => {
        el.classList.remove('co-dragging');
        draggingDocId = null;
        if (unfileZone) {
          unfileZone.classList.remove('co-drag-active', 'co-drag-over');
        }
      });
    });

    // Folder tiles as drop targets (only accept within-app doc drags)
    document.querySelectorAll('.co-tile[data-folder-id]').forEach((folder) => {
      folder.addEventListener('dragover', (e) => {
        if (!e.dataTransfer.types.includes(DOC_DRAG_TYPE) && !draggingDocId) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        folder.classList.add('co-drag-over');
      });
      folder.addEventListener('dragleave', (e) => {
        if (!folder.contains(e.relatedTarget)) folder.classList.remove('co-drag-over');
      });
      folder.addEventListener('drop', (e) => {
        e.preventDefault();
        folder.classList.remove('co-drag-over');
        const docId = e.dataTransfer.getData(DOC_DRAG_TYPE) || draggingDocId;
        const folderId = folder.dataset.folderId;
        if (docId && folderId) void moveDocToFolder(docId, folderId);
      });
    });

    // Unfile drop zone
    if (unfileZone) {
      unfileZone.addEventListener('dragover', (e) => {
        if (!e.dataTransfer.types.includes(DOC_DRAG_TYPE) && !draggingDocId) return;
        e.preventDefault();
        unfileZone.classList.add('co-drag-over');
      });
      unfileZone.addEventListener('dragleave', () => unfileZone.classList.remove('co-drag-over'));
      unfileZone.addEventListener('drop', (e) => {
        e.preventDefault();
        unfileZone.classList.remove('co-drag-over');
        const docId = e.dataTransfer.getData(DOC_DRAG_TYPE) || draggingDocId;
        if (docId) void moveDocToFolder(docId, null);
      });
    }

    // ── OS FILE DROP (import .md/.txt from Finder/Explorer) ──────────────
    const dropOverlay = document.getElementById('co-drop-overlay');
    let osDropCounter = 0;

    window.addEventListener('dragenter', (e) => {
      if (!e.dataTransfer.types.includes('Files')) return;
      osDropCounter++;
      if (dropOverlay) dropOverlay.classList.add('visible');
    });
    window.addEventListener('dragleave', (e) => {
      if (!e.dataTransfer.types.includes('Files')) return;
      osDropCounter = Math.max(0, osDropCounter - 1);
      if (osDropCounter === 0 && dropOverlay) dropOverlay.classList.remove('visible');
    });
    window.addEventListener('dragover', (e) => {
      if (e.dataTransfer.types.includes('Files')) e.preventDefault();
    });
    window.addEventListener('drop', (e) => {
      if (!e.dataTransfer.files?.length) return;
      e.preventDefault();
      osDropCounter = 0;
      if (dropOverlay) dropOverlay.classList.remove('visible');
      const files = Array.from(e.dataTransfer.files);
      const docxPdf = files.filter(f => /\.(docx|pdf)$/i.test(f.name));
      const mdTxt   = files.filter(f => /\.(md|txt|markdown)$/i.test(f.name));
      if (docxPdf.length) void importDocxPdf(docxPdf[0]);
      if (mdTxt.length)   void importFiles(mdTxt);
    });
  </script>

  <script>
    // ── RECENTLY OPENED ───────────────────────────────────────────────────────
    // Track the last 8 docs opened. Store { id, title, href, ts } in localStorage.
    const RECENT_KEY = 'mnema_recent_docs';
    const RECENT_MAX = 8;

    function getRecent() {
      try { return JSON.parse(localStorage.getItem(RECENT_KEY) ?? '[]'); } catch { return []; }
    }
    function saveRecent(list) {
      localStorage.setItem(RECENT_KEY, JSON.stringify(list));
    }
    // Record open when a doc tile is clicked
    document.querySelectorAll('a[data-doc-id]').forEach(a => {
      a.addEventListener('click', () => {
        const id    = a.dataset.docId ?? '';
        const title = a.querySelector<HTMLElement>('.t-name,.co-name')?.textContent?.trim() ?? 'Untitled';
        const href  = a.href;
        if (!id) return;
        const list  = getRecent().filter(r => r.id !== id);
        list.unshift({ id, title, href, ts: Date.now() });
        saveRecent(list.slice(0, RECENT_MAX));
      });
    });

    // Render the recently opened strip
    function relTime(ts: number): string {
      const s = Math.floor((Date.now() - ts) / 1000);
      if (s < 60)   return 'just now';
      if (s < 3600) return Math.floor(s/60) + 'm ago';
      if (s < 86400)return Math.floor(s/3600) + 'h ago';
      return Math.floor(s/86400) + 'd ago';
    }

    const recentSection = document.getElementById('co-recent-section');
    const recentScroll  = document.getElementById('co-recent-scroll');
    if (recentScroll) {
      const list = getRecent();
      if (list.length > 0) {
        recentScroll.innerHTML = list.map(r => `
          <a class="co-recent-item" href="${r.href}" data-doc-id="${r.id}">
            <div class="co-recent-icon">
              <svg width="9" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
            <div>
              <div class="co-recent-name">${r.title.replace(/</g,'&lt;')}</div>
              <div class="co-recent-time">${relTime(r.ts)}</div>
            </div>
          </a>`).join('');
        if (recentSection) recentSection.style.display = '';
        // Wire click tracking on recently opened items too
        recentScroll.querySelectorAll('a[data-doc-id]').forEach(a => {
          a.addEventListener('click', () => {
            const id    = a.dataset.docId ?? '';
            const title = a.querySelector<HTMLElement>('.co-recent-name')?.textContent?.trim() ?? '';
            const href  = a.href;
            if (!id) return;
            const l = getRecent().filter(r => r.id !== id);
            l.unshift({ id, title, href, ts: Date.now() });
            saveRecent(l.slice(0, RECENT_MAX));
          });
        });
      }
    }

    // ── SORT & FILTER ─────────────────────────────────────────────────────────
    // All sorting/filtering is client-side — tiles are already in the DOM.
    const allTiles = Array.from(document.querySelectorAll('.co-icon-grid a[data-doc-id]'));
    const allRows  = Array.from(document.querySelectorAll('.co-list a[data-doc-id]'));
    const iconGrid = document.querySelector('.co-icon-grid');
    const listGrid = document.querySelector('.co-list');

    let currentSort = 'updated'; // 'updated' | 'alpha'
    let currentType = '';        // '' = all

    function applyFilters() {
      const items = [...allTiles, ...allRows];
      items.forEach(el => {
        const type = el.querySelector<HTMLElement>('.co-type')?.textContent?.trim() ?? '';
        const show = !currentType || type === currentType;
        el.style.display = show ? '' : 'none';
      });
      // Re-sort visible tiles
      if (iconGrid) {
        const visible = allTiles.filter(el => el.style.display !== 'none');
        if (currentSort === 'alpha') {
          visible.sort((a, b) => {
            const ta = a.querySelector('.t-name')?.textContent?.trim() ?? '';
            const tb = b.querySelector('.t-name')?.textContent?.trim() ?? '';
            return ta.localeCompare(tb);
          });
        } else {
          // 'updated' — restore original DOM order (already sorted by server)
          allTiles.forEach(el => { if (el.style.display !== 'none') iconGrid.appendChild(el); });
          return;
        }
        visible.forEach(el => iconGrid.appendChild(el));
      }
      if (listGrid && currentSort === 'alpha') {
        const head = listGrid.querySelector('.co-lr.head');
        const visible = allRows.filter(el => el.style.display !== 'none');
        visible.sort((a, b) => {
          const ta = a.querySelector('.co-name')?.textContent?.trim() ?? '';
          const tb = b.querySelector('.co-name')?.textContent?.trim() ?? '';
          return ta.localeCompare(tb);
        });
        visible.forEach(el => listGrid.appendChild(el));
      }
    }

    // Sort buttons
    document.querySelectorAll('.co-sort-btn[data-sort]').forEach(btn => {
      btn.addEventListener('click', () => {
        currentSort = btn.dataset.sort ?? 'updated';
        document.querySelectorAll('.co-sort-btn[data-sort]').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
      });
    });

    // Type filter buttons
    document.querySelectorAll('.co-sort-btn[data-type]').forEach(btn => {
      btn.addEventListener('click', () => {
        currentType = btn.dataset.type ?? '';
        document.querySelectorAll('.co-sort-btn[data-type]').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
      });
    });

    // Set "All types" as active by default
    document.querySelector('.co-sort-btn[data-type=""]')?.classList.add('active');
  </script>
</AppLayout>
