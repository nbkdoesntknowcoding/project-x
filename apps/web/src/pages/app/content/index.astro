---
import AppLayout from '../../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';

// Folder browsing: ?folder=<id> to enter a folder, no param = root view
const folderParam = Astro.url.searchParams.get('folder');
const isInsideFolder = !!folderParam;

interface DocSummary {
  id: string;
  title: string;
  type: string;
  folder_id: string | null;
  updated_at: string;
}

interface FolderSummary {
  id: string;
  name: string;
  doc_count: number;
}

let docs: DocSummary[] = [];
let folders: FolderSummary[] = [];
let currentFolder: FolderSummary | null = null;
const unreadByDoc = new Map<string, number>();

try {
  const docsQuery = isInsideFolder ? `?folder_id=${folderParam}` : '';
  const [docsRes, foldersRes, unreadRes] = await Promise.all([
    fetch(`${apiUrl}/api/docs${docsQuery}`, {
      headers: { Cookie: `boppl_jwt=${auth.jwt}` },
    }),
    fetch(`${apiUrl}/api/folders`, {
      headers: { Cookie: `boppl_jwt=${auth.jwt}` },
    }),
    fetch(`${apiUrl}/api/doc-read-state/unread-counts`, {
      headers: { Cookie: `boppl_jwt=${auth.jwt}` },
    }),
  ]);
  if (docsRes.ok) {
    const body = (await docsRes.json()) as { docs: DocSummary[] };
    docs = body.docs;
  }
  if (foldersRes.ok) {
    const body = (await foldersRes.json()) as { folders: FolderSummary[] };
    folders = body.folders;
    if (isInsideFolder) {
      currentFolder = folders.find((f) => f.id === folderParam) ?? null;
    }
  }
  if (unreadRes.ok) {
    const body = (await unreadRes.json()) as {
      unread: Array<{ doc_id: string; unread_comment_count: number }>;
    };
    for (const row of body.unread ?? []) {
      unreadByDoc.set(row.doc_id, row.unread_comment_count);
    }
  }
} catch {
  /* API offline */
}

// At root level, only show unfiled docs below the folder tiles
const unfiledDocs = isInsideFolder ? docs : docs.filter((d) => !d.folder_id);

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString();
}

const domainPart = auth.email.split('@')[1]?.split('.')[0] ?? '';
const workspaceName = domainPart
  ? domainPart.charAt(0).toUpperCase() + domainPart.slice(1)
  : 'Workspace';

function extClass(type: string): string {
  return type === 'engineering' ? 'eng'
    : type === 'instruction' ? 'inst'
    : type === 'snippet' ? 'snip'
    : 'md';
}
function extLabel(type: string): string {
  return type === 'engineering' ? 'ENG'
    : type === 'instruction' ? 'INST'
    : type === 'snippet' ? 'SNIP'
    : 'MD';
}

const heading = isInsideFolder
  ? (currentFolder?.name ?? 'Folder')
  : 'All docs';

const totalItems = isInsideFolder
  ? docs.length
  : folders.length + unfiledDocs.length;
---

<style>
  .co-main { padding: 14px 24px 80px; }

  /* VIEW TOGGLE */
  .co-wrap.view-icons .co-list { display: none; }
  .co-wrap.view-list .co-icon-grid { display: none; }
  .co-wrap.view-list .co-folder-grid { display: none; }

  /* SECTION TITLE */
  .co-section-title {
    display: flex; align-items: baseline; justify-content: space-between;
    margin: 10px 4px 12px;
  }
  .co-section-title h3 {
    margin: 0; font: 500 11px/1 var(--mono);
    letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-muted);
  }
  .co-section-title .co-count { font: 500 11px/1 var(--mono); color: var(--ink-muted); }

  /* ICON + FOLDER GRID */
  .co-icon-grid,
  .co-folder-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 6px;
    margin-bottom: 24px;
  }

  /* TILE (shared between folders and files) */
  .co-tile {
    display: flex; flex-direction: column; align-items: center;
    gap: 6px;
    padding: 12px 6px 10px;
    border-radius: 9px;
    cursor: default;
    user-select: none;
    position: relative;
    text-decoration: none;
  }
  .co-tile:hover { background: var(--surface-2); }
  .co-tile .ico-wrap {
    height: 78px;
    display: flex; align-items: center; justify-content: center;
  }
  .co-tile .t-name {
    font: 500 12.5px/1.25 var(--sans);
    color: var(--ink);
    text-align: center;
    max-width: 100%;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-word;
    padding: 0 4px;
  }
  .co-tile .t-meta {
    font: 500 10.5px/1 var(--sans);
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  /* ADD-FOLDER TILE */
  .co-tile-add {
    display: flex; flex-direction: column; align-items: center;
    gap: 6px; padding: 12px 6px 10px;
    border-radius: 9px; cursor: pointer;
    user-select: none; border: 0; background: transparent; width: 100%;
  }
  .co-tile-add:hover { background: var(--surface-2); }
  .co-tile-add .ico-wrap {
    height: 78px; display: flex; align-items: center; justify-content: center;
  }
  .co-tile-add .t-name {
    font: 500 12.5px/1.25 var(--sans); color: var(--ink-muted); text-align: center;
  }

  /* Folder name inline editor (shown over the add tile when creating) */
  #co-folder-input-wrap {
    display: none; flex-direction: column; align-items: center;
    gap: 6px; padding: 12px 6px 10px;
    border-radius: 9px; background: var(--surface-2);
  }
  #co-folder-input-wrap.visible { display: flex; }
  #co-folder-input-wrap .ico-wrap {
    height: 78px; display: flex; align-items: center; justify-content: center;
  }
  #co-folder-name-inp {
    width: 100%; background: var(--canvas);
    border: 1px solid var(--accent); border-radius: 4px;
    color: var(--ink); font: 500 12px/1 var(--sans);
    padding: 4px 6px; text-align: center; outline: none;
  }

  /* FOLDER ICON */
  .co-folder-svg {
    width: 96px; height: 74px;
    filter: drop-shadow(0 6px 14px rgba(0,0,0,0.45));
  }

  /* LARGE FILE ICON */
  .co-fi {
    width: 56px; height: 68px;
    position: relative;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.4));
  }
  .co-fi .sheet {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, #FBFBFA, #DBDBD7);
    border-radius: 4px;
    overflow: hidden;
  }
  .co-fi .sheet::before {
    content: ""; position: absolute; top: 0; right: 0;
    width: 16px; height: 16px;
    background: linear-gradient(225deg, rgba(0,0,0,0.18) 50%, transparent 50%);
    border-bottom-left-radius: 4px;
  }
  .co-fi .sheet::after {
    content: ""; position: absolute; top: 0; right: 0;
    width: 16px; height: 16px;
    background: linear-gradient(135deg, transparent 50%, #C7C7C2 50%);
    border-bottom-left-radius: 4px;
  }
  .co-fi .lines {
    position: absolute; left: 7px; right: 7px; top: 24px;
    display: flex; flex-direction: column; gap: 3px;
  }
  .co-fi .lines i {
    height: 2px; background: rgba(10,11,13,0.18); border-radius: 1px;
    display: block;
  }
  .co-fi .lines i:nth-child(2) { width: 72%; }
  .co-fi .lines i:nth-child(3) { width: 90%; }
  .co-fi .lines i:nth-child(4) { width: 60%; }
  .co-fi .lines i:nth-child(5) { width: 82%; }
  .co-fi .ext-tag {
    position: absolute; bottom: 6px; left: -3px; right: -3px;
    display: flex; align-items: center; justify-content: center;
    padding: 3px 0;
    border-radius: 3px;
    font: 700 9px/1 var(--sans);
    color: white;
    letter-spacing: 0.08em;
  }
  .co-fi.md .ext-tag   { background: linear-gradient(180deg, #1E1F23, #0E0F12); color: var(--accent); }
  .co-fi.eng .ext-tag  { background: linear-gradient(180deg, #7C9CFF, #4A67D9); }
  .co-fi.inst .ext-tag { background: linear-gradient(180deg, #FFB370, #FF7A8A); color: var(--on-ink); }
  .co-fi.snip .ext-tag { background: linear-gradient(180deg, #6BE39B, #2B9B9B); color: var(--on-ink); }

  /* LIST VIEW */
  .co-list { display: flex; flex-direction: column; }
  .co-lr {
    display: grid;
    grid-template-columns: 28px minmax(0,1fr) 90px 80px 28px;
    align-items: center; padding: 7px 10px; border-radius: 6px;
    font: 400 12.5px/1 var(--sans); gap: 12px; text-decoration: none; color: var(--ink);
  }
  .co-lr.head {
    font: 500 10.5px/1 var(--mono); color: var(--ink-muted);
    letter-spacing: 0.04em; text-transform: uppercase;
    padding: 8px 10px; border-bottom: 1px solid var(--line); border-radius: 0;
  }
  .co-lr:not(.head):hover { background: var(--surface-2); }
  .co-lr .co-ic {
    width: 22px; height: 22px;
    display: flex; align-items: center; justify-content: center;
  }
  .co-lr .co-nm { color: var(--ink); display: flex; align-items: center; gap: 6px; min-width: 0; }
  .co-lr .co-nm .co-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .co-lr .co-type {
    font: 500 10px/1 var(--mono); letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ink-muted); padding: 2px 6px;
    background: var(--surface-2); border-radius: 4px; white-space: nowrap;
  }
  .co-lr .co-dt { color: var(--ink-muted); font-size: 12px; }
  .co-lr .co-unread {
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0;
  }

  /* SMALL FILE ICON (list view) */
  .co-file-ico {
    width: 18px; height: 22px; position: relative; flex-shrink: 0;
  }
  .co-file-ico .sheet {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, #FBFBFA, #DBDBD7);
    border-radius: 3px; overflow: hidden;
  }
  .co-file-ico .sheet::before {
    content: ""; position: absolute; top: 0; right: 0;
    width: 7px; height: 7px;
    background: linear-gradient(225deg, rgba(0,0,0,0.18) 50%, transparent 50%);
  }
  .co-file-ico .ext {
    position: absolute; bottom: 0; left: -2px; right: -2px;
    display: flex; align-items: center; justify-content: center;
    padding: 2px 0; border-radius: 2px;
    font: 700 6px/1 var(--sans); color: white; letter-spacing: 0.04em;
  }
  .co-file-ico.md .ext   { background: linear-gradient(180deg, #1E1F23, #0E0F12); color: var(--accent); }
  .co-file-ico.eng .ext  { background: linear-gradient(180deg, #7C9CFF, #4A67D9); }
  .co-file-ico.inst .ext { background: linear-gradient(180deg, #FFB370, #FF7A8A); color: var(--on-ink); }
  .co-file-ico.snip .ext { background: linear-gradient(180deg, #6BE39B, #2B9B9B); color: var(--on-ink); }

  /* EMPTY STATE */
  .co-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: calc(100% - 80px); padding: 60px 24px; text-align: center; gap: 12px;
  }
  .co-empty-kicker {
    font: 500 11px/1 var(--mono); letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted);
  }
  .co-empty h2 { margin: 0; font: 500 28px/1.1 var(--sans); letter-spacing: -0.02em; color: var(--ink); }
  .co-empty p { margin: 0; font-size: 14px; line-height: 1.6; color: var(--ink-muted); max-width: 400px; }
  .co-empty-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 16px; border-radius: 7px;
    background: var(--ink); color: var(--on-ink);
    font: 500 13px/1 var(--sans); cursor: pointer; border: 0; margin-top: 8px;
  }
  .co-empty-btn:hover { opacity: 0.88; }

  /* MOVE-TO-FOLDER SELECT (list view) */
  .co-move-sel {
    appearance: none; background: var(--surface-2); border: 1px solid var(--line);
    border-radius: 4px; color: var(--ink-muted); font: 400 11px/1 var(--sans);
    padding: 2px 6px; cursor: pointer; outline: none; max-width: 80px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .co-move-sel:hover { border-color: var(--accent); }

  /* DRAG-AND-DROP */
  .co-tile[data-doc-id] { cursor: default; }
  .co-tile[data-doc-id].co-dragging { opacity: 0.35; pointer-events: none; }
  .co-tile[data-folder-id].co-drag-over {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }
  .co-tile[data-folder-id].co-drag-over .co-folder-svg {
    filter: drop-shadow(0 6px 14px rgba(0,0,0,0.45)) brightness(1.15);
    transform: scale(1.04);
    transition: transform 120ms ease;
  }
  /* Unfile drop zone (shown when dragging inside a folder) */
  .co-unfile-zone {
    display: none; align-items: center; justify-content: center; gap: 8px;
    border: 1.5px dashed var(--line); border-radius: 8px;
    padding: 10px 16px; margin-bottom: 16px;
    color: var(--ink-muted); font: 500 12px/1 var(--sans);
    transition: border-color 120ms, background 120ms;
  }
  .co-unfile-zone.co-drag-active { display: flex; }
  .co-unfile-zone.co-drag-over {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
  }
  /* List row draggable */
  .co-lr[data-doc-id] { cursor: default; }
  .co-lr[data-doc-id].co-dragging { opacity: 0.35; }
</style>

<AppLayout title="Content — Mnema" workspaceName={workspaceName} email={auth.email} hasToolbar={true}>

  <!-- TOOLBAR -->
  <Fragment slot="toolbar">
    <div style="display:flex;align-items:center;flex:1;min-width:0;">
      <div style="display:flex;align-items:center;gap:1px;margin-right:10px;">
        <button
          onclick="history.back()"
          style="width:26px;height:26px;border:0;background:transparent;border-radius:5px;color:var(--ink-muted);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;"
          title="Back"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button
          onclick="history.forward()"
          style="width:26px;height:26px;border:0;background:transparent;border-radius:5px;color:var(--ink-muted);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;"
          title="Forward"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
      <div style="display:flex;align-items:center;gap:6px;font:500 13.5px/1 var(--sans);color:var(--ink-muted);">
        <a href="/app/content" style="text-decoration:none;color:inherit;">{workspaceName}</a>
        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--ink-faint);"><path d="m9 6 6 6-6 6"/></svg>
        {isInsideFolder ? (
          <>
            <a href="/app/content" style="text-decoration:none;color:var(--ink-muted);">All docs</a>
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--ink-faint);"><path d="m9 6 6 6-6 6"/></svg>
            <span style="color:var(--ink);font-weight:600;">{heading}</span>
          </>
        ) : (
          <span style="color:var(--ink);font-weight:600;">All docs</span>
        )}
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <div id="co-view-seg" style="display:inline-flex;background:var(--surface-2);border:1px solid var(--line);border-radius:6px;padding:2px;">
        <button data-view="icons" style="width:28px;height:22px;border:0;background:var(--canvas);border-radius:4px;color:var(--ink);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;" title="Icon view">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
        </button>
        <button data-view="list" style="width:28px;height:22px;border:0;background:transparent;border-radius:4px;color:var(--ink-muted);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;" title="List view">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
      </div>
      <form id="new-doc-form" style="display:flex;align-items:center;gap:6px;">
        <select id="new-doc-type" style="height:28px;padding:0 8px;border-radius:6px;background:var(--surface-2);color:var(--ink);border:1px solid var(--line);font:500 12px/1 var(--sans);outline:none;cursor:pointer;">
          <option value="doc">Doc</option>
          <option value="engineering">Engineering</option>
          <option value="instruction">Instruction</option>
          <option value="snippet">Snippet</option>
        </select>
        <button type="submit" style="display:inline-flex;align-items:center;gap:5px;padding:5px 10px 5px 8px;border-radius:6px;background:var(--ink);border:1px solid var(--ink);font:500 12px/1 var(--sans);color:var(--on-ink);cursor:pointer;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>New
        </button>
      </form>
    </div>
  </Fragment>

  <!-- STATUS LEFT -->
  <Fragment slot="status-left">
    <span style="font:500 11px/1 var(--mono);color:var(--ink-muted);">
      {totalItems} {totalItems === 1 ? 'item' : 'items'}{isInsideFolder ? ` · ${heading}` : ''}
    </span>
  </Fragment>

  <!-- MAIN CONTENT -->
  <div class="co-main">
    {totalItems === 0 && !isInsideFolder ? (
      <div class="co-empty">
        <span class="co-empty-kicker">Empty workspace</span>
        <h2>Add your first content unit.</h2>
        <p>
          Docs become the building blocks of flows — sequenced context Claude reads in order.
          Start with one doc, add more, then compose them.
        </p>
        <form id="new-doc-form-empty">
          <button type="submit" class="co-empty-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            Create document
          </button>
        </form>
      </div>
    ) : isInsideFolder && docs.length === 0 ? (
      <div class="co-empty">
        <span class="co-empty-kicker">Empty folder</span>
        <h2>No docs in this folder yet.</h2>
        <p>Create a new doc or move existing docs here.</p>
        <form id="new-doc-form-empty">
          <button type="submit" class="co-empty-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            Create document here
          </button>
        </form>
      </div>
    ) : (
      <div class="co-wrap view-icons" id="co-wrap">

        {/* ── FOLDERS SECTION (root view only) ── */}
        {!isInsideFolder && (
          <>
            <div class="co-section-title">
              <h3>Folders</h3>
              <span class="co-count">{folders.length} {folders.length === 1 ? 'item' : 'items'}</span>
            </div>

            <div class="co-folder-grid" id="co-folder-grid">
              {folders.map((f) => (
                <a href={`/app/content?folder=${f.id}`} class="co-tile" data-folder-id={f.id} data-folder-name={f.name}>
                  <div class="ico-wrap">
                    <svg class="co-folder-svg" viewBox="0 0 168 130" fill="none" preserveAspectRatio="xMidYMid meet">
                      <defs>
                        <linearGradient id={`fgp-${f.id}`} x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0" stop-color="#F5F5F5"/>
                          <stop offset="1" stop-color="#D6D6D6"/>
                        </linearGradient>
                        <linearGradient id={`fgf-${f.id}`} x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0" stop-color="#5C5E64"/>
                          <stop offset="0.45" stop-color="#3E4046"/>
                          <stop offset="1" stop-color="#2C2E33"/>
                        </linearGradient>
                      </defs>
                      <g>
                        <path d="M48 16 L106 16 L116 26 L116 84 Q116 88 112 88 L48 88 Q44 88 44 84 L44 20 Q44 16 48 16 Z" fill={`url(#fgp-${f.id})`}/>
                        <path d="M106 16 L116 26 L106 26 Z" fill="#B8B8B8"/>
                      </g>
                      <path d="M20 42 Q20 38 24 38 L62 38 Q66 38 67.5 35 L70 30 Q71.5 27 75 27 L148 27 Q152 27 152 31 L152 116 Q152 120 148 120 L24 120 Q20 120 20 116 Z" fill={`url(#fgf-${f.id})`}/>
                      <path d="M20 42 Q20 38 24 38 L62 38 Q66 38 67.5 35 L70 30 Q71.5 27 75 27 L148 27 Q152 27 152 31" stroke="rgba(255,255,255,0.18)" stroke-width="1" fill="none"/>
                      <rect x="20" y="115" width="132" height="5" rx="2" fill="rgba(0,0,0,0.18)"/>
                    </svg>
                  </div>
                  <div class="t-name">{f.name}</div>
                  <div class="t-meta">{f.doc_count} {f.doc_count === 1 ? 'file' : 'files'}</div>
                </a>
              ))}

              {/* ADD FOLDER TILE */}
              <div id="co-folder-input-wrap">
                <div class="ico-wrap">
                  <svg class="co-folder-svg" viewBox="0 0 168 130" fill="none" preserveAspectRatio="xMidYMid meet">
                    <defs>
                      <linearGradient id="fgp-new" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0" stop-color="#F5F5F5"/>
                        <stop offset="1" stop-color="#D6D6D6"/>
                      </linearGradient>
                      <linearGradient id="fgf-new" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0" stop-color="#5C5E64"/>
                        <stop offset="0.45" stop-color="#3E4046"/>
                        <stop offset="1" stop-color="#2C2E33"/>
                      </linearGradient>
                    </defs>
                    <g>
                      <path d="M48 16 L106 16 L116 26 L116 84 Q116 88 112 88 L48 88 Q44 88 44 84 L44 20 Q44 16 48 16 Z" fill="url(#fgp-new)"/>
                      <path d="M106 16 L116 26 L106 26 Z" fill="#B8B8B8"/>
                    </g>
                    <path d="M20 42 Q20 38 24 38 L62 38 Q66 38 67.5 35 L70 30 Q71.5 27 75 27 L148 27 Q152 27 152 31 L152 116 Q152 120 148 120 L24 120 Q20 120 20 116 Z" fill="url(#fgf-new)"/>
                    <path d="M20 42 Q20 38 24 38 L62 38 Q66 38 67.5 35 L70 30 Q71.5 27 75 27 L148 27 Q152 27 152 31" stroke="rgba(255,255,255,0.18)" stroke-width="1" fill="none"/>
                    <rect x="20" y="115" width="132" height="5" rx="2" fill="rgba(0,0,0,0.18)"/>
                  </svg>
                </div>
                <input id="co-folder-name-inp" type="text" placeholder="Folder name" maxlength="200" autocomplete="off" />
              </div>

              <button id="co-add-folder-btn" type="button" class="co-tile-add">
                <div class="ico-wrap">
                  <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
                    <rect x="1" y="1" width="42" height="42" rx="9" stroke="var(--line)" stroke-width="1.5" stroke-dasharray="4 3"/>
                    <path d="M22 14v16M14 22h16" stroke="var(--ink-muted)" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                <div class="t-name">New folder</div>
              </button>
            </div>
          </>
        )}

        {/* ── DOCS SECTION ── */}
        {(unfiledDocs.length > 0 || (isInsideFolder && docs.length > 0)) && (
          <>
            <div class="co-section-title">
              <h3>{isInsideFolder ? heading : 'Docs'}</h3>
              <span class="co-count">
                {isInsideFolder ? docs.length : unfiledDocs.length}
                {' '}
                {(isInsideFolder ? docs.length : unfiledDocs.length) === 1 ? 'item' : 'items'}
              </span>
            </div>

            {/* UNFILE DROP ZONE — shown only when dragging inside a folder */}
            {isInsideFolder && (
              <div id="co-unfile-zone" class="co-unfile-zone">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                Drop here to move out of folder
              </div>
            )}

            {/* ICON GRID */}
            <div class="co-icon-grid">
              {(isInsideFolder ? docs : unfiledDocs).map((d) => {
                const ext = extClass(d.type);
                const label = extLabel(d.type);
                return (
                  <a href={`/app/content/${d.id}`} class="co-tile" draggable="true" data-doc-id={d.id}>
                    <div class="ico-wrap">
                      <div class={`co-fi ${ext}`}>
                        <div class="sheet">
                          <div class="lines">
                            <i></i><i></i><i></i><i></i><i></i>
                          </div>
                        </div>
                        <div class="ext-tag">{label}</div>
                      </div>
                    </div>
                    <div class="t-name">{d.title || 'Untitled'}</div>
                    <div class="t-meta">{relativeTime(d.updated_at)}</div>
                  </a>
                );
              })}
            </div>

            {/* LIST VIEW */}
            <div class="co-list">
              <div class="co-lr head">
                <span></span>
                <span>NAME</span>
                <span>TYPE</span>
                <span>UPDATED</span>
                <span>FOLDER</span>
              </div>
              {(isInsideFolder ? docs : docs).map((d) => {
                const unread = unreadByDoc.get(d.id) ?? 0;
                const ext = extClass(d.type);
                const label = extLabel(d.type);
                return (
                  <a href={`/app/content/${d.id}`} class="co-lr" draggable="true" data-doc-id={d.id}>
                    <div class="co-ic">
                      <div class={`co-file-ico ${ext}`}>
                        <div class="sheet"></div>
                        <div class="ext">{label}</div>
                      </div>
                    </div>
                    <span class="co-nm">
                      {unread > 0 && <span class="co-unread" title={`${unread} unread`}></span>}
                      <span class="co-name">{d.title || 'Untitled'}</span>
                    </span>
                    <span class="co-type">{d.type ?? 'doc'}</span>
                    <span class="co-dt">{relativeTime(d.updated_at)}</span>
                    <span onclick="event.preventDefault();event.stopPropagation();">
                      <select
                        class="co-move-sel"
                        data-doc-id={d.id}
                        data-current-folder={d.folder_id ?? ''}
                        title="Move to folder"
                      >
                        <option value="">— unfiled —</option>
                        {folders.map((f) => (
                          <option value={f.id} selected={f.id === d.folder_id}>{f.name}</option>
                        ))}
                      </select>
                    </span>
                  </a>
                );
              })}
            </div>
          </>
        )}

      </div>
    )}
  </div>

  <script define:vars={{ folderParam, isInsideFolder }}>
    const apiBase = 'http://localhost:8080';

    // --- Create doc ---
    async function createDoc() {
      const typeEl = document.getElementById('new-doc-type');
      const type = typeEl?.value ?? 'doc';
      const body = folderParam
        ? { title: 'Untitled', type, folder_id: folderParam }
        : { title: 'Untitled', type };
      const res = await fetch(`${apiBase}/api/docs`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) { alert('Failed to create doc'); return; }
      const { doc } = await res.json();
      window.location.href = `/app/content/${doc.id}`;
    }
    document.getElementById('new-doc-form')?.addEventListener('submit', (e) => {
      e.preventDefault(); void createDoc();
    });
    document.getElementById('new-doc-form-empty')?.addEventListener('submit', (e) => {
      e.preventDefault(); void createDoc();
    });

    // --- Create folder ---
    const addBtn = document.getElementById('co-add-folder-btn');
    const inputWrap = document.getElementById('co-folder-input-wrap');
    const nameInp = document.getElementById('co-folder-name-inp');

    addBtn?.addEventListener('click', () => {
      addBtn.style.display = 'none';
      inputWrap?.classList.add('visible');
      nameInp?.focus();
    });

    async function submitFolder() {
      const name = nameInp?.value?.trim();
      if (!name) { cancelFolder(); return; }
      const res = await fetch(`${apiBase}/api/folders`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (!res.ok) { alert('Failed to create folder'); return; }
      window.location.reload();
    }

    function cancelFolder() {
      if (inputWrap) inputWrap.classList.remove('visible');
      if (addBtn) addBtn.style.display = '';
      if (nameInp) nameInp.value = '';
    }

    nameInp?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); void submitFolder(); }
      if (e.key === 'Escape') cancelFolder();
    });
    nameInp?.addEventListener('blur', () => {
      setTimeout(() => {
        if (document.activeElement !== nameInp) {
          if (nameInp?.value?.trim()) { void submitFolder(); } else { cancelFolder(); }
        }
      }, 150);
    });

    // --- Move doc to folder (list view select) ---
    document.querySelectorAll('.co-move-sel').forEach((sel) => {
      sel.addEventListener('change', async (e) => {
        const target = e.target;
        const docId = target.dataset.docId;
        const folderId = target.value || null;
        if (!docId) return;
        await fetch(`${apiBase}/api/docs/${docId}/folder`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ folder_id: folderId }),
        });
        window.location.reload();
      });
    });

    // --- View toggle ---
    const coViewSeg = document.getElementById('co-view-seg');
    const coWrap = document.getElementById('co-wrap');
    coViewSeg?.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-view]');
      if (!btn || !coWrap) return;
      const v = btn.dataset.view;
      coWrap.classList.remove('view-icons', 'view-list');
      coWrap.classList.add('view-' + v);
      coViewSeg.querySelectorAll('button').forEach((b) => {
        const isActive = b.dataset.view === v;
        b.style.background = isActive ? 'var(--canvas)' : 'transparent';
        b.style.color = isActive ? 'var(--ink)' : 'var(--ink-muted)';
      });
    });

    // ── DRAG-AND-DROP ──────────────────────────────────────────────────────
    let draggingDocId = null;
    const unfileZone = document.getElementById('co-unfile-zone');

    async function moveDocToFolder(docId, folderId) {
      const res = await fetch(`${apiBase}/api/docs/${docId}/folder`, {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ folder_id: folderId }),
      });
      if (res.ok) window.location.reload();
    }

    // Make file tiles draggable
    document.querySelectorAll('.co-tile[data-doc-id], .co-lr[data-doc-id]').forEach((el) => {
      el.setAttribute('draggable', 'true');

      el.addEventListener('dragstart', (e) => {
        draggingDocId = el.dataset.docId;
        e.dataTransfer.setData('text/plain', draggingDocId);
        e.dataTransfer.effectAllowed = 'move';
        // Slight delay so the drag image captures before opacity change
        setTimeout(() => el.classList.add('co-dragging'), 0);
        // Show unfile zone when inside a folder
        if (unfileZone) unfileZone.classList.add('co-drag-active');
      });

      el.addEventListener('dragend', () => {
        el.classList.remove('co-dragging');
        draggingDocId = null;
        if (unfileZone) {
          unfileZone.classList.remove('co-drag-active');
          unfileZone.classList.remove('co-drag-over');
        }
      });

      // Prevent anchor navigation on drag
      el.addEventListener('click', (e) => {
        if (el.classList.contains('co-dragging')) e.preventDefault();
      });
    });

    // Folder tiles as drop targets
    document.querySelectorAll('.co-tile[data-folder-id]').forEach((folder) => {
      folder.addEventListener('dragover', (e) => {
        if (!draggingDocId) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        folder.classList.add('co-drag-over');
      });
      folder.addEventListener('dragleave', (e) => {
        if (!folder.contains(e.relatedTarget)) {
          folder.classList.remove('co-drag-over');
        }
      });
      folder.addEventListener('drop', (e) => {
        e.preventDefault();
        folder.classList.remove('co-drag-over');
        const docId = e.dataTransfer.getData('text/plain') || draggingDocId;
        const folderId = folder.dataset.folderId;
        if (docId && folderId) void moveDocToFolder(docId, folderId);
      });
    });

    // Unfile drop zone (inside folder view)
    if (unfileZone) {
      unfileZone.addEventListener('dragover', (e) => {
        if (!draggingDocId) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        unfileZone.classList.add('co-drag-over');
      });
      unfileZone.addEventListener('dragleave', () => {
        unfileZone.classList.remove('co-drag-over');
      });
      unfileZone.addEventListener('drop', (e) => {
        e.preventDefault();
        unfileZone.classList.remove('co-drag-over');
        const docId = e.dataTransfer.getData('text/plain') || draggingDocId;
        if (docId) void moveDocToFolder(docId, null);
      });
    }
  </script>
</AppLayout>
