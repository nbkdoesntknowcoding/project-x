---
import AppLayout from '../../../layouts/AppLayout.astro';
import { MonoLabel } from '../../../components/ui/typography';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';

// Read optional ?type= so the sidebar filter chips work without a separate route.
const typeParam = Astro.url.searchParams.get('type');
const VALID_TYPES = new Set(['doc', 'engineering', 'instruction', 'snippet']);
const activeType = typeParam && VALID_TYPES.has(typeParam) ? typeParam : null;

interface DocSummary {
  id: string;
  title: string;
  type: string;
  updated_at: string;
}

let docs: DocSummary[] = [];
const unreadByDoc = new Map<string, number>();

try {
  const docsQuery = activeType ? `?type=${activeType}` : '';
  const [docsRes, unreadRes] = await Promise.all([
    fetch(`${apiUrl}/api/docs${docsQuery}`, {
      headers: { Cookie: `boppl_jwt=${auth.jwt}` },
    }),
    fetch(`${apiUrl}/api/doc-read-state/unread-counts`, {
      headers: { Cookie: `boppl_jwt=${auth.jwt}` },
    }),
  ]);

  if (docsRes.ok) {
    const body = (await docsRes.json()) as { docs: DocSummary[] };
    docs = body.docs;
  }

  if (unreadRes.ok) {
    const body = (await unreadRes.json()) as {
      unread: Array<{ doc_id: string; unread_comment_count: number }>;
    };
    for (const row of body.unread ?? []) {
      unreadByDoc.set(row.doc_id, row.unread_comment_count);
    }
  }
} catch {
  // API offline — render empty state
}

// Heading copy reflects the active filter so the page never feels like
// "I'm in the wrong place" — Engineering tab says Engineering.
const TITLE_BY_TYPE: Record<string, string> = {
  engineering: 'Engineering docs',
  instruction: 'Instructions',
  snippet: 'Snippets',
};
const heading = activeType ? TITLE_BY_TYPE[activeType] : 'All docs';
const kicker = activeType
  ? `Filter · type=${activeType}`
  : 'Workspace content';

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString();
}
---

<AppLayout title="Content — Mnema" workspaceName="Workspace" email={auth.email}>
  <div class="px-8 pt-10 pb-16">
    <div class="max-w-[800px] mx-auto">
      <div class="mb-2">
        <MonoLabel>{kicker}</MonoLabel>
      </div>

      <div class="flex items-center justify-between mb-2">
        <h1 style="font-size: 28px; line-height: 1.3; letter-spacing: -0.01em; font-weight: 500; color: var(--text-primary);">
          {heading}
        </h1>
        <form id="new-doc-form">
          <select
            id="new-doc-type"
            class="mr-2 px-2 h-8 font-medium select-none"
            style="font-size: 13px; background: var(--surface-overlay); color: var(--text-primary); border: 1px solid var(--border-default); border-radius: var(--radius-md);"
          >
            <option value="doc">Doc</option>
            <option value="engineering">Engineering</option>
            <option value="instruction">Instruction</option>
            <option value="snippet">Snippet</option>
          </select>
          <button
            type="submit"
            class="inline-flex items-center justify-center h-8 px-3 font-medium transition-[background,border-color] rounded select-none"
            style="font-size: 13px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border: 1px solid var(--interactive-primary); border-radius: var(--radius-md);"
            onmouseover="this.style.background='var(--interactive-primary-hover)'"
            onmouseout="this.style.background='var(--interactive-primary)'"
          >
            New
          </button>
        </form>
      </div>

      <p style="font-size: 12px; color: var(--text-tertiary); margin-bottom: 32px;">
        {docs.length} {docs.length === 1 ? 'item' : 'items'}{activeType ? ` of type ${activeType}` : ' in your workspace'}
      </p>

      {docs.length === 0 ? (
        <div
          class="relative flex items-center justify-center px-6"
          style="height: 50vh; background: var(--surface-base);"
        >
          <div
            aria-hidden="true"
            style="position: absolute; inset: 0; pointer-events: none; z-index: 0; background-image: radial-gradient(circle at 50% 50%, var(--glow-color-soft), transparent 40%); opacity: 0.6;"
          />
          <div class="relative text-center max-w-md mx-auto" style="z-index: 2;">
            <span
              class="font-mono uppercase block mb-4"
              style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
            >
              Empty workspace
            </span>
            <h2
              class="font-sans font-medium"
              style="font-size: 32px; line-height: 1.1; letter-spacing: -0.02em; color: var(--text-primary); margin-bottom: 16px;"
            >
              Add your first content unit.
            </h2>
            <p
              class="mb-8"
              style="font-size: 14px; line-height: 1.6; color: var(--text-secondary);"
            >
              Docs become the building blocks of flows — sequenced context Claude reads in order.
              Start with one doc, add more, then compose them.
            </p>
            <form id="new-doc-form-empty">
              <button
                type="submit"
                class="inline-flex items-center justify-center h-10 px-5 font-medium transition-[background] rounded select-none"
                style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border-radius: var(--radius-md);"
              >
                Create document
              </button>
            </form>
          </div>
        </div>
      ) : (
        <ul style="border-top: 1px solid var(--border-subtle);">
          {docs.map((d) => {
            const unread = unreadByDoc.get(d.id) ?? 0;
            return (
              <li style="border-bottom: 1px solid var(--border-subtle);">
                <a
                  href={`/app/content/${d.id}`}
                  class="flex items-center h-14 px-3 transition-[background]"
                  style="color: var(--text-primary);"
                  onmouseover="this.style.background='var(--surface-overlay)'"
                  onmouseout="this.style.background='transparent'"
                >
                  <div class="flex items-center gap-2 flex-shrink-0">
                    {unread > 0 && (
                      <span
                        title={`${unread} unread comment${unread === 1 ? '' : 's'}`}
                        style="width: 6px; height: 6px; border-radius: 50%; background: var(--status-info); flex-shrink: 0;"
                      />
                    )}
                    <span style="font-size: 14px; font-weight: 500;">{d.title || 'Untitled'}</span>
                  </div>
                  <span
                    class="ml-3 font-mono uppercase"
                    style="font-size: 10px; letter-spacing: 0.08em; color: var(--text-tertiary); padding: 2px 6px; background: var(--surface-overlay); border-radius: var(--radius-sm);"
                  >
                    {d.type ?? 'doc'}
                  </span>
                  <span
                    class="flex-1 mx-4 truncate"
                    style="font-size: 13px; color: var(--text-tertiary);"
                  >
                    —
                  </span>
                  <span
                    class="flex-shrink-0"
                    style="font-size: 12px; color: var(--text-tertiary);"
                  >
                    {relativeTime(d.updated_at)}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </div>

  <script>
    async function createDoc() {
      const apiBase =
        (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
      const typeEl = document.getElementById('new-doc-type') as HTMLSelectElement | null;
      const type = typeEl?.value ?? 'doc';
      const res = await fetch(`${apiBase}/api/docs`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: 'Untitled', type }),
      });
      if (!res.ok) {
        alert('Failed to create doc');
        return;
      }
      const { doc } = (await res.json()) as { doc: { id: string } };
      window.location.href = `/app/content/${doc.id}`;
    }

    document.getElementById('new-doc-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      void createDoc();
    });
    document.getElementById('new-doc-form-empty')?.addEventListener('submit', (e) => {
      e.preventDefault();
      void createDoc();
    });
  </script>
</AppLayout>
