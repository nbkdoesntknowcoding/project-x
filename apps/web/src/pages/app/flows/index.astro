---
import AppLayout from '../../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';

interface FlowSummary {
  id: string;
  slug: string;
  name: string;
  description: string | null;
  is_published: boolean;
  has_unpublished_changes: boolean;
  step_count: number;
}

let flows: FlowSummary[] = [];
let loadError = false;
try {
  const res = await fetch(`${apiUrl}/api/flows`, {
    headers: { Cookie: `boppl_jwt=${auth.jwt}` },
  });
  if (res.ok) {
    const body = (await res.json()) as { flows: FlowSummary[] };
    flows = body.flows;
  } else {
    loadError = true;
  }
} catch {
  loadError = true;
}

const domainPart = auth.email.split('@')[1]?.split('.')[0] ?? '';
const workspaceName = domainPart
  ? domainPart.charAt(0).toUpperCase() + domainPart.slice(1)
  : 'Workspace';

function statusClass(flow: FlowSummary): string {
  if (flow.has_unpublished_changes) return 'draft-changes';
  if (flow.is_published) return 'published';
  return 'draft';
}
function statusLabel(flow: FlowSummary): string {
  if (flow.has_unpublished_changes) return 'Draft changes';
  if (flow.is_published) return 'Published';
  return 'Draft';
}
---

<style>
  .fl-main { overflow-y: auto; }
  .fl-wrap { max-width: 880px; margin: 0 auto; padding: 48px 32px 80px; }

  .fl-pre {
    font: 500 11px/1 var(--mono);
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-muted); margin-bottom: 14px;
  }
  .fl-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 24px; margin-bottom: 36px;
  }
  .fl-head h1 {
    margin: 0; font: 500 28px/1.2 var(--sans);
    letter-spacing: -0.02em; color: var(--ink);
  }
  .fl-head .fl-sub {
    margin: 12px 0 0; font-size: 15px; line-height: 1.6;
    color: var(--ink-soft); max-width: 36rem;
  }
  .fl-new-btn {
    flex-shrink: 0; margin-top: 6px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 12px; border-radius: 6px; cursor: pointer;
    background: var(--ink); color: var(--on-ink);
    border: 1px solid transparent;
    font: 500 12.5px/1 var(--sans);
  }
  .fl-new-btn:hover { opacity: 0.88; }

  /* FLOW CARDS */
  .fl-list { display: flex; flex-direction: column; gap: 8px; }
  .fl-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    cursor: pointer; text-decoration: none; color: inherit;
    transition: background 160ms ease, border-color 160ms ease;
  }
  .fl-card:hover { background: var(--surface-2); border-color: var(--line-strong); }
  .fl-card:hover .fl-arrow { opacity: 1; transform: translateX(2px); }
  .fl-card:hover .fl-walk { opacity: 1; }
  .fl-card .fl-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .fl-card .fl-name { font: 500 14px/1.3 var(--sans); color: var(--ink); }
  .fl-card .fl-desc {
    font: 400 13px/1.4 var(--sans); color: var(--ink-muted);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .fl-card .fl-right {
    display: flex; align-items: center; gap: 10px; flex-shrink: 0;
  }
  .fl-steps {
    font: 500 11px/1 var(--mono); color: var(--ink-muted); letter-spacing: 0.02em;
  }

  /* STATUS PILLS */
  .fl-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 8px 3px 7px; border-radius: 999px;
    font: 500 10.5px/1 var(--sans); letter-spacing: 0.02em;
  }
  .fl-pill .dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
  .fl-pill.published { background: rgba(107,227,155,0.10); border: 1px solid rgba(107,227,155,0.28); color: var(--status-sync); }
  .fl-pill.draft-changes { background: rgba(255,179,112,0.10); border: 1px solid rgba(255,179,112,0.28); color: var(--status-edit); }
  .fl-pill.draft { background: var(--surface-3); border: 1px solid var(--line); color: var(--ink-muted); }
  .fl-pill.draft .dot { background: var(--ink-faint); }

  .fl-walk {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 5px 9px; border-radius: 5px;
    background: transparent; border: 0;
    color: var(--ink-soft); cursor: pointer;
    font: 500 12px/1 var(--sans); opacity: 0;
    transition: opacity 160ms ease;
  }
  .fl-walk:hover { background: var(--surface-3); color: var(--ink); }
  .fl-arrow {
    color: var(--ink-muted); opacity: 0; flex-shrink: 0;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  /* EMPTY STATE */
  .fl-empty {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 48px 32px;
    background: var(--surface); border: 1px solid var(--line); border-radius: 10px;
  }
  .fl-empty-ico {
    width: 48px; height: 48px;
    background: var(--surface-2); border: 1px solid var(--line); border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--ink-soft); margin-bottom: 18px;
  }
  .fl-empty h3 { margin: 0 0 8px; font: 500 16px/1.3 var(--sans); letter-spacing: -0.01em; color: var(--ink); }
  .fl-empty p { margin: 0 auto 18px; font-size: 13px; color: var(--ink-soft); line-height: 1.55; max-width: 28rem; }
  .fl-coming {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 5px 11px 5px 9px; border-radius: 999px;
    background: var(--surface-2); border: 1px solid var(--line);
    font: 500 10.5px/1 var(--mono); letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-soft);
  }
  .fl-coming .sig {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--status-info);
    box-shadow: 0 0 6px rgba(124,156,255,0.6);
    animation: fl-sigpulse 2.4s ease-in-out infinite;
  }
  @keyframes fl-sigpulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(124,156,255,0.6); }
    50% { box-shadow: 0 0 0 5px rgba(124,156,255,0); }
  }

  /* HOW FLOWS WILL WORK */
  .fl-how { margin-top: 48px; }
  .fl-how-label {
    font: 500 11px/1 var(--mono); letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ink-muted); margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .fl-how-label::after { content: ""; flex: 1; height: 1px; background: var(--line); }
  .fl-how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .fl-how-block {
    padding: 16px; background: var(--surface);
    border: 1px solid var(--line); border-radius: 8px;
  }
  .fl-hb-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 6px;
    background: var(--surface-2); border: 1px solid var(--line);
    color: var(--ink-soft); margin-bottom: 12px;
  }
  .fl-how-block h4 { margin: 0 0 6px; font: 500 14px/1.3 var(--sans); letter-spacing: -0.005em; color: var(--ink); }
  .fl-how-block p { margin: 0; font: 400 13px/1.55 var(--sans); color: var(--ink-soft); }

  /* ERROR BANNER */
  .fl-error {
    margin-top: 16px; padding: 10px 14px;
    background: rgba(255,122,138,0.08); border: 1px solid rgba(255,122,138,0.28);
    border-radius: 6px; font-size: 13px; color: var(--status-warn);
  }
</style>

<AppLayout title="Flows — Mnema" workspaceName={workspaceName} email={auth.email}>

  <!-- STATUS LEFT -->
  <Fragment slot="status-left">
    <span style="font:500 11px/1 var(--mono);color:var(--ink-muted);">
      {flows.length} {flows.length === 1 ? 'flow' : 'flows'}
    </span>
  </Fragment>

  <!-- MAIN CONTENT -->
  <div class="fl-main">
    <div class="fl-wrap">

      <div class="fl-pre">Flows</div>
      <div class="fl-head">
        <div>
          <h1>Compose context for your AI agents.</h1>
          <p class="fl-sub">
            A flow is a sequence of content units — docs, instructions, snippets — that an AI agent
            reads in order. Each step has an instruction. Claude pulls them one at a time, reasoning
            through your context in the order you specified, not all at once.
          </p>
        </div>
        <button class="fl-new-btn" id="fl-new-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          New flow
        </button>
      </div>

      {flows.length > 0 ? (
        <div class="fl-list">
          {flows.map((flow) => (
            <a href={`/app/flows/${flow.slug}`} class="fl-card">
              <div class="fl-meta">
                <span class="fl-name">{flow.name}</span>
                {flow.description && (
                  <span class="fl-desc">{flow.description}</span>
                )}
              </div>
              <div class="fl-right">
                <span class="fl-steps">{flow.step_count} {flow.step_count === 1 ? 'step' : 'steps'}</span>
                <span class={`fl-pill ${statusClass(flow)}`}>
                  <span class="dot"></span>{statusLabel(flow)}
                </span>
                <button class="fl-walk" onclick="event.preventDefault()">
                  Walk
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </button>
                <svg class="fl-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <>
          <div class="fl-empty">
            <div class="fl-empty-ico">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="6" height="6" rx="1"/>
                <rect x="15" y="3" width="6" height="6" rx="1"/>
                <rect x="3" y="15" width="6" height="6" rx="1"/>
                <rect x="15" y="15" width="6" height="6" rx="1"/>
                <path d="M9 6h4a2 2 0 0 1 2 2v10"/>
                <path d="M15 18h-6"/>
              </svg>
            </div>
            <h3>No flows yet</h3>
            <p>Flows let you control exactly how Claude reads your workspace. Build one by sequencing docs and adding instructions for each step.</p>
            <span class="fl-coming"><span class="sig"></span>Flow editor — coming in next release</span>
          </div>

          <div class="fl-how">
            <div class="fl-how-label">How flows will work</div>
            <div class="fl-how-grid">
              <div class="fl-how-block">
                <span class="fl-hb-num">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="3" width="6" height="6" rx="1"/><rect x="3" y="15" width="6" height="6" rx="1"/><path d="M9 6h4a2 2 0 0 1 2 2v10M9 18h6"/></svg>
                </span>
                <h4>Sequence content</h4>
                <p>Drag docs, snippets, and instructions into the order you want Claude to read them.</p>
              </div>
              <div class="fl-how-block">
                <span class="fl-hb-num">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 14h6M9 18h4"/></svg>
                </span>
                <h4>Annotate each step</h4>
                <p>Add an instruction per step — what the agent should look for, extract, or hold onto.</p>
              </div>
              <div class="fl-how-block">
                <span class="fl-hb-num">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 12 12 19 19 12"/><line x1="12" y1="5" x2="12" y2="19"/></svg>
                </span>
                <h4>Claude reads in order</h4>
                <p>Through MCP, Claude pulls each step sequentially and reasons through your context.</p>
              </div>
            </div>
          </div>
        </>
      )}

      {loadError && (
        <div class="fl-error">
          Couldn't load flows from the API. The list above may be empty even if you have flows.
        </div>
      )}

    </div>
  </div>

  <script>
    async function createFlow() {
      const res = await fetch(`/api/flows`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: 'Untitled flow' }),
      });
      if (!res.ok) { alert('Failed to create flow'); return; }
      const { flow } = await res.json();
      window.location.href = `/app/flows/${flow.slug}`;
    }
    document.getElementById('fl-new-btn')?.addEventListener('click', () => void createFlow());
  </script>

</AppLayout>
