---
import AppLayout from '../../../layouts/AppLayout.astro';
import { AdminLogs } from '../../../components/admin/AdminLogs';
import { isAdminEmail } from '../../../lib/admin';

const auth = Astro.locals.auth;
if (!auth) return Astro.redirect('/auth/login');
if (!isAdminEmail(auth.email)) return Astro.redirect('/app');
---

<AppLayout title="Admin · Live logs">
  <div style="padding:28px 32px;">
    <h1 style="margin:0 0 6px;font:500 22px/1.15 var(--sans);letter-spacing:-0.02em;color:var(--ink);">Live logs</h1>
    <p style="margin:0 0 24px;font-size:13px;color:var(--ink-soft);max-width:42rem;">
      Real-time container logs from the VPS. Secrets are redacted; every view is recorded in the audit log.
    </p>
    <AdminLogs client:load />
  </div>
</AppLayout>
