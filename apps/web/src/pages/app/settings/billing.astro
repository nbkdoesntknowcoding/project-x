---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
---

<SettingsLayout title="Billing">
  <h1
    class="text-xl font-medium mb-1"
    style="color: var(--text-primary);"
  >
    Billing
  </h1>
  <p
    class="text-sm mb-8"
    style="color: var(--text-secondary);"
  >
    Your subscription, invoices, and payment method.
  </p>

  <div
    class="rounded-lg p-8 text-center"
    style="background: var(--surface-overlay); border: 1px solid var(--border-default);"
  >
    <div
      class="inline-block px-2 py-0.5 rounded text-xs font-medium mb-3"
      style="background: var(--surface-selected); color: var(--text-accent);"
    >
      Coming in Phase 4.4
    </div>
    <h2
      class="text-base font-medium mb-2"
      style="color: var(--text-primary);"
    >
      Billing isn't wired up yet
    </h2>
    <p
      class="text-sm max-w-md mx-auto"
      style="color: var(--text-secondary);"
    >
      You're on the free plan during the closed beta. Subscription
      management and invoicing land alongside Stripe scaffolding in
      Phase 4.4.
    </p>
  </div>
</SettingsLayout>
