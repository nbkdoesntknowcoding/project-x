---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
import { WorkspaceSettings } from '../../../components/settings/WorkspaceSettings';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const apiUrl =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
const meRes = await fetch(`${apiUrl}/api/auth/me`, {
  headers: { Cookie: `boppl_jwt=${auth.jwt}` },
});
let role: 'owner' | 'editor' | 'viewer' = 'viewer';
if (meRes.ok) {
  const body = (await meRes.json()) as { role?: string };
  if (body.role === 'owner' || body.role === 'editor' || body.role === 'viewer') {
    role = body.role;
  }
}
---

<SettingsLayout title="Workspace">
  <p style="font:500 11px/1 var(--mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-muted);margin:0 0 12px;">Settings</p>
  <h1 style="margin:0;font:500 28px/1.15 var(--sans);letter-spacing:-0.02em;color:var(--ink);">Workspace</h1>
  <p style="margin:6px 0 36px;font-size:14px;color:var(--ink-soft);max-width:36rem;">
    {
      role === 'owner'
        ? 'Rename this workspace or change its URL slug. Only owners can edit.'
        : 'Only workspace owners can change these settings.'
    }
  </p>

  <WorkspaceSettings client:load currentUserRole={role} />
</SettingsLayout>
