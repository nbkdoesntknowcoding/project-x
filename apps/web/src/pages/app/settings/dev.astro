---
import SettingsLayout from '../../../layouts/SettingsLayout.astro';
import { DevSettings } from '../../../components/settings/DevSettings';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const apiUrl =
  (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
const meRes = await fetch(`${apiUrl}/api/auth/me`, {
  headers: { Cookie: `boppl_jwt=${auth.jwt}` },
});
let role: 'owner' | 'editor' | 'viewer' = 'viewer';
if (meRes.ok) {
  const body = (await meRes.json()) as { role?: string };
  if (body.role === 'owner' || body.role === 'editor' || body.role === 'viewer') {
    role = body.role;
  }
}
---

<SettingsLayout title="Dev / AgentLens">
  <span
    class="block mb-2 font-mono uppercase"
    style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
  >
    Settings
  </span>
  <h1
    style="font-size: 28px; line-height: 1.3; letter-spacing: -0.01em; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;"
  >
    Dev / AgentLens
  </h1>
  <p
    style="font-size: 16px; color: var(--text-secondary); margin-bottom: 40px;"
  >
    Hook token, install command, and MCP configuration for AgentLens integration.
  </p>

  <DevSettings
    client:load
    workspaceId={auth.tenant_id}
    isOwner={role === 'owner'}
  />
</SettingsLayout>
