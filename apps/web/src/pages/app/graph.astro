---
import AppLayout from '../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) return Astro.redirect('/auth/login');

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';

// Prefetch initial graph data server-side
let initialData: { nodes: unknown[]; edges: unknown[]; communities: unknown[]; report: unknown } | null = null;
try {
  const res = await fetch(`${apiUrl}/api/graph/full`, {
    headers: { Cookie: `boppl_jwt=${auth.jwt}` },
  });
  if (res.ok) initialData = await res.json() as typeof initialData;
} catch { /* offline */ }
---

<AppLayout title="Knowledge Graph — Mnema">
  <style>
    #graph-shell {
      display: grid;
      grid-template-columns: 260px 1fr;
      height: calc(100vh - var(--topbar-h, 40px));
      overflow: hidden;
    }
    #graph-sidebar {
      background: var(--surface);
      border-right: 1px solid var(--line);
      overflow-y: auto;
      padding: 14px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    #graph-sidebar h2 { font: 600 11px/1 var(--mono); letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 8px; }
    .filter-group { display: flex; flex-direction: column; gap: 4px; }
    .filter-label { display: flex; align-items: center; gap: 7px; font: 400 12.5px/1 var(--sans); cursor: pointer; padding: 3px 0; }
    .filter-label input { accent-color: var(--accent); }
    .comm-item { padding: 7px 10px; border-radius: 6px; background: var(--surface-2); margin-bottom: 4px; cursor: pointer; }
    .comm-item:hover { background: var(--surface-3, var(--surface-2)); }
    .comm-name { font: 500 12.5px/1 var(--sans); margin-bottom: 3px; }
    .comm-qs { font: 400 11px/1.5 var(--sans); color: var(--ink-muted); }
    #build-btn {
      height: 32px; border-radius: 7px; background: var(--accent); border: 0;
      color: #fff; font: 600 12px/1 var(--sans); cursor: pointer; width: 100%;
    }
    #build-btn:hover { opacity: 0.88; }
    #build-status { font: 400 11px/1 var(--mono); color: var(--ink-muted); text-align: center; min-height: 16px; }
    .graph-search { width: 100%; height: 30px; background: var(--surface-2); border: 1px solid var(--line); border-radius: 6px; padding: 0 10px; color: var(--ink); font: 400 12.5px/1 var(--sans); outline: none; }
    .graph-search::placeholder { color: var(--ink-muted); }
    #graph-canvas { position: relative; width: 100%; height: 100%; background: var(--canvas); }
    #graph-canvas svg { position: absolute; inset: 0; width: 100%; height: 100%; }
    #graph-loading { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--ink-muted); font: 400 13px/1 var(--sans); }
    #graph-detail {
      position: absolute; top: 0; right: 0; width: 240px; height: 100%;
      background: var(--surface); border-left: 1px solid var(--line);
      padding: 14px; overflow-y: auto; transform: translateX(100%);
      transition: transform 200ms ease; z-index: 10;
    }
    #graph-detail.open { transform: translateX(0); }
    #detail-label { font: 600 14px/1.3 var(--sans); margin-bottom: 6px; }
    .detail-badge { font: 500 10px/1 var(--mono); padding: 2px 6px; border-radius: 3px; background: var(--surface-2); margin-right: 4px; letter-spacing: 0.04em; text-transform: uppercase; }
    .god-badge { background: rgba(251,191,36,0.15); color: #fbbf24; }
    #detail-stats { font: 400 11.5px/1.6 var(--mono); color: var(--ink-muted); margin: 8px 0; }
    #detail-summary { font: 400 12px/1.55 var(--sans); color: var(--ink-muted); }
  </style>

  <div id="graph-shell">
    <!-- Sidebar -->
    <aside id="graph-sidebar">
      <div>
        <h2>Build Graph</h2>
        <button id="build-btn">Build Knowledge Graph</button>
        <div id="build-status"></div>
      </div>

      <div>
        <h2>Search</h2>
        <input type="search" class="graph-search" id="node-search" placeholder="Search nodes…" />
      </div>

      <div class="filter-group">
        <h2>Entity types</h2>
        {['doc','flow','flow_step','task','concept','decision','project','rationale'].map(t => (
          <label class="filter-label">
            <input type="checkbox" data-type={t} checked /> {t}
          </label>
        ))}
        <label class="filter-label" style="margin-top:4px">
          <input type="checkbox" id="god-nodes-only" /> God-nodes only
        </label>
      </div>

      <div id="community-list">
        <h2>Communities</h2>
        <div id="communities-inner"><span style="font:400 11px/1 var(--mono);color:var(--ink-muted)">Build graph to see communities.</span></div>
      </div>
    </aside>

    <!-- Canvas -->
    <div id="graph-canvas">
      <div id="graph-loading">Loading graph…</div>
      <svg id="graph-svg">
        <defs>
          <marker id="arr" markerWidth="6" markerHeight="4" refX="6" refY="2" orient="auto">
            <polygon points="0 0,6 2,0 4" fill="rgba(255,255,255,0.15)"/>
          </marker>
        </defs>
        <g id="zc">
          <g id="el"></g>
          <g id="nl"></g>
        </g>
      </svg>
      <div id="graph-detail">
        <div id="detail-label"></div>
        <div id="detail-badges"></div>
        <div id="detail-stats"></div>
        <div id="detail-summary"></div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js" is:inline></script>
  <script define:vars={{ initialData }}>
    var NODE_COLORS = {
      doc:'#60a5fa',flow:'#fbbf24',flow_step:'#fbbf24',task:'#4ade80',
      session:'#52525b',concept:'#a78bfa',decision:'#f0997b',project:'#e879f9',rationale:'#f0997b'
    };

    var currentData = initialData;
    var hiddenTypes = new Set();
    var godOnly = false;
    var simRef = null;

    function radius(d){ return 6 + Math.min((d.degree||0)*0.5,12); }

    function render(data){
      if (!data || !window.d3) return;
      var nodes = (data.nodes||[]).map(function(n){ return Object.assign({},n); });
      var edges = data.edges||[];
      document.getElementById('graph-loading').style.display='none';

      var svg = d3.select('#graph-svg');
      var W = svg.node().clientWidth, H = svg.node().clientHeight;
      var zc = d3.select('#zc'), el = d3.select('#el'), nl = d3.select('#nl');
      el.selectAll('*').remove(); nl.selectAll('*').remove();

      var zoom = d3.zoom().scaleExtent([0.05,10]).on('zoom',function(e){ zc.attr('transform',e.transform); });
      svg.call(zoom);
      svg.on('click',function(e){ if(e.target===svg.node()||e.target.tagName==='svg') closeDetail(); });

      var linkData = edges.map(function(e){ return {source:e.fromNodeId||e.from_node_id,target:e.toNodeId||e.to_node_id,d:e}; });
      var sim = d3.forceSimulation(nodes)
        .force('link',d3.forceLink(linkData).id(function(d){ return d.id; }).distance(function(l){ return l.d.edgeType==='part_of'?60:120; }))
        .force('charge',d3.forceManyBody().strength(function(d){ return -80-(d.degree||0)*3; }))
        .force('center',d3.forceCenter(W/2,H/2))
        .force('collide',d3.forceCollide().radius(function(d){ return radius(d)+4; }));
      simRef = sim;

      var edgeSel = el.selectAll('line').data(linkData).enter().append('line')
        .attr('stroke',function(d){ return d.d.provenance==='INFERRED'?'rgba(255,255,255,0.1)':'rgba(255,255,255,0.18)'; })
        .attr('stroke-width',1).attr('opacity',0.7)
        .attr('stroke-dasharray',function(d){ return d.d.provenance==='INFERRED'?'5,3':null; })
        .attr('marker-end','url(#arr)');

      var godRings = nl.selectAll('circle.gr').data(nodes.filter(function(n){ return n.isGodNode; }))
        .enter().append('circle').attr('class','gr').attr('r',function(d){ return radius(d)+6; })
        .attr('fill','none').attr('stroke','#fbbf24').attr('stroke-width',1.5).attr('opacity',0.5);

      function pulseRings(){
        godRings.transition().duration(1200).attr('opacity',0.1).attr('r',function(d){ return radius(d)+14; })
          .transition().duration(1200).attr('opacity',0.6).attr('r',function(d){ return radius(d)+6; })
          .on('end',pulseRings);
      }
      if(godRings.size()>0) pulseRings();

      var nodeSel = nl.selectAll('circle.nd').data(nodes).enter().append('circle').attr('class','nd')
        .attr('r',radius).attr('fill',function(d){ return NODE_COLORS[d.entityType]||'#6b7280'; })
        .attr('stroke',function(d){ return d.isGodNode?'#fbbf24':'rgba(255,255,255,0.12)'; })
        .attr('stroke-width',function(d){ return d.isGodNode?2:1; }).attr('opacity',0.9)
        .style('cursor','pointer').on('click',function(e,d){ e.stopPropagation(); openDetail(d); });

      nodeSel.call(d3.drag()
        .on('start',function(e,d){ if(!e.active) sim.alphaTarget(0.3).restart(); d.fx=d.x; d.fy=d.y; })
        .on('drag',function(e,d){ d.fx=e.x; d.fy=e.y; })
        .on('end',function(e,d){ if(!e.active) sim.alphaTarget(0); d.fx=null; d.fy=null; }));

      var labelSel = nl.selectAll('text.nl').data(nodes.filter(function(n){ return (n.degree||0)>=3||n.isGodNode; }))
        .enter().append('text').attr('class','nl')
        .text(function(d){ return d.label&&d.label.length>16?d.label.slice(0,14)+'…':d.label||''; })
        .attr('font-size','9px').attr('fill','rgba(240,238,233,0.55)').attr('text-anchor','middle')
        .attr('dy',function(d){ return -(radius(d)+4); }).style('pointer-events','none');

      sim.on('tick',function(){
        edgeSel.attr('x1',function(d){ return d.source.x; }).attr('y1',function(d){ return d.source.y; })
               .attr('x2',function(d){ return d.target.x; }).attr('y2',function(d){ return d.target.y; });
        nodeSel.attr('cx',function(d){ return d.x; }).attr('cy',function(d){ return d.y; });
        godRings.attr('cx',function(d){ return d.x; }).attr('cy',function(d){ return d.y; });
        labelSel.attr('x',function(d){ return d.x; }).attr('y',function(d){ return d.y; });
      });

      setTimeout(function(){
        var b = nl.node().getBBox();
        if(b&&b.width>0){
          var pad=40,s=Math.min((W-pad*2)/b.width,(H-pad*2)/b.height,2);
          var tx=W/2-s*(b.x+b.width/2), ty=H/2-s*(b.y+b.height/2);
          svg.transition().duration(600).call(zoom.transform,d3.zoomIdentity.translate(tx,ty).scale(s));
        }
      },2500);

      // Communities sidebar
      var comms = data.communities||[];
      var ci = document.getElementById('communities-inner');
      if(comms.length){
        ci.innerHTML = comms.map(function(c){
          var qs=(c.suggestedQuestions||[]).slice(0,2).map(function(q){ return '<div>• '+q+'</div>'; }).join('');
          return '<div class="comm-item" data-comm="'+c.id+'">'+'<div class="comm-name">'+c.label+'</div>'+(qs?'<div class="comm-qs">'+qs+'</div>':'')+'</div>';
        }).join('');
      }

      // Apply filters
      function applyFilters(){
        nodeSel.attr('display',function(d){
          if(hiddenTypes.has(d.entityType)) return 'none';
          if(godOnly&&!d.isGodNode) return 'none';
          return null;
        });
        godRings.attr('display',function(d){ return (hiddenTypes.has(d.entityType)||godOnly)?null:null; });
      }
      applyFilters();

      // Type filter checkboxes
      document.querySelectorAll('[data-type]').forEach(function(cb){
        cb.addEventListener('change',function(){
          var t=cb.dataset.type;
          if(cb.checked) hiddenTypes.delete(t); else hiddenTypes.add(t);
          applyFilters();
        });
      });

      document.getElementById('god-nodes-only').addEventListener('change',function(){
        godOnly=this.checked; applyFilters();
      });

      // Node search
      document.getElementById('node-search').addEventListener('input',function(){
        var q=this.value.toLowerCase().trim();
        if(!q){ nodeSel.attr('opacity',0.9); return; }
        nodeSel.attr('opacity',function(d){ return (d.label||'').toLowerCase().includes(q)?1:0.1; });
        // Centre on first match
        var match=nodes.find(function(n){ return (n.label||'').toLowerCase().includes(q)&&n.x; });
        if(match){
          var s=1.5;
          svg.transition().duration(400).call(zoom.transform,d3.zoomIdentity.translate(W/2-s*match.x,H/2-s*match.y).scale(s));
        }
      });
    }

    function openDetail(d){
      document.getElementById('detail-label').textContent=d.label;
      var b=document.getElementById('detail-badges');
      b.innerHTML='<span class="detail-badge">'+d.entityType+'</span>';
      if(d.isGodNode) b.innerHTML+='<span class="detail-badge god-badge">★ god node</span>';
      document.getElementById('detail-stats').textContent=
        'Degree: '+(d.degree||0)+'  Betweenness: '+(((d.betweennessCentrality||0)*100).toFixed(1))+'%'+(d.communityLabel?'  Community: '+d.communityLabel:'');
      document.getElementById('detail-summary').textContent=d.summary||'';
      document.getElementById('graph-detail').classList.add('open');
    }
    function closeDetail(){ document.getElementById('graph-detail').classList.remove('open'); }
    document.addEventListener('keydown',function(e){ if(e.key==='Escape') closeDetail(); });

    // Build button
    document.getElementById('build-btn').addEventListener('click',function(){
      var status=document.getElementById('build-status');
      status.textContent='Queuing build…';
      fetch('/api/graph/build',{method:'POST',credentials:'include'})
        .then(function(r){ return r.json(); })
        .then(function(){ status.textContent='Build queued. Check back in ~2 minutes.'; })
        .catch(function(){ status.textContent='Failed to queue build.'; });
    });

    // SSE: re-fetch on graph_updated
    var evtSource = new EventSource('/api/notifications/stream',{withCredentials:true});
    evtSource.addEventListener('graph_updated',function(){
      fetch('/api/graph/full',{credentials:'include'}).then(function(r){ return r.ok?r.json():null; })
        .then(function(d){ if(d){ currentData=d; render(d); } });
    });

    // Initial render
    if(currentData) render(currentData);
    else document.getElementById('graph-loading').textContent='No graph data yet. Click "Build Knowledge Graph" to start.';
  </script>
</AppLayout>
