---
import AppLayout from '../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) return Astro.redirect('/auth/login');

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';

let initialData: { nodes: unknown[]; edges: unknown[]; communities: unknown[]; report: unknown } | null = null;
try {
  const res = await fetch(`${apiUrl}/api/graph/full`, {
    headers: { Cookie: `boppl_jwt=${auth.jwt}` },
  });
  if (res.ok) initialData = await res.json() as typeof initialData;
} catch { /* offline */ }
---

<AppLayout title="Knowledge Graph — Mnema">
  <style>
    #graph-shell {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: var(--canvas);
    }

    /* ── Canvas ── */
    #graph-canvas { position: absolute; inset: 0; }
    #graph-canvas svg { position: absolute; inset: 0; width: 100%; height: 100%; }
    #graph-loading {
      position: absolute; inset: 0; display: flex;
      align-items: center; justify-content: center;
      color: var(--ink-muted); font: 400 13px/1 var(--sans); pointer-events: none;
    }

    /* ── Shared glass surface ── */
    .glass {
      background: rgba(13,14,18,0.78);
      backdrop-filter: blur(16px) saturate(160%);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
    }

    /* ── Top search bar ── */
    #search-bar {
      position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
      z-index: 30; width: min(440px, calc(100vw - 200px));
      display: flex; align-items: center; gap: 0;
    }
    #search-icon {
      position: absolute; left: 12px; color: var(--ink-muted);
      font-size: 13px; pointer-events: none; z-index: 1;
    }
    #node-search {
      width: 100%; height: 36px; background: transparent;
      border: none; outline: none;
      padding: 0 36px 0 34px;
      color: var(--ink); font: 400 13px/1 var(--sans);
      border-radius: 10px;
    }
    #node-search::placeholder { color: var(--ink-muted); }
    #search-clear {
      position: absolute; right: 10px; color: var(--ink-muted);
      background: none; border: none; cursor: pointer;
      font-size: 12px; padding: 4px; display: none; z-index: 1;
    }
    #search-clear.visible { display: block; }

    /* Search results dropdown */
    #search-dropdown {
      position: absolute; top: calc(100% + 4px); left: 0; right: 0;
      background: rgba(13,14,18,0.96); backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.07); border-radius: 10px;
      overflow: hidden; max-height: 280px; overflow-y: auto;
      display: none; z-index: 50;
    }
    #search-dropdown.visible { display: block; }
    .s-hit {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 14px; cursor: pointer; transition: background 80ms;
    }
    .s-hit:hover { background: rgba(255,255,255,0.05); }
    .s-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .s-label { font: 400 12.5px/1.3 var(--sans); color: var(--ink); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .s-meta { font: 400 10px/1 var(--mono); color: var(--ink-muted); flex-shrink: 0; }
    .s-comm { font: 400 10.5px/1 var(--sans); color: var(--ink-muted); flex-shrink: 0; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #search-empty-msg { padding: 16px 14px; font: 400 12px/1 var(--mono); color: var(--ink-muted); }

    /* ── Top-left: stats + build ── */
    #top-left {
      position: absolute; top: 12px; left: 12px; z-index: 30;
      display: flex; gap: 6px; align-items: center;
    }
    #graph-stats {
      padding: 6px 12px; display: flex; gap: 10px; align-items: center;
    }
    .stat { font: 500 11px/1 var(--mono); color: var(--ink-muted); }
    .stat b { color: var(--ink-soft); font-weight: 600; }
    #build-btn {
      height: 34px; padding: 0 14px; border-radius: 10px;
      background: var(--accent); border: 0; color: #000;
      font: 600 11.5px/1 var(--sans); cursor: pointer; white-space: nowrap;
    }
    #build-btn:hover { opacity: 0.85; }

    /* ── Top-right: zoom controls ── */
    #zoom-controls {
      position: absolute; top: 12px; right: 12px; z-index: 30;
      display: flex; flex-direction: column; gap: 1px; overflow: hidden;
      border-radius: 10px; border: 1px solid rgba(255,255,255,0.07);
    }
    .zoom-btn {
      width: 32px; height: 32px; background: rgba(13,14,18,0.78);
      backdrop-filter: blur(16px); border: none;
      color: var(--ink-muted); font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 100ms, color 100ms;
    }
    .zoom-btn:hover { background: rgba(255,255,255,0.08); color: var(--ink); }

    /* ── Bottom filter bar ── */
    #filter-bar {
      position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
      z-index: 30; display: flex; gap: 6px; align-items: center;
      padding: 5px 8px; flex-wrap: nowrap;
    }
    .f-label {
      font: 500 10px/1 var(--mono); letter-spacing: 0.05em;
      text-transform: uppercase; color: var(--ink-muted); padding: 0 4px;
    }
    .f-chip {
      display: flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 999px;
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
      font: 500 11px/1 var(--mono); color: var(--ink-soft);
      cursor: pointer; transition: background 120ms, border-color 120ms, color 120ms;
      white-space: nowrap; user-select: none;
    }
    .f-chip:hover { background: rgba(255,255,255,0.09); }
    .f-chip.active { background: rgba(255,179,112,0.12); border-color: rgba(255,179,112,0.3); color: var(--accent); }
    .f-chip-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .f-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.08); flex-shrink: 0; }

    /* ── Node detail panel ── */
    #graph-detail {
      position: absolute; top: 0; right: 0; width: 260px; height: 100%;
      background: var(--surface); border-left: 1px solid var(--line);
      padding: 18px 16px; overflow-y: auto;
      transform: translateX(100%); transition: transform 220ms cubic-bezier(0.4,0,0.2,1);
      z-index: 40;
    }
    #graph-detail.open { transform: translateX(0); }
    #detail-close {
      position: absolute; top: 12px; right: 12px; width: 22px; height: 22px;
      border-radius: 50%; border: 1px solid var(--line); background: var(--surface-2);
      color: var(--ink-muted); font-size: 12px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    #detail-close:hover { color: var(--ink); }
    #detail-label { font: 600 13.5px/1.4 var(--sans); margin-bottom: 8px; padding-right: 28px; }
    .d-badge {
      display: inline-block; font: 500 9.5px/1 var(--mono); padding: 2px 6px;
      border-radius: 3px; background: var(--surface-2); margin-right: 4px;
      letter-spacing: 0.04em; text-transform: uppercase;
    }
    .d-god { background: rgba(251,191,36,0.15); color: #fbbf24; }
    #detail-community { font: 400 11px/1 var(--sans); color: var(--ink-muted); margin: 8px 0 4px; }
    #detail-stats { font: 400 11px/1.8 var(--mono); color: var(--ink-muted); margin-bottom: 8px; }
    #detail-summary { font: 400 12px/1.6 var(--sans); color: var(--ink-soft); }
  </style>

  <div id="graph-shell">

    <!-- Canvas -->
    <div id="graph-canvas">
      <div id="graph-loading">Loading graph…</div>
      <svg id="graph-svg">
        <defs>
          <marker id="arr" markerWidth="6" markerHeight="4" refX="6" refY="2" orient="auto">
            <polygon points="0 0,6 2,0 4" fill="rgba(255,255,255,0.1)"/>
          </marker>
        </defs>
        <g id="zc"><g id="el"></g><g id="nl"></g></g>
      </svg>
    </div>

    <!-- Top-left: stats + build -->
    <div id="top-left">
      <div id="graph-stats" class="glass">
        <span class="stat"><b id="stat-nodes">—</b> nodes</span>
        <span class="stat"><b id="stat-edges">—</b> edges</span>
        <span class="stat"><b id="stat-comms">—</b> clusters</span>
      </div>
      <button id="build-btn">↺ Rebuild</button>
    </div>

    <!-- Top-center: search -->
    <div id="search-bar" class="glass">
      <span id="search-icon">⌕</span>
      <input type="search" id="node-search" placeholder="Search docs, concepts, decisions…" autocomplete="off" />
      <button id="search-clear">✕</button>
      <div id="search-dropdown"></div>
    </div>

    <!-- Top-right: zoom -->
    <div id="zoom-controls">
      <button class="zoom-btn" id="zoom-in" title="Zoom in">+</button>
      <button class="zoom-btn" id="zoom-fit" title="Fit" style="font-size:11px">⊡</button>
      <button class="zoom-btn" id="zoom-out" title="Zoom out">−</button>
    </div>

    <!-- Bottom: filter chips -->
    <div id="filter-bar" class="glass">
      <span class="f-label">Show</span>
      <div class="f-chip active" data-type="doc"><div class="f-chip-dot" style="background:#60a5fa"></div>docs</div>
      <div class="f-chip active" data-type="concept"><div class="f-chip-dot" style="background:#a78bfa"></div>concepts</div>
      <div class="f-chip active" data-type="decision"><div class="f-chip-dot" style="background:#f0997b"></div>decisions</div>
      <div class="f-chip active" data-type="flow"><div class="f-chip-dot" style="background:#fbbf24"></div>flows</div>
      <div class="f-chip active" data-type="task"><div class="f-chip-dot" style="background:#4ade80"></div>tasks</div>
      <div class="f-chip active" data-type="project"><div class="f-chip-dot" style="background:#e879f9"></div>projects</div>
      <div class="f-divider"></div>
      <div class="f-chip" id="chip-god">★ god-nodes</div>
    </div>

    <!-- Node detail panel -->
    <div id="graph-detail">
      <button id="detail-close">✕</button>
      <div id="detail-label"></div>
      <div id="detail-badges"></div>
      <div id="detail-community"></div>
      <div id="detail-stats"></div>
      <div id="detail-summary"></div>
    </div>

  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js" is:inline></script>
  <script define:vars={{ initialData }}>
    var NC = { doc:'#60a5fa', flow:'#fbbf24', flow_step:'#fbbf24', task:'#4ade80', session:'#52525b', concept:'#a78bfa', decision:'#f0997b', project:'#e879f9', rationale:'#f0997b' };

    var currentData = initialData;
    var allNodes = [], nodeSel, godRings, simRef, zoomRef, svgSel;
    var hiddenTypes = new Set();
    var godOnly = false;

    function radius(d){ return 6 + Math.min((d.degree||0)*0.5,12); }

    /* ─ Filter chips ─ */
    document.querySelectorAll('.f-chip[data-type]').forEach(function(chip){
      chip.addEventListener('click', function(){
        var t = chip.dataset.type;
        chip.classList.toggle('active');
        if (chip.classList.contains('active')) hiddenTypes.delete(t);
        else hiddenTypes.add(t);
        applyFilters();
      });
    });
    document.getElementById('chip-god').addEventListener('click', function(){
      this.classList.toggle('active');
      godOnly = this.classList.contains('active');
      applyFilters();
    });

    function applyFilters(){
      if (!nodeSel) return;
      nodeSel.attr('display', function(d){
        if (hiddenTypes.has(d.entityType)) return 'none';
        if (godOnly && !d.isGodNode) return 'none';
        return null;
      });
      if (godRings) godRings.attr('display', function(d){ return hiddenTypes.has(d.entityType) ? 'none' : null; });
    }

    /* ─ Search ─ */
    var searchInput = document.getElementById('node-search');
    var dropdown = document.getElementById('search-dropdown');
    var clearBtn = document.getElementById('search-clear');

    searchInput.addEventListener('input', function(){
      var q = this.value.trim();
      clearBtn.classList.toggle('visible', q.length > 0);

      if (!q) {
        dropdown.classList.remove('visible');
        if (nodeSel) nodeSel.attr('opacity', 0.9);
        return;
      }

      var hits = allNodes.filter(function(n){ return (n.label||'').toLowerCase().includes(q.toLowerCase()); }).slice(0,25);
      if (nodeSel) nodeSel.attr('opacity', function(d){ return (d.label||'').toLowerCase().includes(q.toLowerCase()) ? 1 : 0.07; });

      if (!hits.length) {
        dropdown.innerHTML = '<div id="search-empty-msg">No matches for "' + q + '"</div>';
      } else {
        dropdown.innerHTML = hits.map(function(n){
          return '<div class="s-hit" data-id="' + n.id + '">'
            + '<div class="s-dot" style="background:' + (NC[n.entityType]||'#6b7280') + (n.isGodNode?';box-shadow:0 0 0 2px #fbbf24':'') + '"></div>'
            + '<span class="s-label">' + (n.label||'') + '</span>'
            + '<span class="s-meta">' + (n.entityType||'') + '</span>'
            + (n.communityLabel ? '<span class="s-comm">' + n.communityLabel + '</span>' : '')
            + '</div>';
        }).join('');
        dropdown.querySelectorAll('.s-hit').forEach(function(el){
          el.addEventListener('click', function(){
            var node = allNodes.find(function(n){ return n.id === el.dataset.id; });
            if (node && node.x && svgSel && zoomRef) {
              var svg = svgSel.node(), W = svg.clientWidth, H = svg.clientHeight, s = 2.2;
              svgSel.transition().duration(400).call(zoomRef.transform, d3.zoomIdentity.translate(W/2 - s*node.x, H/2 - s*node.y).scale(s));
              openDetail(node);
            }
            dropdown.classList.remove('visible');
            searchInput.value = ''; clearBtn.classList.remove('visible');
            if (nodeSel) nodeSel.attr('opacity', 0.9);
          });
        });
      }
      dropdown.classList.add('visible');
    });

    clearBtn.addEventListener('click', function(){
      searchInput.value = ''; clearBtn.classList.remove('visible');
      dropdown.classList.remove('visible');
      if (nodeSel) nodeSel.attr('opacity', 0.9);
    });

    document.addEventListener('click', function(e){
      if (!document.getElementById('search-bar').contains(e.target)) dropdown.classList.remove('visible');
    });

    /* ─ Zoom controls ─ */
    document.getElementById('zoom-in').addEventListener('click', function(){
      if (svgSel && zoomRef) svgSel.transition().duration(250).call(zoomRef.scaleBy, 1.4);
    });
    document.getElementById('zoom-out').addEventListener('click', function(){
      if (svgSel && zoomRef) svgSel.transition().duration(250).call(zoomRef.scaleBy, 1/1.4);
    });
    document.getElementById('zoom-fit').addEventListener('click', fitGraph);

    function fitGraph(){
      if (!svgSel || !zoomRef) return;
      var nl = document.getElementById('nl');
      try {
        var b = nl.getBBox();
        if (!b || b.width === 0) return;
        var svg = svgSel.node(), W = svg.clientWidth, H = svg.clientHeight;
        var pad = 60, s = Math.min((W-pad*2)/b.width, (H-pad*2)/b.height, 2);
        var tx = W/2 - s*(b.x+b.width/2), ty = H/2 - s*(b.y+b.height/2);
        svgSel.transition().duration(500).call(zoomRef.transform, d3.zoomIdentity.translate(tx,ty).scale(s));
      } catch(e){}
    }

    /* ─ Render ─ */
    function render(data){
      if (!data || !window.d3) return;
      allNodes = (data.nodes||[]).map(function(n){ return Object.assign({},n); });
      var edges = data.edges||[];
      var comms = data.communities||[];

      document.getElementById('graph-loading').style.display = 'none';
      document.getElementById('stat-nodes').textContent = allNodes.length;
      document.getElementById('stat-edges').textContent = edges.length;
      document.getElementById('stat-comms').textContent = comms.length;

      svgSel = d3.select('#graph-svg');
      var W = svgSel.node().clientWidth, H = svgSel.node().clientHeight;
      var zc = d3.select('#zc'), el = d3.select('#el'), nl = d3.select('#nl');
      el.selectAll('*').remove(); nl.selectAll('*').remove();

      zoomRef = d3.zoom().scaleExtent([0.04,12]).on('zoom', function(e){ zc.attr('transform', e.transform); });
      svgSel.call(zoomRef);
      svgSel.on('click', function(e){ if (e.target === svgSel.node() || e.target.tagName === 'svg') closeDetail(); });

      var linkData = edges.map(function(e){ return {source:e.fromNodeId||e.from_node_id, target:e.toNodeId||e.to_node_id, d:e}; });
      var sim = d3.forceSimulation(allNodes)
        .force('link', d3.forceLink(linkData).id(function(d){ return d.id; }).distance(function(l){ return l.d.edgeType==='part_of'?60:120; }))
        .force('charge', d3.forceManyBody().strength(function(d){ return -80-(d.degree||0)*3; }))
        .force('center', d3.forceCenter(W/2,H/2))
        .force('collide', d3.forceCollide().radius(function(d){ return radius(d)+4; }));
      simRef = sim;

      var edgeSel = el.selectAll('line').data(linkData).enter().append('line')
        .attr('stroke', function(d){ return d.d.provenance==='INFERRED'?'rgba(255,255,255,0.07)':'rgba(255,255,255,0.15)'; })
        .attr('stroke-width',1).attr('opacity',0.8)
        .attr('stroke-dasharray', function(d){ return d.d.provenance==='INFERRED'?'4,3':null; })
        .attr('marker-end','url(#arr)');

      godRings = nl.selectAll('circle.gr').data(allNodes.filter(function(n){ return n.isGodNode; }))
        .enter().append('circle').attr('class','gr').attr('r', function(d){ return radius(d)+6; })
        .attr('fill','none').attr('stroke','#fbbf24').attr('stroke-width',1.5).attr('opacity',0.5);

      (function pulse(){
        godRings.transition().duration(1400).attr('opacity',0.08).attr('r', function(d){ return radius(d)+14; })
          .transition().duration(1400).attr('opacity',0.55).attr('r', function(d){ return radius(d)+6; })
          .on('end', pulse);
      })();

      nodeSel = nl.selectAll('circle.nd').data(allNodes).enter().append('circle').attr('class','nd')
        .attr('r', radius)
        .attr('fill', function(d){ return NC[d.entityType]||'#6b7280'; })
        .attr('stroke', function(d){ return d.isGodNode?'#fbbf24':'rgba(255,255,255,0.1)'; })
        .attr('stroke-width', function(d){ return d.isGodNode?2:1; })
        .attr('opacity',0.9).style('cursor','pointer')
        .on('click', function(e,d){ e.stopPropagation(); openDetail(d); });

      nodeSel.call(d3.drag()
        .on('start', function(e,d){ if(!e.active) sim.alphaTarget(0.3).restart(); d.fx=d.x; d.fy=d.y; })
        .on('drag',  function(e,d){ d.fx=e.x; d.fy=e.y; })
        .on('end',   function(e,d){ if(!e.active) sim.alphaTarget(0); d.fx=null; d.fy=null; }));

      nl.selectAll('text.nl').data(allNodes.filter(function(n){ return (n.degree||0)>=3||n.isGodNode; }))
        .enter().append('text').attr('class','nl')
        .text(function(d){ return d.label&&d.label.length>18?d.label.slice(0,16)+'…':d.label||''; })
        .attr('font-size','9px').attr('fill','rgba(240,238,233,0.5)').attr('text-anchor','middle')
        .attr('dy', function(d){ return -(radius(d)+4); }).style('pointer-events','none');

      sim.on('tick', function(){
        edgeSel.attr('x1',function(d){ return d.source.x; }).attr('y1',function(d){ return d.source.y; })
               .attr('x2',function(d){ return d.target.x; }).attr('y2',function(d){ return d.target.y; });
        nodeSel.attr('cx',function(d){ return d.x; }).attr('cy',function(d){ return d.y; });
        godRings.attr('cx',function(d){ return d.x; }).attr('cy',function(d){ return d.y; });
        nl.selectAll('text.nl').attr('x',function(d){ return d.x; }).attr('y',function(d){ return d.y; });
      });

      setTimeout(fitGraph, 2800);
      applyFilters();
    }

    /* ─ Detail panel ─ */
    function openDetail(d){
      document.getElementById('detail-label').textContent = d.label||'';
      var b = document.getElementById('detail-badges');
      b.innerHTML = '<span class="d-badge">' + (d.entityType||'') + '</span>';
      if (d.isGodNode) b.innerHTML += '<span class="d-badge d-god">★ god-node</span>';
      document.getElementById('detail-community').textContent = d.communityLabel ? '◆ ' + d.communityLabel : '';
      document.getElementById('detail-stats').textContent = 'Degree: ' + (d.degree||0) + '\nBetweenness: ' + (((d.betweennessCentrality||0)*100).toFixed(2)) + '%';
      document.getElementById('detail-summary').textContent = d.summary||'';
      document.getElementById('graph-detail').classList.add('open');
    }
    function closeDetail(){ document.getElementById('graph-detail').classList.remove('open'); }
    document.getElementById('detail-close').addEventListener('click', closeDetail);
    document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ closeDetail(); dropdown.classList.remove('visible'); } });

    /* ─ Build ─ */
    document.getElementById('build-btn').addEventListener('click', function(){
      var btn = this; btn.textContent = 'Queuing…'; btn.disabled = true;
      fetch('/api/graph/build',{method:'POST',credentials:'include'})
        .then(function(r){ return r.json(); })
        .then(function(){ btn.textContent = '✓ Queued'; setTimeout(function(){ btn.textContent = '↺ Rebuild'; btn.disabled = false; }, 3000); })
        .catch(function(){ btn.textContent = '↺ Rebuild'; btn.disabled = false; });
    });

    /* ─ SSE ─ */
    var es = new EventSource('/api/notifications/stream',{withCredentials:true});
    es.addEventListener('graph_updated', function(){
      fetch('/api/graph/full',{credentials:'include'}).then(function(r){ return r.ok?r.json():null; })
        .then(function(d){ if(d){ currentData=d; render(d); } });
    });

    /* ─ Load ─ */
    if (currentData) {
      render(currentData);
    } else {
      fetch('/api/graph/full',{credentials:'include'})
        .then(function(r){ return r.ok?r.json():null; })
        .then(function(d){
          if(d){ currentData=d; render(d); }
          else document.getElementById('graph-loading').textContent = 'No graph yet — click Rebuild to start.';
        })
        .catch(function(){ document.getElementById('graph-loading').textContent = 'No graph yet — click Rebuild to start.'; });
    }
  </script>
</AppLayout>
