---
import AppLayout from '../../layouts/AppLayout.astro';
import { GraphPageIsland } from '../../components/graph/GraphPageIsland';

const auth = Astro.locals.auth;
if (!auth) return Astro.redirect('/auth/login');

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';

let initialData = null;
try {
  const res = await fetch(`${apiUrl}/api/graph/full`, {
    headers: { Cookie: `boppl_jwt=${auth.jwt}` },
  });
  if (res.ok) initialData = await res.json();
} catch { /* offline — island will fetch client-side */ }
---

<AppLayout title="Knowledge Graph — Mnema">
  <style>
    #graph-shell {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #050508;
    }
  </style>

  <div id="graph-shell">
    <GraphPageIsland initialData={initialData} client:only="react" />
  </div>
</AppLayout>
