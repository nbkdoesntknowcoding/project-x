---
import AppLayout from '../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const domainPart = auth.email?.split('@')[1]?.split('.')[0] ?? '';
const workspaceName = domainPart
  ? domainPart.charAt(0).toUpperCase() + domainPart.slice(1)
  : 'Workspace';
---

<style>
  .nt-main { max-width: 880px; margin: 0 auto; padding: 40px 32px 100px; }

  .nt-pre {
    font: 500 11px/1 var(--mono); letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-muted); margin-bottom: 12px;
  }
  .nt-page-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 16px; margin-bottom: 22px;
  }
  .nt-page-head h1 { margin: 0; font: 500 28px/1.15 var(--sans); letter-spacing: -0.02em; }
  .nt-page-head .nt-sub { margin: 6px 0 0; font-size: 14px; color: var(--ink-soft); max-width: 36rem; }

  /* FILTER CHIPS */
  .nt-chips { display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
  .nt-chip {
    font: 500 12px/1 var(--sans); padding: 6px 11px; border-radius: 999px;
    background: transparent; border: 1px solid transparent;
    color: var(--ink-muted); cursor: pointer;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .nt-chip:hover { color: var(--ink); background: var(--surface-2); }
  .nt-chip.active { background: var(--surface-2); color: var(--ink); border-color: var(--line); }
  .nt-chip .ct { font: 500 10.5px/1 var(--mono); color: var(--ink-faint); letter-spacing: 0.02em; }
  .nt-chip.active .ct { color: var(--ink-muted); }

  .nt-meta-line {
    font: 500 11px/1 var(--mono); letter-spacing: 0.04em;
    color: var(--ink-muted); margin: 0 0 8px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nt-meta-line .v { color: var(--ink-soft); font-weight: 600; }
  .nt-mark-all {
    font: 500 12px var(--sans); background: transparent; border: 0;
    color: var(--ink-soft); cursor: pointer; padding: 6px 8px;
    border-radius: 5px; letter-spacing: 0;
  }
  .nt-mark-all:hover { color: var(--ink); background: var(--surface-2); }

  /* DAY DIVIDER */
  .nt-day-divider {
    font: 500 10.5px/1 var(--mono); letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink-muted);
    padding: 18px 0 8px; border-top: 1px solid var(--line);
  }
  .nt-day-divider:first-of-type { border-top: 0; padding-top: 6px; }

  /* NOTIFICATION ROWS */
  .nt-notif {
    display: grid; grid-template-columns: 14px 36px 1fr auto;
    gap: 12px; align-items: flex-start;
    padding: 14px 12px; border-radius: 8px; cursor: pointer; position: relative;
  }
  .nt-notif:hover { background: var(--surface); }
  .nt-notif.unread {
    background: linear-gradient(180deg, rgba(124,156,255,0.04), transparent 60%);
  }
  .nt-notif.unread:hover {
    background: linear-gradient(180deg, rgba(124,156,255,0.07), transparent 60%);
  }

  .nt-unread-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--status-info);
    box-shadow: 0 0 5px rgba(124,156,255,0.55);
    margin-top: 13px; justify-self: center;
  }
  .nt-notif:not(.unread) .nt-unread-dot { background: transparent; box-shadow: none; }

  .nt-av {
    width: 32px; height: 32px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    color: white; font: 700 12px/1 var(--sans); flex-shrink: 0; margin-top: 2px;
  }
  .nt-av.a { background: linear-gradient(135deg,#FFB370,#FF7A8A); }
  .nt-av.b { background: linear-gradient(135deg,#7C9CFF,#C8A2FF); }
  .nt-av.c { background: linear-gradient(135deg,#6BE39B,#2B9B9B); }
  .nt-av.d { background: linear-gradient(135deg,#FF7A8A,#B847C0); }

  .nt-sys-ic {
    width: 32px; height: 32px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--surface-2); border: 1px solid var(--line);
    color: var(--ink-soft); flex-shrink: 0; margin-top: 2px;
  }
  .nt-sys-ic.claude {
    background: linear-gradient(135deg,#FFB370,#FF7A8A); color: white;
    border-color: transparent; font: 700 13px/1 var(--sans);
  }
  .nt-sys-ic.warn {
    background: rgba(255,179,112,0.12); border-color: rgba(255,179,112,0.32);
    color: var(--status-edit);
  }
  .nt-sys-ic.err {
    background: rgba(255,122,138,0.10); border-color: rgba(255,122,138,0.30);
    color: var(--status-error);
  }
  .nt-sys-ic.ok {
    background: rgba(107,227,155,0.10); border-color: rgba(107,227,155,0.28);
    color: var(--status-sync);
  }

  .nt-meta { min-width: 0; }
  .nt-line { font: 400 13.5px/1.45 var(--sans); color: var(--ink); }
  .nt-line strong { font-weight: 600; color: var(--ink); }
  .nt-line .ref { color: var(--ink); font-weight: 500; }
  .nt-snippet {
    margin-top: 5px; font: 400 12.5px/1.5 var(--sans); color: var(--ink-muted);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; border-left: 2px solid var(--line-strong); padding-left: 10px;
  }
  .nt-link {
    display: inline-flex; align-items: center; gap: 4px;
    margin-top: 7px; font: 500 12px/1 var(--sans); color: var(--ink-soft);
    text-decoration: none;
  }
  .nt-link:hover { color: var(--accent); }
  .nt-ts {
    font: 500 11px/1 var(--mono); color: var(--ink-muted);
    letter-spacing: 0.02em; text-align: right; margin-top: 4px; flex-shrink: 0;
  }

  .nt-empty {
    display: none; flex-direction: column; align-items: center;
    text-align: center; padding: 80px 24px;
  }
  .nt-empty.active { display: flex; }
  .nt-empty .ic {
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--surface); border: 1px solid var(--line);
    color: var(--ink-soft);
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .nt-empty h3 { margin: 0 0 8px; font: 500 16px/1.3 var(--sans); letter-spacing: -0.005em; }
  .nt-empty p { margin: 0; font-size: 13px; color: var(--ink-muted); line-height: 1.55; max-width: 24rem; }

  .nt-foot-link {
    margin-top: 32px; padding-top: 20px; border-top: 1px solid var(--line);
    display: flex; align-items: center; justify-content: space-between;
  }
  .nt-foot-link a {
    font: 500 12.5px var(--sans); color: var(--ink-soft);
    display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
  }
  .nt-foot-link a:hover { color: var(--ink); }
  .nt-foot-link .live {
    font: 500 10.5px/1 var(--mono); color: var(--ink-faint);
    letter-spacing: 0.06em; display: inline-flex; align-items: center; gap: 6px;
  }
  .nt-foot-link .live .dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--status-sync); box-shadow: 0 0 4px rgba(107,227,155,0.5);
  }
</style>

<AppLayout title="Notifications — Mnema" workspaceName={workspaceName} email={auth.email}>

  <Fragment slot="status-left">
    <span style="font:500 11px/1 var(--mono);color:var(--ink-muted);">8 notifications · 5 unread</span>
  </Fragment>

  <div class="nt-main">

    <div class="nt-page-head">
      <div>
        <p class="nt-pre">NOTIFICATIONS</p>
        <h1>Inbox</h1>
        <p class="nt-sub">Mentions, comments, flow runs, billing, and system events from your workspace.</p>
      </div>
    </div>

    <div class="nt-chips" id="nt-chips">
      <button class="nt-chip active" data-filter="all">All<span class="ct">8</span></button>
      <button class="nt-chip" data-filter="unread">Unread<span class="ct">5</span></button>
      <button class="nt-chip" data-filter="mention">Mentions<span class="ct">2</span></button>
      <button class="nt-chip" data-filter="comment">Comments<span class="ct">1</span></button>
      <button class="nt-chip" data-filter="flow">Flow updates<span class="ct">1</span></button>
      <button class="nt-chip" data-filter="billing">Billing<span class="ct">2</span></button>
    </div>

    <div class="nt-meta-line">
      <span><span class="v" id="nt-meta-count">8</span> notifications · <span class="v" id="nt-meta-unread">5</span> unread</span>
      <button class="nt-mark-all" id="nt-mark-all">Mark all as read</button>
    </div>

    <div id="nt-list">

      <div class="nt-day-divider">TODAY</div>

      <div class="nt-notif unread" data-type="mention">
        <span class="nt-unread-dot"></span>
        <span class="nt-av b">A</span>
        <div class="nt-meta">
          <div class="nt-line"><strong>Anton</strong> mentioned you in <span class="ref">Pricing strategy v2</span></div>
          <div class="nt-snippet">"Hey @kevin — are we sure 5,000 is the right rate limit for Pro? Looking at usage, 78% of teams are well under…"</div>
        </div>
        <span class="nt-ts">14 min ago</span>
      </div>

      <div class="nt-notif unread" data-type="comment">
        <span class="nt-unread-dot"></span>
        <span class="nt-av c">M</span>
        <div class="nt-meta">
          <div class="nt-line"><strong>Maya</strong> replied to your comment on <span class="ref">MCP tool reference</span></div>
          <div class="nt-snippet">"Good catch — I'll update the rate-limit headers section before the next release."</div>
        </div>
        <span class="nt-ts">42 min ago</span>
      </div>

      <div class="nt-notif unread" data-type="flow">
        <span class="nt-unread-dot"></span>
        <span class="nt-sys-ic claude">C</span>
        <div class="nt-meta">
          <div class="nt-line">Claude walked <span class="ref">New-hire onboarding</span> · <span style="color:var(--ink-muted);">7 steps</span></div>
        </div>
        <span class="nt-ts">2 hours ago</span>
      </div>

      <div class="nt-notif unread" data-type="billing">
        <span class="nt-unread-dot"></span>
        <span class="nt-sys-ic warn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </span>
        <div class="nt-meta">
          <div class="nt-line">You've used <strong>80%</strong> of your MCP calls this period</div>
          <div class="nt-snippet" style="border-color:rgba(255,179,112,0.28);color:var(--ink-soft);">4,012 of 5,000 calls used · resets in 9 days</div>
          <a class="nt-link" href="/app/cost">View usage <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
        </div>
        <span class="nt-ts">3 hours ago</span>
      </div>

      <div class="nt-notif unread" data-type="mention">
        <span class="nt-unread-dot"></span>
        <span class="nt-av d">P</span>
        <div class="nt-meta">
          <div class="nt-line"><strong>Priya</strong> mentioned you in a comment on <span class="ref">Local dev setup</span></div>
          <div class="nt-snippet">"@kevin can you double-check the Postgres connection string section before we onboard the new eng cohort?"</div>
        </div>
        <span class="nt-ts">5 hours ago</span>
      </div>

      <div class="nt-day-divider">YESTERDAY</div>

      <div class="nt-notif" data-type="billing">
        <span class="nt-unread-dot"></span>
        <span class="nt-sys-ic err">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </span>
        <div class="nt-meta">
          <div class="nt-line">Payment for <span class="ref">INV-2025-0214-B0PP1</span> failed</div>
          <div class="nt-snippet" style="border-color:rgba(255,122,138,0.30);color:var(--ink-soft);">Mastercard •••• 4242 was declined. We'll retry in 2 days.</div>
          <a class="nt-link" href="/app/settings" style="color:var(--status-error);">Update payment method <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
        </div>
        <span class="nt-ts">1 day ago</span>
      </div>

      <div class="nt-notif" data-type="mention">
        <span class="nt-unread-dot"></span>
        <span class="nt-av a">N</span>
        <div class="nt-meta">
          <div class="nt-line"><strong>Nikhil Bhat</strong> joined the workspace</div>
        </div>
        <span class="nt-ts">1 day ago</span>
      </div>

      <div class="nt-day-divider">EARLIER</div>

      <div class="nt-notif" data-type="billing">
        <span class="nt-unread-dot"></span>
        <span class="nt-sys-ic ok">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <div class="nt-meta">
          <div class="nt-line">Workspace upgraded to <strong>Pro</strong></div>
          <div class="nt-snippet" style="border-color:rgba(107,227,155,0.28);color:var(--ink-soft);">5 seats · 5,000 MCP calls/month · unlimited docs</div>
        </div>
        <span class="nt-ts">3 days ago</span>
      </div>

      <div class="nt-empty" id="nt-empty">
        <div class="ic">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
        </div>
        <h3>No notifications</h3>
        <p>When something happens, it'll show up here.</p>
      </div>
    </div>

    <div class="nt-foot-link">
      <a href="/app/settings">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Notification preferences
      </a>
      <span class="live"><span class="dot"></span>REAL-TIME · LIVE</span>
    </div>

  </div>

</AppLayout>

<script>
function updateMeta() {
  const visible = [...document.querySelectorAll('.nt-notif')].filter((r) => (r as HTMLElement).style.display !== 'none');
  const unread = visible.filter((r) => r.classList.contains('unread')).length;
  const countEl = document.getElementById('nt-meta-count');
  const unreadEl = document.getElementById('nt-meta-unread');
  if (countEl) countEl.textContent = String(visible.length);
  if (unreadEl) unreadEl.textContent = String(unread);
}

document.getElementById('nt-chips')?.addEventListener('click', (e) => {
  const b = (e.target as Element).closest('.nt-chip') as HTMLElement | null;
  if (!b) return;
  document.querySelectorAll('.nt-chip').forEach((c) => c.classList.toggle('active', c === b));
  const f = b.dataset.filter;
  let visible = 0;
  document.querySelectorAll('.nt-notif').forEach((r: Element) => {
    const row = r as HTMLElement;
    let show = true;
    if (f === 'unread') show = row.classList.contains('unread');
    else if (f !== 'all') show = row.dataset.type === f;
    row.style.display = show ? 'grid' : 'none';
    if (show) visible++;
  });
  document.querySelectorAll('.nt-day-divider').forEach((d) => {
    let next = d.nextElementSibling;
    let hasVisible = false;
    while (next && !next.classList.contains('nt-day-divider') && !next.classList.contains('nt-empty')) {
      if ((next as HTMLElement).style.display !== 'none') { hasVisible = true; break; }
      next = next.nextElementSibling;
    }
    (d as HTMLElement).style.display = hasVisible ? '' : 'none';
  });
  document.getElementById('nt-empty')?.classList.toggle('active', visible === 0);
  updateMeta();
});

document.getElementById('nt-mark-all')?.addEventListener('click', () => {
  document.querySelectorAll('.nt-notif.unread').forEach((r) => r.classList.remove('unread'));
  updateMeta();
});

document.querySelectorAll('.nt-notif').forEach((r) => {
  r.addEventListener('click', () => { r.classList.remove('unread'); updateMeta(); });
});
</script>
