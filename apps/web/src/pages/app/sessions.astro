---
// Phase 2 stub — agent session history
import AppLayout from '../../layouts/AppLayout.astro';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}
---

<AppLayout title="Sessions">
  <div style="padding: 40px; color: var(--ink-muted); font-family: var(--mono);">
    <!-- TODO: Claude Design — apply Mnema glassmorphism design system -->
    <!-- Background: var(--bg) #0a0a0a -->
    <!-- Cards: rgba(255,255,255,0.04) + backdrop-filter: blur(24px) -->
    <!-- See BOPPL_Context_Engine_Prompt_UI_Redesign_All_MCP_Panels for token system -->
    <h1 style="font-size: 18px; font-weight: 600; color: var(--ink);">Sessions</h1>
    <p style="margin-top: 8px; font-size: 13px;">Agent session history — available in Phase 2.</p>
  </div>
</AppLayout>
