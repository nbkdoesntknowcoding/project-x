---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { WorkspaceSwitcher } from '../../components/nav/WorkspaceSwitcher';
import { ThemeToggle } from '../../components/theme/ThemeToggle';

const auth = Astro.locals.auth;
if (!auth) {
  return Astro.redirect('/auth/login');
}

const apiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
const [docsRes, unreadRes] = await Promise.all([
  fetch(`${apiUrl}/api/docs`, { headers: { Cookie: `boppl_jwt=${auth.jwt}` } }),
  fetch(`${apiUrl}/api/doc-read-state/unread-counts`, {
    headers: { Cookie: `boppl_jwt=${auth.jwt}` },
  }),
]);

interface DocSummary {
  id: string;
  title: string;
  updated_at: string;
}

let docs: DocSummary[] = [];
if (docsRes.ok) {
  const body = (await docsRes.json()) as { docs: DocSummary[] };
  docs = body.docs;
}

const unreadByDoc = new Map<string, number>();
if (unreadRes.ok) {
  const body = (await unreadRes.json()) as {
    unread: Array<{ doc_id: string; unread_comment_count: number }>;
  };
  for (const row of body.unread ?? []) {
    unreadByDoc.set(row.doc_id, row.unread_comment_count);
  }
}

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString();
}
---

<BaseLayout title="Docs — Mnema">
  <!-- Top bar -->
  <header
    class="h-12 flex items-center px-4"
    style="border-bottom: 1px solid var(--border-subtle); background: var(--surface-base);"
  >
    <span style="font-size: 14px; font-weight: 500; color: var(--text-primary); margin-right: 16px;">
      Mnema
    </span>
    <WorkspaceSwitcher client:load currentWorkspaceId={auth.tenant_id} />
    <div class="flex items-center gap-3 ml-auto">
      <ThemeToggle client:load />
      <span style="font-size: 12px; color: var(--text-tertiary);">{auth.email}</span>
      <a
        href="/auth/logout"
        style="font-size: 12px; color: var(--text-tertiary);"
        class="transition-colors"
        onmouseover="this.style.color='var(--text-primary)'"
        onmouseout="this.style.color='var(--text-tertiary)'"
      >
        Sign out
      </a>
    </div>
  </header>

  <div class="flex min-h-[calc(100vh-48px)]">
    <!-- Left sidebar -->
    <aside
      class="w-60 py-3 px-2 flex-shrink-0"
      style="border-right: 1px solid var(--border-subtle); background: var(--surface-base);"
    >
      <a
        href="/app"
        class="flex items-center h-7 px-2 rounded transition-[background] w-full"
        style="font-size: 13px; font-weight: 500; color: var(--text-primary); background: var(--surface-overlay); border-radius: var(--radius-sm);"
      >
        Home
      </a>
      <a
        href="/app/settings/members"
        class="flex items-center h-7 px-2 rounded transition-[background] w-full mt-0.5"
        style="font-size: 13px; color: var(--text-secondary);"
        onmouseover="this.style.background='var(--interactive-ghost-hover)'"
        onmouseout="this.style.background='transparent'"
      >
        Settings
      </a>
    </aside>

    <!-- Main content -->
    <main class="flex-1 px-8 pt-10">
      <div class="max-w-[800px]">
        <!-- Header row -->
        <div class="flex items-center justify-between mb-2">
          <h1 style="font-size: 28px; line-height: 1.3; letter-spacing: -0.01em; font-weight: 500; color: var(--text-primary);">
            Documents
          </h1>
          <form id="new-doc-form">
            <button
              type="submit"
              class="inline-flex items-center justify-center h-8 px-3 font-medium transition-[background,border-color] rounded select-none"
              style="font-size: 13px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border: 1px solid var(--interactive-primary); border-radius: var(--radius-md);"
              onmouseover="this.style.background='var(--interactive-primary-hover)'"
              onmouseout="this.style.background='var(--interactive-primary)'"
            >
              New document
            </button>
          </form>
        </div>
        <p style="font-size: 12px; color: var(--text-tertiary); margin-bottom: 32px;">
          {docs.length} document{docs.length !== 1 ? 's' : ''} in your workspace
        </p>

        <!-- Doc list -->
        {docs.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-16 px-6 text-center">
            <div style="color: var(--text-tertiary); margin-bottom: 16px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
            <p style="font-size: 14px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">
              No documents yet.
            </p>
            <p style="font-size: 13px; color: var(--text-tertiary); max-width: 340px; margin-bottom: 24px;">
              Create your first doc to start building your live context.
            </p>
            <form id="new-doc-form-empty">
              <button
                type="submit"
                class="inline-flex items-center justify-center h-8 px-3 font-medium transition-[background,border-color] rounded select-none"
                style="font-size: 13px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border: 1px solid var(--interactive-primary); border-radius: var(--radius-md);"
              >
                Create document
              </button>
            </form>
          </div>
        ) : (
          <ul style="border-top: 1px solid var(--border-subtle);">
            {docs.map((d) => {
              const unread = unreadByDoc.get(d.id) ?? 0;
              return (
                <li style="border-bottom: 1px solid var(--border-subtle);">
                  <a
                    href={`/app/d/${d.id}`}
                    class="flex items-center h-14 px-3 transition-[background]"
                    style="color: var(--text-primary);"
                    onmouseover="this.style.background='var(--surface-overlay)'"
                    onmouseout="this.style.background='transparent'"
                  >
                    <div class="flex items-center gap-2 flex-shrink-0">
                      {unread > 0 && (
                        <span
                          title={`${unread} unread comment${unread === 1 ? '' : 's'}`}
                          style="width: 6px; height: 6px; border-radius: 50%; background: var(--status-info); flex-shrink: 0;"
                        />
                      )}
                      <span style="font-size: 14px; font-weight: 500;">{d.title || 'Untitled'}</span>
                    </div>
                    <span
                      class="flex-1 mx-4 truncate"
                      style="font-size: 13px; color: var(--text-tertiary);"
                    >
                      —
                    </span>
                    <span
                      class="flex-shrink-0"
                      style="font-size: 12px; color: var(--text-tertiary);"
                    >
                      {relativeTime(d.updated_at)}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </main>
  </div>

  <script>
    async function createDoc() {
      const apiBase =
        (import.meta.env.PUBLIC_API_URL as string | undefined) ?? 'http://localhost:8080';
      const res = await fetch(`${apiBase}/api/docs`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: 'Untitled' }),
      });
      if (!res.ok) {
        alert('Failed to create doc');
        return;
      }
      const { doc } = (await res.json()) as { doc: { id: string } };
      window.location.href = `/app/d/${doc.id}`;
    }

    document.getElementById('new-doc-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      void createDoc();
    });
    document.getElementById('new-doc-form-empty')?.addEventListener('submit', (e) => {
      e.preventDefault();
      void createDoc();
    });
  </script>
</BaseLayout>
