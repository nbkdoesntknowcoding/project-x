<div class="s-corner-mark">MNEMA · <span class="s-v">v2.0</span> · AUTH</div>
<div class="s-status-pill"><span class="s-signal"></span>ALL SYSTEMS LIVE</div>

<script is:inline>
  /* Star particles */
  (function () {
    var host = document.getElementById('s-stars');
    var n = 60;
    for (var i = 0; i < n; i++) {
      var s = document.createElement('div');
      s.className = 's-star';
      var sz = 1 + Math.random() * 2.2;
      s.style.width = s.style.height = sz + 'px';
      s.style.left = Math.random() * 100 + '%';
      s.style.top = Math.random() * 100 + '%';
      s.style.setProperty('--life', (3 + Math.random() * 5).toFixed(1) + 's');
      s.style.setProperty('--delay', (Math.random() * 5).toFixed(1) + 's');
      host.appendChild(s);
    }
  })();

  /* Email validation + submit state */
  (function () {
    var emailEl = document.getElementById('s-email');
    var btn = document.getElementById('s-continue-btn');

    function validate() {
      var v = emailEl.value.trim();
      btn.disabled = !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
    }
    emailEl.addEventListener('input', validate);

    var SPINNER = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></path></svg>';

    btn.addEventListener('click', function () {
      if (btn.disabled) return;
      var email = emailEl.value.trim();
      btn.disabled = true;
      btn.innerHTML = SPINNER + ' Sending magic link…';

      fetch('/auth/send-magic-link', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email: email }),
      })
        .then(function (res) {
          if (res.ok) {
            btn.innerHTML = '✓ Code sent — check your inbox';
            btn.style.background = '#6BE39B';
            btn.style.color = '#07140C';
            btn.style.borderColor = '#6BE39B';
            setTimeout(function () {
              window.location.href = '/auth/verify-code?email=' + encodeURIComponent(email);
            }, 1000);
          } else {
            btn.disabled = false;
            btn.innerHTML = '✗ Send failed — try again';
            btn.style.background = '#f87171';
            btn.style.color = '#fff';
            btn.style.borderColor = '#f87171';
            setTimeout(function () {
              btn.innerHTML = 'Continue with email';
              btn.style.cssText = '';
              validate();
            }, 3000);
          }
        })
        .catch(function () {
          btn.disabled = false;
          btn.innerHTML = '✗ Network error — try again';
          setTimeout(function () { btn.innerHTML = 'Continue with email'; btn.style.cssText = ''; validate(); }, 3000);
        });
    });
  })();
</script>

