---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignupForm } from '../components/auth/SignupForm';

const auth = Astro.locals.auth;
if (auth) {
  return Astro.redirect('/app');
}
---

<BaseLayout title="Sign up · Mnema">
  <main
    class="min-h-screen flex items-center justify-center px-4"
    style="background: var(--surface-base);"
  >
    <div class="w-full max-w-[400px]">
      <div class="mb-12 text-center">
        <span
          style="font-size: 22px; font-weight: 500; color: var(--text-primary); display: block;"
        >
          Mnema
        </span>
      </div>

      <h1
        class="text-center mb-2"
        style="font-size: 22px; line-height: 1.3; font-weight: 500; color: var(--text-primary);"
      >
        Create your account
      </h1>
      <p
        class="text-center mb-8"
        style="font-size: 14px; color: var(--text-secondary);"
      >
        The live context engine for AI-native teams.
      </p>

      <SignupForm client:load />

      <p
        class="mt-6 text-center"
        style="font-size: 12px; color: var(--text-tertiary);"
      >
        Already have an account?{' '}
        <a
          href="/auth/login"
          class="transition-colors"
          style="color: var(--text-secondary);"
          onmouseover="this.style.color='var(--text-primary)'"
          onmouseout="this.style.color='var(--text-secondary)'"
        >
          Sign in
        </a>
      </p>
    </div>
  </main>
</BaseLayout>
