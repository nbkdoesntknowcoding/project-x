---
import PublicLayout from '../layouts/PublicLayout.astro';
import { RadialGlow } from '../components/ui/RadialGlow';
import { NoiseOverlay } from '../components/ui/NoiseOverlay';
import FlowMockup from '../components/landing/FlowMockup.astro';
import HeroGraph from '../components/landing/HeroGraph.tsx';
import CommandPalette from '../components/landing/CommandPalette.tsx';
import LiveStats from '../components/landing/LiveStats.tsx';
import FeatureCards from '../components/landing/FeatureCards.tsx';

const auth = Astro.locals.auth;
---

<PublicLayout
  title="Mnema — the context engine for AI agents"
  description="Compose docs, instructions, and snippets into structured flows that Claude reads in order — through MCP, live, no uploads."
  pathname="/"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden pt-24 pb-16" style="background: var(--surface-base);">
    <RadialGlow cx={50} cy={28} radius={50} tone="warm" intensity={1} />
    <NoiseOverlay opacity={0.04} />

    <div
      class="relative max-w-3xl mx-auto px-6 text-center mb-12"
      style="z-index: 2;"
    >
      <span
        class="font-mono uppercase block mb-5"
        style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
      >
        The context engine for AI agents
      </span>

      <!-- MixedHeading: Geist Sans base, ONE Instrument Serif italic emphasis -->
      <h1
        class="font-sans font-medium tracking-[-0.02em]"
        style="font-size: 64px; line-height: 1.05; color: var(--text-primary);"
      >
        Compose the context your AI
        <em
          style="font-family: var(--font-display); font-style: italic; font-weight: 400;"
        >reads from</em>.
      </h1>

      <p
        class="mt-6 max-w-xl mx-auto"
        style="font-size: 16px; line-height: 1.65; color: var(--text-secondary);"
      >
        Mnema turns your docs, instructions, and snippets into structured flows your AI reads
        in order through MCP. A live knowledge graph connects everything, and a meeting
        assistant joins your calls and answers from your workspace in real time.
      </p>

      <div class="mt-10 flex items-center justify-center gap-3">
        {auth ? (
          <a
            href="/app"
            class="inline-flex items-center justify-center h-10 px-5 font-medium transition-[background] rounded select-none"
            style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border-radius: var(--radius-md);"
            onmouseover="this.style.background='var(--interactive-primary-hover)'"
            onmouseout="this.style.background='var(--interactive-primary)'"
          >
            Open app
          </a>
        ) : (
          <>
            <a
              href="/waitlist"
              class="inline-flex items-center justify-center h-10 px-5 font-medium transition-[background] rounded select-none"
              style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border-radius: var(--radius-md);"
              onmouseover="this.style.background='var(--interactive-primary-hover)'"
              onmouseout="this.style.background='var(--interactive-primary)'"
            >
              Join the waitlist
            </a>
            <a
              href="/docs/flows"
              class="inline-flex items-center justify-center h-10 px-5 font-medium transition-[background] rounded select-none"
              style="font-size: 14px; background: var(--interactive-secondary); color: var(--text-primary); border: 1px solid var(--border-default); border-radius: var(--radius-md);"
              onmouseover="this.style.background='var(--interactive-secondary-hover)'"
              onmouseout="this.style.background='var(--interactive-secondary)'"
            >
              See how flows work
            </a>
          </>
        )}
      </div>

      <p
        class="mt-6 font-mono uppercase"
        style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-quaternary);"
      >
        Free forever for personal use · No credit card
      </p>
    </div>

    <!-- ===== Raycast-style desktop frame: the graph IS the workspace, the
         palette is the MCP agent reading it ===== -->
    <div class="relative max-w-6xl mx-auto px-6" style="z-index: 2;">
      <div
        class="relative overflow-hidden mnema-window"
        style="
          border-radius: 16px;
          border: 1px solid var(--border-default);
          background: var(--surface-overlay);
          box-shadow:
            0 1px 0 rgba(255,255,255,0.05) inset,
            0 40px 100px -30px rgba(0,0,0,0.75),
            0 0 0 1px rgba(255,255,255,0.03),
            0 0 120px -40px rgba(255,179,112,0.18);
        "
      >
        <!-- window top bar (app chrome) -->
        <div
          class="flex items-center justify-between"
          style="height: 44px; padding: 0 14px; border-bottom: 1px solid var(--border-subtle); background: var(--surface-base);"
        >
          <div class="flex items-center gap-3">
            <span class="flex gap-1.5" aria-hidden="true">
              <span style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.14);"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.10);"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.07);"></span>
            </span>
            <span class="inline-flex items-center gap-2 ml-1">
              <span class="inline-flex overflow-hidden" style="width:18px;height:18px;border-radius:5px;">
                <img src="/logo.svg" width="18" height="18" alt="" draggable="false" />
              </span>
              <span style="font-size:13px;font-weight:500;color:var(--text-secondary);">Acme workspace</span>
            </span>
            <nav class="hidden sm:flex items-center gap-1 ml-2 font-mono" style="font-size:11px;">
              <span style="padding:3px 8px;border-radius:6px;background:var(--surface-overlay);color:var(--text-primary);">Graph</span>
              <span style="padding:3px 8px;color:var(--text-tertiary);">Docs</span>
              <span style="padding:3px 8px;color:var(--text-tertiary);">Flows</span>
              <span style="padding:3px 8px;color:var(--text-tertiary);">Tasks</span>
            </nav>
          </div>
          <div class="flex items-center gap-3 font-mono" style="font-size:10px; letter-spacing:0.06em; color:var(--text-tertiary); text-transform:uppercase;">
            <span class="hidden sm:inline-flex items-center gap-1.5" style="color:#7C9CFF;">
              <span style="width:6px;height:6px;border-radius:50%;background:#7C9CFF;"></span>MCP
            </span>
            <span class="hidden sm:inline-flex items-center gap-1.5">
              <span style="width:6px;height:6px;border-radius:50%;background:var(--status-sync);box-shadow:0 0 8px rgba(107,227,155,0.6);"></span>Synced
            </span>
            <span>9:41</span>
          </div>
        </div>

        <!-- window body: real-graph "desktop" (renders on black) + floating palette -->
        <div
          class="relative"
          style="height: clamp(360px, 42vw, 480px); background:
            radial-gradient(ellipse 70% 70% at 30% 22%, rgba(255,179,112,0.07), transparent 62%),
            radial-gradient(ellipse 60% 60% at 85% 82%, rgba(124,156,255,0.07), transparent 58%),
            #050609;"
        >
          <HeroGraph client:only="react" />

          <div
            class="absolute top-3 left-4 font-mono uppercase pointer-events-none"
            style="font-size: 10px; letter-spacing: 0.08em; color: var(--text-tertiary); z-index: 2;"
          >
            Knowledge graph · 2 projects · drag a node
          </div>

          <!-- floating command palette (the agent reading context) -->
          <div
            class="absolute left-1/2 bottom-5 px-4 w-full"
            style="transform: translateX(-50%); max-width: 520px; z-index: 3;"
          >
            <CommandPalette client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LIVE STATS (dub-style counters) ===== -->
  <section class="py-24" style="background: var(--surface-base);">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <span
          class="font-mono uppercase block mb-3"
          style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
        >
          Built to remember
        </span>
        <h2
          class="font-sans font-medium max-w-2xl mx-auto"
          style="font-size: 28px; line-height: 1.2; letter-spacing: -0.02em; color: var(--text-primary);"
        >
          Every doc, flow, and decision — connected and queryable.
        </h2>
      </div>
      <LiveStats client:visible />
    </div>
  </section>

  <!-- ===== HOW FLOWS WORK ===== -->
  <section class="py-24" style="background: var(--surface-base);">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <span
          class="font-mono uppercase block mb-3"
          style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
        >
          How it works next
        </span>
        <h2
          class="font-sans font-medium max-w-2xl mx-auto"
          style="font-size: 28px; line-height: 1.2; letter-spacing: -0.02em; color: var(--text-primary);"
        >
          Flows turn docs into sequences.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- LEFT: visual mockup of a flow -->
        <div>
          <FlowMockup />
        </div>

        <!-- RIGHT: three short paragraphs -->
        <div class="space-y-6">
          <div>
            <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
              Sequence content.
            </h3>
            <p style="font-size: 14px; line-height: 1.65; color: var(--text-secondary);">
              Drag docs from your workspace into a step list. Every step is one chunk of
              context the agent reads.
            </p>
          </div>
          <div>
            <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
              Annotate each step.
            </h3>
            <p style="font-size: 14px; line-height: 1.65; color: var(--text-secondary);">
              Add an instruction in your own words. Claude reads the instruction before
              reading the doc.
            </p>
          </div>
          <div>
            <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 6px;">
              Claude pulls each step in order.
            </h3>
            <p style="font-size: 14px; line-height: 1.65; color: var(--text-secondary);">
              No giant context dump. Each step is a separate MCP call, so the agent reasons
              between them.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURE CARDS (Raycast 'extension cards' translation) ===== -->
  <section class="py-24" style="background: var(--surface-base);">
    <div class="max-w-6xl mx-auto px-6">
      <FeatureCards client:visible />
    </div>
  </section>

  <!-- ===== CTA STRIP ===== -->
  <section class="relative py-32" style="background: var(--surface-base);">
    <RadialGlow cx={50} cy={50} radius={45} tone="warm" intensity={0.8} />
    <div
      class="relative max-w-2xl mx-auto px-6 text-center"
      style="z-index: 2;"
    >
      <h2
        class="font-sans font-medium"
        style="font-size: var(--display-sm); line-height: 1.1; letter-spacing: -0.02em; color: var(--text-primary); margin-bottom: 16px;"
      >
        Be first in line.
      </h2>
      <p
        class="mb-8"
        style="font-size: 15px; color: var(--text-secondary);"
      >
        Mnema is opening up gradually ahead of launch. Join the waitlist and we'll reach out with an invite.
      </p>
      <a
        href="/waitlist"
        class="inline-flex items-center justify-center h-10 px-5 font-medium transition-[background] rounded select-none"
        style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border-radius: var(--radius-md);"
        onmouseover="this.style.background='var(--interactive-primary-hover)'"
        onmouseout="this.style.background='var(--interactive-primary)'"
      >
        Join the waitlist
      </a>
    </div>
  </section>

</PublicLayout>
