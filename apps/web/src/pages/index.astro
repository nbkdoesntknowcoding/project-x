---
import PublicLayout from '../layouts/PublicLayout.astro';

const auth = Astro.locals.auth;
---

<PublicLayout
  title="Mnema — the live context engine"
  description="AI-native docs that connect directly to Claude. Your docs stay current, your AI stays informed."
  pathname="/"
>
  <!-- Hero -->
  <section class="max-w-[720px] mx-auto px-6 pt-[128px] pb-[128px] text-center">
    <span
      class="font-mono uppercase block mb-4"
      style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
    >
      The live context engine
    </span>

    <h1
      style="font-size: 56px; line-height: 1.15; letter-spacing: -0.02em; font-weight: 600; color: var(--text-primary);"
    >
      AI-native docs that connect directly to Claude.
    </h1>

    <p
      class="mx-auto mt-6 mb-8"
      style="font-size: 18px; color: var(--text-secondary); max-width: 580px; line-height: 1.5;"
    >
      Write your docs once. Edit them live. Claude reads them straight from the source.
      No uploads, no version churn, no stale exports.
    </p>

    <div class="flex items-center justify-center gap-3">
      {auth ? (
        <a
          href="/app"
          class="inline-flex items-center justify-center h-10 px-4 font-medium transition-[background,border-color] rounded select-none"
          style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border: 1px solid var(--interactive-primary); border-radius: var(--radius-md);"
          onmouseover="this.style.background='var(--interactive-primary-hover)'"
          onmouseout="this.style.background='var(--interactive-primary)'"
        >
          Open app
        </a>
      ) : (
        <>
          <a
            href="/signup"
            class="inline-flex items-center justify-center h-10 px-4 font-medium transition-[background,border-color] rounded select-none"
            style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border: 1px solid var(--interactive-primary); border-radius: var(--radius-md);"
            onmouseover="this.style.background='var(--interactive-primary-hover)'"
            onmouseout="this.style.background='var(--interactive-primary)'"
          >
            Start free
          </a>
          <a
            href="/pricing"
            class="inline-flex items-center justify-center h-10 px-4 font-medium transition-[background] rounded select-none"
            style="font-size: 14px; background: var(--interactive-secondary); color: var(--text-primary); border: 1px solid var(--border-default); border-radius: var(--radius-md);"
            onmouseover="this.style.background='var(--interactive-secondary-hover)'"
            onmouseout="this.style.background='var(--interactive-secondary)'"
          >
            View pricing
          </a>
        </>
      )}
    </div>

    <p
      class="mt-6 font-mono uppercase"
      style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-quaternary);"
    >
      Free forever for personal use · No credit card
    </p>
  </section>

  <!-- Editor placeholder -->
  <section
    class="px-6 py-[96px]"
    style="background: var(--surface-overlay);"
  >
    <div class="max-w-[1100px] mx-auto">
      <div
        class="mx-auto"
        style="max-width: 1100px; height: 480px; background: var(--surface-sunken); border: 1px solid var(--border-default); border-radius: var(--radius-xl);"
      ></div>
      <p
        class="text-center mt-4 font-mono uppercase"
        style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
      >
        The editor
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-[1100px] mx-auto px-6 py-[96px]">
    <p class="text-center font-mono uppercase mb-3" style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);">
      How it works
    </p>
    <h2
      class="text-center mb-16"
      style="font-size: 28px; line-height: 1.3; font-weight: 500; color: var(--text-primary);"
    >
      Three things make Mnema different.
    </h2>

    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <span
          class="block mb-3 font-mono uppercase"
          style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
        >
          01
        </span>
        <h3 style="font-size: 18px; font-weight: 500; color: var(--text-primary); margin-bottom: 8px;">
          Live, not static.
        </h3>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.55;">
          Every edit syncs instantly. The doc Claude reads at 3:14 is the doc your teammate updated at 3:13.
          No re-upload.
        </p>
      </div>
      <div>
        <span
          class="block mb-3 font-mono uppercase"
          style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
        >
          02
        </span>
        <h3 style="font-size: 18px; font-weight: 500; color: var(--text-primary); margin-bottom: 8px;">
          Search that understands.
        </h3>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.55;">
          Search "rate limiting" — find docs about throttling. Search "pricing" — find docs about cost,
          tiers, plans. Hybrid keyword and semantic.
        </p>
      </div>
      <div>
        <span
          class="block mb-3 font-mono uppercase"
          style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
        >
          03
        </span>
        <h3 style="font-size: 18px; font-weight: 500; color: var(--text-primary); margin-bottom: 8px;">
          Built for Claude.
        </h3>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.55;">
          Mnema is an MCP server. One-click connect from your Claude account. Your docs become
          first-class context.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="max-w-[720px] mx-auto px-6 py-[128px] text-center">
    <h2
      class="mb-3"
      style="font-size: 18px; font-weight: 500; color: var(--text-primary);"
    >
      Ready to try it?
    </h2>
    <p class="mb-8" style="font-size: 14px; color: var(--text-secondary);">
      Set up a workspace in under a minute. Free forever for personal use.
    </p>
    <a
      href="/signup"
      class="inline-flex items-center justify-center h-10 px-4 font-medium transition-[background,border-color] rounded select-none"
      style="font-size: 14px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border: 1px solid var(--interactive-primary); border-radius: var(--radius-md);"
      onmouseover="this.style.background='var(--interactive-primary-hover)'"
      onmouseout="this.style.background='var(--interactive-primary)'"
    >
      Start free
    </a>
  </section>
</PublicLayout>
