---
// Public placement-prep question bank. No auth (middleware only guards /app/*),
// so this is shareable by link. Self-contained layout (responsive viewport) rather
// than AppLayout/BaseLayout so it reads well on mobile too.
import '../styles/global.css';
import { PrepApp } from '../components/prep/PrepApp';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Placement Prep — Interview & Aptitude Question Bank</title>
    <meta name="description" content="Interview and aptitude question bank for Deloitte, KPMG, Oracle NetSuite, Sapiens, Capgemini and Cognizant — browse, flashcards, and self-test quizzes." />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/geist/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist/Geist-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist/GeistMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <style>
      html, body { margin: 0; background: var(--canvas); color: var(--ink); }
      body { min-height: 100dvh; }
    </style>
  </head>
  <body>
    <PrepApp client:only="react" />
  </body>
</html>
