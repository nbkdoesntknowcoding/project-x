---
import PublicLayout from '../layouts/PublicLayout.astro';
import { RadialGlow } from '../components/ui/RadialGlow';
import { NoiseOverlay } from '../components/ui/NoiseOverlay';
import { PricingCards } from '../components/pricing/PricingCards';

// Server-side currency detection from Cloudflare CF-IPCountry header.
// Falls back to INR (most of our users are India-based).
const cfCountry = Astro.request.headers.get('cf-ipcountry') ?? 'IN';
const defaultCurrency: 'INR' | 'USD' = cfCountry.toUpperCase() === 'IN' ? 'INR' : 'USD';
---

<PublicLayout
  title="Pricing — Mnema"
  description="Simple plans, honest pricing. Free forever for personal use. Writer seats only — readers always free."
  pathname="/pricing"
>

  <!-- ===== HEADING ===== -->
  <section
    class="relative pt-32 pb-16"
    style="background: var(--surface-base);"
  >
    <RadialGlow cx={50} cy={30} radius={50} tone="soft" intensity={0.7} />
    <NoiseOverlay opacity={0.03} />
    <div
      class="relative max-w-2xl mx-auto px-6 text-center"
      style="z-index: 2;"
    >
      <span
        class="font-mono uppercase block mb-4"
        style="font-size: 11px; letter-spacing: 0.10em; color: var(--text-tertiary);"
      >
        Pricing
      </span>
      <h1
        class="font-sans font-medium"
        style="font-size: var(--display-sm); line-height: 1.06; letter-spacing: -0.025em; color: var(--text-primary); margin-bottom: 16px;"
      >
        Pay for writers.<br />Readers are always free.
      </h1>
      <p
        class="max-w-md mx-auto"
        style="font-size: 15px; line-height: 1.65; color: var(--text-secondary);"
      >
        Only teammates who create and edit docs count as billable seats.
        Reviewers and stakeholders read for free.
      </p>
    </div>
  </section>

  <!-- ===== PLAN CARDS (glass, dark strip) ===== -->
  <section
    style="
      background: #080808;
      padding: 60px 0 80px;
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Ambient glow behind cards -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(255,255,255,0.04) 0%, transparent 70%);
        pointer-events: none;
      "
    ></div>
    <!-- Noise texture -->
    <NoiseOverlay opacity={0.025} />

    <div class="relative max-w-6xl mx-auto px-6" style="z-index: 2;">
      <!-- React island: toggles + cards -->
      <PricingCards defaultCurrency={defaultCurrency} client:load />
    </div>
  </section>

  <!-- ===== GUARANTEE ROW ===== -->
  <section
    style="background: var(--surface-base); padding: 48px 24px;"
  >
    <div
      class="max-w-3xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-12 text-center"
    >
      {[
        { icon: '🔓', title: 'No annual lock-in', body: 'Cancel any time. We prorate the unused days.' },
        { icon: '🪑', title: 'Only writers pay', body: 'Readers (viewers) join for free, always.' },
        { icon: '🌐', title: 'INR or USD', body: 'We auto-detect your region. Change any time.' },
      ].map(item => (
        <div style="max-width: 200px;">
          <div style="font-size: 22px; margin-bottom: 8px;">{item.icon}</div>
          <p style="font-size: 13px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">{item.title}</p>
          <p style="font-size: 12px; color: var(--text-secondary); line-height: 1.6;">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section
    class="max-w-3xl mx-auto px-6 pb-28"
    style="background: var(--surface-base);"
  >
    <h2
      style="font-size: 18px; font-weight: 500; color: var(--text-primary); margin-bottom: 40px;"
    >
      Frequently asked questions
    </h2>

    {[
      {
        q: "What's a writer seat?",
        a: "Any workspace member with the Owner, Admin, or Editor role counts as a writer seat. Viewers (read-only members) are always free — you can add as many as you like.",
      },
      {
        q: "What's an MCP call?",
        a: "Every time Claude searches, reads a doc, or pulls a flow step through Mnema's MCP connector, it counts as one call. A normal hour of conversation typically uses 10–30 calls.",
      },
      {
        q: "What's the difference between Individual and Team?",
        a: "Individual is a flat per-workspace plan — ideal for solo builders. Team is per-writer-seat, so it scales with your team size. Team includes unlimited teammates.",
      },
      {
        q: "Can I switch plans later?",
        a: "Yes. Upgrade or downgrade any time from your workspace settings. Changes take effect immediately; billing adjusts at the next cycle.",
      },
      {
        q: "Is there a free trial?",
        a: "The Free plan is free forever — no trial period needed. Paid plans bill from day one but you can cancel at any time.",
      },
      {
        q: "Where is my data stored?",
        a: "On Neon Postgres in ap-south-1 (Mumbai). We're working on additional regions for teams that need EU or US data residency.",
      },
      {
        q: "Is there an annual discount?",
        a: "Yes. Annual plans give you ~20% off versus monthly. The toggle on this page shows exact pricing for both cycles.",
      },
    ].map((item, i) => (
      <div style={i > 0 ? 'border-top: 1px solid var(--border-subtle);' : ''}>
        <p
          style="font-size: 14px; font-weight: 500; color: var(--text-primary); padding-top: 24px; padding-bottom: 8px;"
        >
          {item.q}
        </p>
        <p
          style="font-size: 14px; color: var(--text-secondary); line-height: 1.65; padding-bottom: 24px;"
        >
          {item.a}
        </p>
      </div>
    ))}
  </section>

</PublicLayout>
