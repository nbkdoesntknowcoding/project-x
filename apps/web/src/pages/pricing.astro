---
import PublicLayout from '../layouts/PublicLayout.astro';
import { RadialGlow } from '../components/ui/RadialGlow';
import { NoiseOverlay } from '../components/ui/NoiseOverlay';
---

<PublicLayout
  title="Pricing — Mnema"
  description="Simple plans, honest pricing. Free forever for personal use."
  pathname="/pricing"
>

  <!-- ===== HEADING ===== -->
  <section class="relative pt-32 pb-20" style="background: var(--surface-base);">
    <RadialGlow cx={50} cy={30} radius={45} tone="soft" intensity={0.8} />
    <NoiseOverlay opacity={0.03} />
    <div
      class="relative max-w-3xl mx-auto px-6 text-center"
      style="z-index: 2;"
    >
      <span
        class="font-mono uppercase block mb-4"
        style="font-size: 11px; letter-spacing: 0.08em; color: var(--text-tertiary);"
      >
        Pricing
      </span>
      <h1 style="font-family: var(--font-display); font-size: var(--display-sm); line-height: 1.05; letter-spacing: -0.02em; font-weight: 400; color: var(--text-primary); margin-bottom: 16px;">
        Simple plans. <em style="font-style: italic;">Honest pricing.</em>
      </h1>
      <p
        class="max-w-lg mx-auto"
        style="font-size: 16px; line-height: 1.6; color: var(--text-secondary);"
      >
        Start free. Upgrade when your team grows past three teammates. No annual contracts.
      </p>
    </div>
  </section>

  <!-- ===== PLAN CARDS ===== -->
  <section class="pb-24" style="background: var(--surface-base);">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-3 gap-4">

      <!-- Free -->
      <article
        style="position: relative; background: var(--surface-overlay); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: 32px;"
      >
        <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">Free</h3>
        <p style="font-size: 13px; color: var(--text-tertiary); margin-bottom: 24px;">For trying it out.</p>

        <div class="flex items-baseline gap-2 mb-1">
          <span style="font-family: var(--font-display); font-size: 44px; line-height: 1; color: var(--text-primary);">$0</span>
          <span style="font-size: 13px; color: var(--text-tertiary);">forever</span>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--border-subtle); margin: 24px 0;" />

        <ul style="list-style: none; padding: 0; margin: 0 0 32px;" class="space-y-2.5">
          {[
            'Up to 3 teammates',
            '100 docs',
            '500 MCP calls / month',
            'Real-time collaboration',
            'Hybrid search',
          ].map(feat => (
            <li class="flex items-center gap-2" style="font-size: 13px; color: var(--text-primary);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1.75" aria-hidden="true">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              {feat}
            </li>
          ))}
        </ul>

        <a
          href="/signup?plan=free"
          class="flex items-center justify-center w-full h-8 font-medium transition-[background] rounded select-none"
          style="font-size: 13px; background: var(--interactive-secondary); color: var(--text-primary); border: 1px solid var(--border-default); border-radius: var(--radius-md);"
          onmouseover="this.style.background='var(--interactive-secondary-hover)'"
          onmouseout="this.style.background='var(--interactive-secondary)'"
        >
          Get started
        </a>
      </article>

      <!-- Pro — recommended -->
      <article
        style="position: relative; background: var(--surface-overlay); border: 1px solid var(--border-strong); border-radius: var(--radius-lg); padding: 32px;"
      >
        <!-- RECOMMENDED pill — inside the card, top-right -->
        <div style="position: absolute; top: 16px; right: 16px;">
          <span
            class="inline-flex items-center gap-1.5 px-2 h-5 font-medium"
            style="font-size: 11px; background: var(--surface-elevated); color: var(--text-tertiary); border: 1px solid var(--border-default); border-radius: var(--radius-full);"
          >
            <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor; display: inline-block;"></span>
            RECOMMENDED
          </span>
        </div>

        <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">Pro</h3>
        <p style="font-size: 13px; color: var(--text-tertiary); margin-bottom: 24px;">For small teams.</p>

        <div class="flex items-baseline gap-2 mb-1">
          <span style="font-family: var(--font-display); font-size: 44px; line-height: 1; color: var(--text-primary);">$15</span>
          <span style="font-size: 13px; color: var(--text-tertiary);">per seat / month</span>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--border-subtle); margin: 24px 0;" />

        <ul style="list-style: none; padding: 0; margin: 0 0 32px;" class="space-y-2.5">
          {[
            'Up to 5 teammates',
            'Unlimited docs',
            '5,000 MCP calls / month',
            'AI autocomplete',
            'Version history',
            'Email support',
          ].map(feat => (
            <li class="flex items-center gap-2" style="font-size: 13px; color: var(--text-primary);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1.75" aria-hidden="true">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              {feat}
            </li>
          ))}
        </ul>

        <a
          href="/signup?plan=pro"
          class="flex items-center justify-center w-full h-8 font-medium transition-[background] rounded select-none"
          style="font-size: 13px; background: var(--interactive-primary); color: var(--interactive-primary-fg); border-radius: var(--radius-md);"
          onmouseover="this.style.background='var(--interactive-primary-hover)'"
          onmouseout="this.style.background='var(--interactive-primary)'"
        >
          Start Pro
        </a>
      </article>

      <!-- Team -->
      <article
        style="position: relative; background: var(--surface-overlay); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: 32px;"
      >
        <h3 style="font-size: 16px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px;">Team</h3>
        <p style="font-size: 13px; color: var(--text-tertiary); margin-bottom: 24px;">For growing companies.</p>

        <div class="flex items-baseline gap-2 mb-1">
          <span style="font-family: var(--font-display); font-size: 44px; line-height: 1; color: var(--text-primary);">$25</span>
          <span style="font-size: 13px; color: var(--text-tertiary);">per seat / month</span>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--border-subtle); margin: 24px 0;" />

        <ul style="list-style: none; padding: 0; margin: 0 0 32px;" class="space-y-2.5">
          {[
            'Unlimited teammates',
            'Unlimited docs',
            'Unlimited MCP calls',
            'AI autocomplete',
            'Priority support',
            'SSO (coming soon)',
          ].map(feat => (
            <li class="flex items-center gap-2" style="font-size: 13px; color: var(--text-primary);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1.75" aria-hidden="true">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              {feat}
            </li>
          ))}
        </ul>

        <a
          href="mailto:hello@theboringpeople.in"
          class="flex items-center justify-center w-full h-8 font-medium transition-[background] rounded select-none"
          style="font-size: 13px; background: var(--interactive-secondary); color: var(--text-primary); border: 1px solid var(--border-default); border-radius: var(--radius-md);"
          onmouseover="this.style.background='var(--interactive-secondary-hover)'"
          onmouseout="this.style.background='var(--interactive-secondary)'"
        >
          Contact sales
        </a>
      </article>

    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="max-w-3xl mx-auto px-6 pb-24" style="background: var(--surface-base);">
    <h2 style="font-size: 18px; font-weight: 500; color: var(--text-primary); margin-bottom: 40px;">
      Frequently asked questions
    </h2>

    {[
      {
        q: "What's an MCP call?",
        a: "Every time Claude searches or reads a doc through Mnema, it counts as one call. A normal hour of conversation typically uses 10–30 calls.",
      },
      {
        q: "Do I need a paid Claude account?",
        a: "You need Claude Pro or higher to use MCP connectors. Mnema connects to your existing Claude account.",
      },
      {
        q: "Can I switch plans later?",
        a: "Yes. Upgrade or downgrade any time from your workspace settings. Changes prorate within the billing cycle.",
      },
      {
        q: "Where is my data stored?",
        a: "On Neon Postgres in ap-south-1 (Mumbai). We're working on additional regions for teams that need EU or US residency.",
      },
      {
        q: "Is there an annual discount?",
        a: "Yes. Annual plans are billed once with a 15% discount. Contact us when you're ready to switch.",
      },
    ].map((item, i) => (
      <div style={i > 0 ? 'border-top: 1px solid var(--border-subtle);' : ''}>
        <p style="font-size: 14px; font-weight: 500; color: var(--text-primary); padding-top: 24px; padding-bottom: 8px;">
          {item.q}
        </p>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.65; padding-bottom: 24px;">
          {item.a}
        </p>
      </div>
    ))}
  </section>

</PublicLayout>
