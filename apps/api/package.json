{
  "name": "@boppl/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,collab,workers -c blue,green,magenta \"npm:dev:api\" \"npm:dev:collab\" \"npm:dev:workers\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:collab": "tsx watch src/collab/server.ts",
    "dev:workers": "tsx watch src/workers/server.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/server.js",
    "start:collab": "node dist/collab/server.js",
    "start:workers": "node dist/workers/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:round-trip": "vitest run src/tests/round-trip",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.74",
    "@anthropic-ai/sdk": "^0.99.0",
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "@boppl/schema": "workspace:*",
    "@boppl/shared": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.0",
    "@hocuspocus/extension-logger": "^4.0.0",
    "@hocuspocus/provider": "^4.0.0",
    "@hocuspocus/server": "^4.0.0",
    "@m2d/md2docx": "^0.0.1",
    "@mistralai/mistralai": "^2.2.5",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.53.1",
    "@types/mime-types": "^3.0.1",
    "@types/turndown": "^5.0.6",
    "@workos-inc/node": "^7.0.0",
    "ai": "^6.0.183",
    "bullmq": "^5.76.8",
    "diff": "^9.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "gpt-tokenizer": "^3.4.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "ioredis": "^5.10.1",
    "iron-session": "^8.0.0",
    "jose": "^5.0.0",
    "juice": "^11.1.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "mime-types": "^3.0.2",
    "nanoid": "^5.0.0",
    "pdfjs-dist": "^6.0.227",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.60.0",
    "postgres": "^3.4.0",
    "razorpay": "^2.9.6",
    "resend": "^6.12.4",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "voyageai": "^0.2.1",
    "yjs": "^13.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "ws": "^8.20.1"
  }
}
