# Postgres (local Docker)
DATABASE_URL=postgresql://boppl:boppl_dev_pw_change_me@localhost:5432/boppl_context

# Redis (local Docker)
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
API_PORT=8080
LOG_LEVEL=debug

# Web
PUBLIC_API_URL=http://localhost:8080

# WorkOS (Staging — copy from workos.com dashboard, Add http://localhost:5173/auth/callback under Redirects)
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me
WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback

# Session sealing (32+ chars; generate via: openssl rand -base64 48)
WORKOS_COOKIE_PASSWORD=replace_with_32_plus_random_characters

# JWT signing (32+ chars; generate similarly)
JWT_SECRET=replace_with_another_32_plus_random_characters
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=http://localhost:8080
# MCP audience accepted on Bearer tokens. Local dev accepts both the REST
# audience and the MCP audience so the browser cookie's JWT can be pasted
# into the MCP Inspector verbatim.
JWT_AUDIENCE_MCP=http://localhost:8080/mcp

# Hocuspocus (local)
COLLAB_PORT=1234
COLLAB_INTERNAL_URL=http://localhost:1234

# Web — browser uses this to find the collab server
PUBLIC_COLLAB_URL=ws://localhost:1234

# MCP (Phase 2.1)
# Wire-protocol version we advertise on initialize. Bump per the MCP spec.
MCP_PROTOCOL_VERSION=2025-11-25
# Canonical externally-visible URL of the api process. The MCP resource
# identifier is `${MCP_BASE_URL}/mcp`. For local dev = http://localhost:8080.
MCP_BASE_URL=http://localhost:8080
# Authorization Server URL advertised in /.well-known/oauth-protected-resource.
# Phase 2.1 placeholder — Phase 2.2 swaps this for the WorkOS AS URL.
MCP_AUTHORIZATION_SERVER=http://localhost:8080
# Origins allowed to POST to /mcp (CSV). MCP Inspector defaults to :6274.
MCP_ORIGIN_ALLOWLIST=http://localhost:5173,http://localhost:6274
