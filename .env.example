# Postgres (local Docker)
DATABASE_URL=postgresql://boppl:boppl_dev_pw_change_me@localhost:5432/boppl_context

# Redis (local Docker)
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
API_PORT=8080
LOG_LEVEL=debug

# Web
PUBLIC_API_URL=http://localhost:8080

# Phase 4.1 — web origin used in invitation accept URLs
WEB_BASE_URL=http://localhost:5173

# WorkOS (Staging — copy from workos.com dashboard, Add http://localhost:5173/auth/callback under Redirects)
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me
WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback

# Session sealing (32+ chars; generate via: openssl rand -base64 48)
WORKOS_COOKIE_PASSWORD=replace_with_32_plus_random_characters

# JWT signing (32+ chars; generate similarly)
JWT_SECRET=replace_with_another_32_plus_random_characters
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=http://localhost:8080
# MCP audience accepted on Bearer tokens. Local dev accepts both the REST
# audience and the MCP audience so the browser cookie's JWT can be pasted
# into the MCP Inspector verbatim.
JWT_AUDIENCE_MCP=http://localhost:8080/mcp

# Hocuspocus (local)
COLLAB_PORT=1234
COLLAB_INTERNAL_URL=http://localhost:1234

# Web — browser uses this to find the collab server
PUBLIC_COLLAB_URL=ws://localhost:1234

# Phase 4.3 — public site URL. Used in OG / Twitter meta and the rel=canonical
# link on every marketing page. Phase D flips this to https://context.theboringpeople.in.
PUBLIC_SITE_URL=http://localhost:5173

# MCP (Phase 2.1)
# Wire-protocol version we advertise on initialize. Bump per the MCP spec.
MCP_PROTOCOL_VERSION=2025-11-25
# Canonical externally-visible URL of the api process. The MCP resource
# identifier is `${MCP_BASE_URL}/mcp`. For local dev = http://localhost:8080.
MCP_BASE_URL=http://localhost:8080
# Authorization Server URL advertised in /.well-known/oauth-protected-resource.
# Phase 2.1 placeholder — Phase 2.2 swaps this for the WorkOS AS URL.
MCP_AUTHORIZATION_SERVER=http://localhost:8080
# Origins allowed to POST to /mcp (CSV). MCP Inspector defaults to :6274.
MCP_ORIGIN_ALLOWLIST=http://localhost:5173,http://localhost:6274

# Voyage AI (embeddings — get from https://dash.voyageai.com)
VOYAGE_API_KEY=your_voyage_api_key_here
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
EMBEDDING_CHUNK_TARGET_TOKENS=500
EMBEDDING_CHUNK_OVERLAP_TOKENS=50
EMBEDDING_BATCH_SIZE=128
EMBEDDING_WORKER_CONCURRENCY=2

# Autocomplete (Phase 3.3 stub, Phase 3.4 production)
AUTOCOMPLETE_DEBOUNCE_MS=350
AUTOCOMPLETE_MAX_PREFIX_CHARS=2000
AUTOCOMPLETE_MAX_SUFFIX_CHARS=500

# Gemini (Phase 3.4 — user obtains from aistudio.google.com)
GEMINI_API_KEY=
AUTOCOMPLETE_MODEL=gemini-2.5-flash-lite
AUTOCOMPLETE_MAX_OUTPUT_TOKENS=60
# CSV of stop sequences. `\n` literal becomes a real newline at parse time.
AUTOCOMPLETE_STOP_SEQUENCES=\n\n

# Rate limits (Phase 3.4)
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_USER_PER_DAY=1000
# 1 unit ≈ $0.0001 of Gemini Flash-Lite cost. 50,000 = $5/tenant/day.
RATE_LIMIT_TENANT_DAILY_UNITS=50000

# Email (Resend) — get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=noreply@mnema.theboringpeople.in

# Billing (Razorpay) — get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_ENVIRONMENT=test
# Error monitoring (Sentry)
SENTRY_DSN=https://your_dsn@sentry.io/your_project
SENTRY_ENVIRONMENT=production
